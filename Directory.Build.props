<Project>
  <!-- Solution-wide build standards for HostsGuard .NET.
       Rock-solid defaults: nullable on, warnings are errors, latest analyzers,
       deterministic builds, and a single shared version. -->
  <PropertyGroup>
    <LangVersion>12.0</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <AnalysisLevel>latest</AnalysisLevel>
    <EnableNETAnalyzers>true</EnableNETAnalyzers>
    <EnforceCodeStyleInBuild>true</EnforceCodeStyleInBuild>
    <Deterministic>true</Deterministic>
    <GenerateDocumentationFile>false</GenerateDocumentationFile>
    <!-- Shared product version — single source of truth for every assembly.
         0.4.0: WFC-parity consent loop (Security 5157/5152 detection →
         dedup/trust broker → top-most consent window → HG_ rule write, with
         Normal/Notify/Learning modes, decision history, and posture safety
         rails), Phase 2 residuals (backup restore, FW activity timeline, orphan
         rebind, mode toggles), Phase 5 packaging (single-file publish, Inno
         service installer, release-smoke, HostsGuard.Cli), and Phase 6
         hardening (fuzz/property suite, security review with ProgramData ACL +
         SSRF guard + posture-restore-on-stop, dependency CVE remediation,
         observability event taxonomy, per-domain 24h sparkline). -->
    <Version>0.4.0</Version>
    <Product>HostsGuard</Product>
    <Company>SysAdminDoc</Company>
    <Authors>SysAdminDoc</Authors>
    <Copyright>Copyright (c) SysAdminDoc. MIT License.</Copyright>
    <NeutralLanguage>en</NeutralLanguage>
  </PropertyGroup>
</Project>
