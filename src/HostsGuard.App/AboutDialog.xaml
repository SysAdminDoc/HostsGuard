<Window x:Class="HostsGuard.App.AboutDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:svc="clr-namespace:HostsGuard.App.Services"
        Style="{StaticResource Hg.Window}"
        Title="{svc:Loc Key=About_Title}"
        Width="540"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        AutomationProperties.Name="{svc:Loc Key=About_AutomationName}">
    <Border Style="{StaticResource Hg.DialogFrame}">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Style="{StaticResource Hg.BrandMark}" Margin="0,0,14,0">
                    <Viewbox Stretch="Uniform">
                        <Grid Width="32" Height="36">
                            <Path Data="M 16 2 L 29 7 V 17 C 29 24 23.5 29.5 16 34 C 8.5 29.5 3 24 3 17 V 7 Z"
                                  Stroke="{DynamicResource Hg.Teal}"
                                  Fill="Transparent"
                                  StrokeThickness="2.4"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round" />
                            <Path Data="M 10 17 L 14 21 L 22.5 12"
                                  Stroke="{DynamicResource Hg.Green}"
                                  StrokeThickness="2.6"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round" />
                        </Grid>
                    </Viewbox>
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="{svc:Loc Key=Xaml_HostsGuard_bf992a7e}"
                               FontSize="24"
                               FontWeight="SemiBold" />
                    <TextBlock Text="{svc:Loc Key=About_Tagline}"
                               Style="{StaticResource Hg.SubText}"
                               FontSize="14"
                               Margin="0,3,0,0" />
                    <Border Style="{StaticResource Hg.Badge}"
                            HorizontalAlignment="Left"
                            Margin="0,9,0,0">
                        <TextBlock x:Name="VersionText"
                                   Foreground="{DynamicResource Hg.Teal}"
                                   FontWeight="SemiBold" />
                    </Border>
                </StackPanel>
            </Grid>

            <TextBlock Grid.Row="1"
                       Text="{svc:Loc Key=About_Description}"
                       Style="{StaticResource Hg.HelperText}"
                       Margin="0,20,0,0" />

            <Border Grid.Row="2"
                    Style="{StaticResource Hg.StatusStrip}"
                    Margin="0,18,0,0"
                    Padding="14,12">
                <StackPanel>
                    <TextBlock Text="{svc:Loc Key=About_ProtectionTitle}"
                               Style="{StaticResource Hg.SectionTitle}" />
                    <TextBlock Text="{svc:Loc Key=About_ProtectionBody}"
                               Style="{StaticResource Hg.HelperText}"
                               Margin="0,4,0,0" />
                    <Border Height="1" Background="{DynamicResource Hg.S0}" Margin="0,12" />
                    <TextBlock Text="{svc:Loc Key=About_PrivacyTitle}"
                               Style="{StaticResource Hg.SectionTitle}" />
                    <TextBlock Text="{svc:Loc Key=About_PrivacyBody}"
                               Style="{StaticResource Hg.HelperText}"
                               Margin="0,4,0,0" />
                </StackPanel>
            </Border>

            <Grid Grid.Row="3" Margin="0,20,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="1"
                        Content="{svc:Loc Key=About_OpenGitHub}"
                        MinWidth="112"
                        Margin="0,0,8,0"
                        Click="OnOpenGitHub" />
                <Button Grid.Column="2"
                        x:Name="CloseButton"
                        Content="{svc:Loc Key=About_Close}"
                        MinWidth="96"
                        Style="{StaticResource Hg.AccentButton}"
                        IsDefault="True"
                        IsCancel="True"
                        Click="OnClose" />
            </Grid>
        </Grid>
    </Border>
</Window>
