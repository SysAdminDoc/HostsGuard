<Window x:Class="HostsGuard.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:tb="http://www.hardcodet.net/taskbar"
        xmlns:vm="clr-namespace:HostsGuard.App.ViewModels"
        x:Name="Root"
        Style="{StaticResource Hg.Window}"
        Title="HostsGuard" Height="800" Width="1280"
        MinHeight="680" MinWidth="1080"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:svc="clr-namespace:HostsGuard.App.Services"
        mc:Ignorable="d">
    <Window.Resources>
        <svc:PointsTextConverter x:Key="PointsConverter" />
        <svc:SeriesBrushConverter x:Key="SeriesBrush" />
        <svc:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVis" />
        <svc:EmptyStateVisibilityConverter x:Key="EmptyStateVis" />
        <svc:ObjectPresentBooleanConverter x:Key="ObjectPresentBool" />
    </Window.Resources>
    <Grid>
        <tb:TaskbarIcon x:Name="Tray"
                        IconSource="pack://application:,,,/HostsGuard.App;component/Assets/icon.ico"
                        ToolTipText="HostsGuard"
                        TrayMouseDoubleClick="OnTrayOpen">
            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu Opened="OnTrayMenuOpened">
                    <MenuItem Header="Open HostsGuard" Click="OnTrayOpen" />
                    <Separator />
                    <MenuItem Header="Filtering mode">
                        <MenuItem x:Name="TrayModeNormal" Header="Normal — enforce silently" Tag="normal" Click="OnTrayMode" />
                        <MenuItem x:Name="TrayModeNotify" Header="Notify — prompt on new connections" Tag="notify" Click="OnTrayMode" />
                        <MenuItem x:Name="TrayModeLearning" Header="Learning — auto-allow and record" Tag="learning" Click="OnTrayMode" />
                        <MenuItem Header="Learning — 15 min, then lock" Tag="learning:15" Click="OnTrayMode" />
                        <MenuItem Header="Learning — 1 hour, then lock" Tag="learning:60" Click="OnTrayMode" />
                    </MenuItem>
                    <MenuItem Header="Global outbound">
                        <MenuItem Header="Block all outbound" Tag="block-all" Click="OnTrayGlobalMode" />
                        <MenuItem Header="Allow all outbound" Tag="allow-all" Click="OnTrayGlobalMode" />
                    </MenuItem>
                    <Separator />
                    <MenuItem Header="Exit" Click="OnTrayExit" />
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
        </tb:TaskbarIcon>

        <DockPanel>
            <DockPanel.LayoutTransform>
                <ScaleTransform ScaleX="{Binding UiScale}" ScaleY="{Binding UiScale}" />
            </DockPanel.LayoutTransform>

            <!-- Menu bar -->
            <Menu DockPanel.Dock="Top">
                <MenuItem Header="{svc:Loc Key=Menu_File, Default=_File}">
                    <MenuItem Header="Import hosts file…" Command="{Binding ImportHostsFileCommand}"
                              ToolTip="Replace the live hosts file with a picked file (backs up the current one first)" />
                    <MenuItem Header="Export hosts file…" Command="{Binding ExportHostsFileCommand}" />
                    <MenuItem Header="Export managed domains (JSON)…" Command="{Binding ExportDomainsCommand}" />
                    <MenuItem Header="Export AI knowledge" Command="{Binding Tools.ExportAiKnowledgeCommand}" />
                    <Separator />
                    <MenuItem Header="Export policy (JSON)…" Command="{Binding ExportPolicyCommand}"
                              ToolTip="Save the whole policy — domains, firewall rules, schedules, profiles, locks, subscriptions — as one portable JSON file" />
                    <MenuItem Header="Import policy (JSON)…" Command="{Binding ImportPolicyCommand}"
                              ToolTip="Reconstruct the policy from an exported JSON file (merges into the current machine)" />
                    <Separator />
                    <MenuItem Header="Save hosts file" Command="{Binding RawHosts.SaveCommand}"
                              ToolTip="Write unsaved Raw Editor changes to the hosts file" />
                    <MenuItem Header="Backup hosts file" Command="{Binding Tools.BackupHostsCommand}" />
                    <Separator />
                    <MenuItem Header="Exit" Click="OnTrayExit" />
                </MenuItem>
                <MenuItem Header="{svc:Loc Key=Menu_View, Default=_View}">
                    <MenuItem Header="Group by root (activity)" IsCheckable="True" IsChecked="{Binding Activity.GroupByRoot}" />
                    <MenuItem Header="Hide blocked (activity)" IsCheckable="True" IsChecked="{Binding Activity.HideBlocked}" />
                    <MenuItem Header="Show hidden (activity)" IsCheckable="True" IsChecked="{Binding Activity.ShowHidden}" />
                    <Separator />
                    <MenuItem Header="Group by app (connections)" IsCheckable="True" IsChecked="{Binding FwActivity.GroupByApp}" />
                    <MenuItem Header="Resolve IPs (connections)" IsCheckable="True" IsChecked="{Binding FwActivity.ResolveIps}" />
                    <Separator />
                    <MenuItem Header="UI scale" ItemsSource="{x:Static vm:MainViewModel.UiScaleChoices}">
                        <MenuItem.ItemContainerStyle>
                            <Style TargetType="MenuItem" BasedOn="{StaticResource {x:Type MenuItem}}">
                                <Setter Property="Header" Value="{Binding}" />
                                <Setter Property="HeaderStringFormat" Value="{}{0}%" />
                                <Setter Property="Command"
                                        Value="{Binding DataContext.SetScaleCommand, RelativeSource={RelativeSource AncestorType=Menu}}" />
                                <Setter Property="CommandParameter" Value="{Binding}" />
                            </Style>
                        </MenuItem.ItemContainerStyle>
                    </MenuItem>
                    <MenuItem Header="Toggle theme" Command="{Binding ToggleThemeCommand}" />
                    <MenuItem Header="{svc:Loc Key=Menu_Language, Default=Language}">
                        <MenuItem Header="System default" Command="{Binding SetLanguageCommand}" CommandParameter="" />
                        <MenuItem Header="English" Command="{Binding SetLanguageCommand}" CommandParameter="en" />
                        <MenuItem Header="Español" Command="{Binding SetLanguageCommand}" CommandParameter="es" />
                    </MenuItem>
                    <Separator />
                    <MenuItem Header="Reset view" Command="{Binding ResetViewCommand}"
                              ToolTip="Clear every filter and toggle, back to defaults at 100% scale" />
                    <MenuItem Header="Refresh all" Command="{Binding RefreshAllCommand}" />
                </MenuItem>
                <MenuItem Header="_Tools">
                    <MenuItem Header="Run diagnostics" Command="{Binding RunDiagnosticsCommand}" />
                    <MenuItem Header="Flush DNS" Command="{Binding Tools.FlushDnsCommand}" />
                    <MenuItem Header="Export support bundle" Command="{Binding Tools.ExportBundleCommand}" />
                    <Separator />
                    <MenuItem Header="Check for updates" Command="{Binding CheckForUpdatesCommand}" />
                </MenuItem>
                <MenuItem Header="{svc:Loc Key=Menu_Help, Default=_Help}">
                    <MenuItem Header="Check for updates" Command="{Binding CheckForUpdatesCommand}" />
                    <MenuItem Header="Open GitHub repository" Click="OnOpenGitHub" />
                    <MenuItem Header="About HostsGuard" Click="OnAbout" />
                </MenuItem>
            </Menu>

            <!-- Status bar -->
            <StatusBar DockPanel.Dock="Bottom">
                <StatusBarItem>
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="9" Height="9" Margin="4,0,7,0" VerticalAlignment="Center">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="{DynamicResource Hg.Red}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                            <Setter Property="Fill" Value="{DynamicResource Hg.Green}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock Text="{Binding ConnectionText}" Style="{StaticResource Hg.SubText}" />
                    </StackPanel>
                </StatusBarItem>
                <Separator />
                <StatusBarItem>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Style="{StaticResource Hg.SubText}"
                                   Text="{Binding HostsBlocked, Mode=OneWay, StringFormat='Hosts file: {0}'}"
                                   ToolTip="Blocked entries currently written to the Windows hosts file" />
                        <TextBlock Style="{StaticResource Hg.SubText}" Margin="14,0,0,0"
                                   Text="{Binding DbBlocked, Mode=OneWay, StringFormat='Blocked: {0}'}"
                                   ToolTip="Managed domains set to blocked" />
                        <TextBlock Style="{StaticResource Hg.SubText}" Margin="14,0,0,0"
                                   Text="{Binding DbAllowed, Mode=OneWay, StringFormat='Allowed: {0}'}"
                                   ToolTip="Managed domains set to allowed — these always win over blocklists" />
                    </StackPanel>
                </StatusBarItem>
                <Separator />
                <StatusBarItem>
                    <TextBlock Text="{Binding FilteringModeText}" Style="{StaticResource Hg.SubText}"
                               ToolTip="Filtering mode — switch from the tray menu" />
                </StatusBarItem>
                <StatusBarItem HorizontalAlignment="Right">
                    <TextBlock Text="{Binding ServiceVersion, StringFormat='service {0}'}"
                               Style="{StaticResource Hg.DimText}" />
                </StatusBarItem>
            </StatusBar>

            <!-- Main workbench -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource Hg.SideRail}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Hidden">
                            <StackPanel>
                                <StackPanel HorizontalAlignment="Center" Margin="0,6,0,10">
                                    <Border Width="54"
                                            Height="54"
                                            CornerRadius="16"
                                            Background="{DynamicResource Hg.Mauve}"
                                            Padding="8"
                                            HorizontalAlignment="Center">
                                        <Image Source="pack://application:,,,/HostsGuard.App;component/Assets/icon.ico"
                                               Stretch="Uniform" />
                                    </Border>
                                    <TextBlock Text="HostsGuard"
                                               FontSize="18"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Center"
                                               Margin="0,8,0,0" />
                                    <TextBlock Text="{Binding AppVersion, StringFormat='v{0}'}"
                                               Style="{StaticResource Hg.DimText}"
                                               HorizontalAlignment="Center"
                                               Margin="0,2,0,0" />
                                </StackPanel>

                                <Border Style="{StaticResource Hg.RailDivider}" />

                                <Border Style="{StaticResource Hg.RailTile}">
                                    <StackPanel>
                                        <TextBlock Text="Service health" Style="{StaticResource Hg.Kicker}" />
                                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                            <Ellipse Width="16" Height="16" Margin="0,0,8,0" VerticalAlignment="Center">
                                                <Ellipse.Style>
                                                    <Style TargetType="Ellipse">
                                                        <Setter Property="Fill" Value="{DynamicResource Hg.Red}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                                                <Setter Property="Fill" Value="{DynamicResource Hg.Green}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Ellipse.Style>
                                            </Ellipse>
                                            <TextBlock Text="{Binding ConnectionStateTitle}"
                                                       Style="{StaticResource Hg.RailValue}"
                                                       Foreground="{DynamicResource Hg.Green}" />
                                        </StackPanel>
                                        <TextBlock Text="HostsGuardSvc" Style="{StaticResource Hg.DimText}" Margin="0,8,0,0" />
                                        <TextBlock Text="Running"
                                                   Visibility="{Binding IsConnected, Converter={StaticResource BoolToVis}}"
                                                   Style="{StaticResource Hg.RailActionText}"
                                                   Foreground="{DynamicResource Hg.Green}" />
                                        <TextBlock Text="{Binding ServiceVersion, StringFormat='v{0}', TargetNullValue='service offline'}"
                                                   Style="{StaticResource Hg.DimText}" />
                                        <Button Content="Reconnect"
                                                Command="{Binding ConnectCommand}"
                                                Visibility="{Binding IsConnected, Converter={StaticResource InverseBoolToVis}}"
                                                Margin="0,10,0,0"
                                                HorizontalAlignment="Stretch" />
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource Hg.RailTile}">
                                    <StackPanel>
                                        <TextBlock Text="Filtering mode" Style="{StaticResource Hg.Kicker}" />
                                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                            <TextBlock Text="◆"
                                                       Foreground="{DynamicResource Hg.Mauve}"
                                                       FontSize="16"
                                                       Margin="0,0,8,0"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Text="{Binding FilteringModeTitle}"
                                                       Style="{StaticResource Hg.RailValue}"
                                                       Foreground="{DynamicResource Hg.Mauve}" />
                                        </StackPanel>
                                        <TextBlock Text="{Binding FilteringModeText}"
                                                   Style="{StaticResource Hg.HelperText}"
                                                   Margin="0,6,0,10" />
                                        <Button Content="Change mode"
                                                Command="{Binding SetFilteringModeCommand}"
                                                CommandParameter="notify"
                                                HorizontalAlignment="Stretch"
                                                Padding="7,3"
                                                ToolTip="Switch to Notify mode" />
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource Hg.RailTile}">
                                    <StackPanel>
                                        <TextBlock Text="Global posture" Style="{StaticResource Hg.Kicker}" />
                                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                            <TextBlock Text="◆"
                                                       Foreground="{DynamicResource Hg.Teal}"
                                                       FontSize="16"
                                                       Margin="0,0,8,0"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Text="Default allow"
                                                       Style="{StaticResource Hg.RailValue}"
                                                       Foreground="{DynamicResource Hg.Teal}" />
                                        </StackPanel>
                                        <TextBlock Text="Outbound" Style="{StaticResource Hg.DimText}" Margin="0,6,0,10" />
                                        <Button Content="Block all outbound"
                                                Command="{Binding SetGlobalModeCommand}"
                                                CommandParameter="block-all"
                                                HorizontalAlignment="Stretch"
                                                Padding="7,3"
                                                ToolTip="Block new outbound traffic unless an allow rule covers it" />
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource Hg.RailTile}">
                                    <StackPanel>
                                        <TextBlock Text="Quick actions" Style="{StaticResource Hg.Kicker}" Margin="0,0,0,8" />
                                        <Button Style="{StaticResource Hg.RailLinkButton}"
                                                Command="{Binding Tools.FlushDnsCommand}"
                                                HorizontalContentAlignment="Left"
                                                Margin="0,0,0,4">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="↻" Margin="0,0,8,0" />
                                                <TextBlock Text="Flush DNS" />
                                            </StackPanel>
                                        </Button>
                                        <Button Style="{StaticResource Hg.RailLinkButton}"
                                                Command="{Binding RunDiagnosticsCommand}"
                                                HorizontalContentAlignment="Left"
                                                Margin="0,0,0,4">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="◎" Margin="0,0,8,0" />
                                                <TextBlock Text="Run diagnostics" />
                                            </StackPanel>
                                        </Button>
                                        <Button Style="{StaticResource Hg.RailLinkButton}"
                                                Command="{Binding Tools.ExportBundleCommand}"
                                                HorizontalContentAlignment="Left"
                                                Margin="0,0,0,4">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="⇧" Margin="0,0,8,0" />
                                                <TextBlock Text="Export support bundle" />
                                            </StackPanel>
                                        </Button>
                                        <Button Style="{StaticResource Hg.RailLinkButton}"
                                                Command="{Binding CheckForUpdatesCommand}"
                                                HorizontalContentAlignment="Left">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="⟳" Margin="0,0,8,0" />
                                                <TextBlock Text="Check for updates" />
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>

                        <StackPanel Grid.Row="1">
                            <Border Style="{StaticResource Hg.RailDivider}" Margin="0,8,0,10" />
                            <UniformGrid Columns="3">
                                <Button Content="⟳"
                                        Width="38"
                                        Height="34"
                                        MinHeight="34"
                                        Padding="0"
                                        Command="{Binding RefreshAllCommand}"
                                        ToolTip="Refresh all" />
                                <Button Content="☾"
                                        Width="38"
                                        Height="34"
                                        MinHeight="34"
                                        Padding="0"
                                        Command="{Binding ToggleThemeCommand}"
                                        Margin="6,0,0,0"
                                        ToolTip="Switch theme" />
                                <Button Content="≡"
                                        Width="38"
                                        Height="34"
                                        MinHeight="34"
                                        Padding="0"
                                        Command="{Binding ResetViewCommand}"
                                        Margin="6,0,0,0"
                                        ToolTip="Reset view" />
                            </UniformGrid>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource Hg.ShellSurface}">
                    <Grid>
            <TabControl x:Name="MainTabs" Margin="0"
                        IsEnabled="{Binding IsConnected}">
                <TabItem>
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="◎" Style="{StaticResource Hg.MainTabIcon}" />
                            <TextBlock Text="{svc:Loc Key=Tab_HostsActivity, Default=Hosts Activity}" />
                        </StackPanel>
                    </TabItem.Header>
                    <Grid Margin="4" DataContext="{Binding Activity}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" MinHeight="180" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Style="{StaticResource Hg.CommandBar}" Margin="0,0,0,8">
                        <WrapPanel VerticalAlignment="Center">
                            <TextBox Text="{Binding Filter, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource Hg.HintBox}"
                                     Width="160"
                                     Tag="Search domains"
                                     AutomationProperties.Name="Search DNS activity"
                                     ToolTip="Filters as you type - supports field:value, !term, and field!=value" />
                            <Button Content="AI purposes"
                                    Command="{Binding ResearchPurposesCommand}"
                                    Padding="10,5"
                                    Margin="6,0,0,0"
                                    ToolTip="Have DeepSeek research what each domain without a Purpose is for (results are saved to the AI knowledge log)" />
                            <Button Content="Block"
                                    Style="{StaticResource Hg.DangerButton}"
                                    Padding="10,5"
                                    Command="{Binding BlockSelectedCommand}"
                                    CommandParameter="{Binding SelectedItems, ElementName=ActivityGrid}"
                                    IsEnabled="{Binding SelectedItem, ElementName=ActivityGrid, Converter={StaticResource ObjectPresentBool}}"
                                    Margin="6,0,0,0" />
                            <Button Content="Allow"
                                    Style="{StaticResource Hg.SuccessButton}"
                                    Padding="10,5"
                                    Command="{Binding AllowSelectedCommand}"
                                    CommandParameter="{Binding SelectedItems, ElementName=ActivityGrid}"
                                    IsEnabled="{Binding SelectedItem, ElementName=ActivityGrid, Converter={StaticResource ObjectPresentBool}}"
                                    Margin="6,0,8,0" />
                            <CheckBox Content="Reverse DNS" Margin="6,0,0,0"
                                      VerticalAlignment="Center"
                                      IsChecked="{Binding HideReverseDns}"
                                      AutomationProperties.Name="Hide reverse DNS PTR lookups"
                                      ToolTip="Hide reverse-DNS PTR lookups (*.in-addr.arpa) - background noise, not real destinations" />
                            <CheckBox Content="Group root" Margin="6,0,0,0"
                                      VerticalAlignment="Center"
                                      IsChecked="{Binding GroupByRoot}"
                                      AutomationProperties.Name="Group feed rows by root domain"
                                      ToolTip="Collapse subdomains under their root" />
                            <CheckBox Content="Blocked" Margin="6,0,0,0"
                                      VerticalAlignment="Center"
                                      IsChecked="{Binding BlockedOnly}"
                                      AutomationProperties.Name="Show only blocked domains" />
                            <CheckBox Content="Hide blocked" Margin="6,0,0,0"
                                      VerticalAlignment="Center"
                                      IsChecked="{Binding HideBlocked}"
                                      AutomationProperties.Name="Hide already-blocked domains" />
                            <CheckBox Content="Hidden" Margin="6,0,0,0"
                                      VerticalAlignment="Center"
                                      IsChecked="{Binding ShowHidden}" />
                            <Button Content="Refresh"
                                    Command="{Binding RefreshCommand}"
                                    Padding="10,5"
                                    Margin="6,0,0,0" />
                        </WrapPanel>
                        </Border>

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="250" />
                            </Grid.ColumnDefinitions>

                        <DataGrid Grid.Column="0" x:Name="ActivityGrid" ItemsSource="{Binding RowsView}"
                                  SelectedIndex="0"
                                  AutomationProperties.Name="DNS activity feed"
                                  IsVisibleChanged="OnGridVisible">
                            <DataGrid.GroupStyle>
                                <!-- Flat section headers: a styled band per root with the
                                     normal grid rows directly beneath — same layout as the
                                     ungrouped feed, just sectioned. Right-click hides the root. -->
                                <GroupStyle>
                                    <GroupStyle.ContainerStyle>
                                        <Style TargetType="{x:Type GroupItem}">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="{x:Type GroupItem}">
                                                        <StackPanel>
                                                            <Border Background="{DynamicResource Hg.Mantle}"
                                                                    BorderBrush="{DynamicResource Hg.S0}"
                                                                    BorderThickness="0,1,0,1"
                                                                    Padding="8,4" Cursor="Hand"
                                                                    Tag="{Binding RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                                    ToolTip="Right-click to hide this group">
                                                                <Border.ContextMenu>
                                                                    <ContextMenu>
                                                                        <MenuItem Header="Hide this group"
                                                                                  Command="{Binding PlacementTarget.Tag.DataContext.HideGroupCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                                  CommandParameter="{Binding Name}"
                                                                                  ToolTip="Hide every domain currently listed under this root (remembered)" />
                                                                    </ContextMenu>
                                                                </Border.ContextMenu>
                                                                <StackPanel Orientation="Horizontal">
                                                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                                                               Foreground="{DynamicResource Hg.Blue}" />
                                                                    <TextBlock Text="{Binding ItemCount, StringFormat=' — {0} domains'}"
                                                                               Style="{StaticResource Hg.DimText}" />
                                                                </StackPanel>
                                                            </Border>
                                                            <ItemsPresenter />
                                                        </StackPanel>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </GroupStyle.ContainerStyle>
                                </GroupStyle>
                            </DataGrid.GroupStyle>
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="Foreground" Value="{DynamicResource Hg.Text}" />
                                    <Setter Property="MinHeight" Value="32" />
                                    <Setter Property="ToolTip" Value="{Binding Reason}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Status}" Value="blocked">
                                            <Setter Property="Background" Value="{DynamicResource Hg.DangerSoft}" />
                                        </DataTrigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource Hg.S0}" />
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource Hg.Sel}" />
                                        </Trigger>
                                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource Hg.Sel}" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>
                            <DataGrid.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Block"
                                              Command="{Binding PlacementTarget.DataContext.BlockSelectedCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding PlacementTarget.SelectedItems, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              ToolTip="Block every selected domain (multi-select with Ctrl/Shift)" />
                                    <MenuItem Header="Block root"
                                              Command="{Binding PlacementTarget.DataContext.BlockRootCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding PlacementTarget.SelectedItem.Domain, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                    <MenuItem Header="Allow"
                                              Command="{Binding PlacementTarget.DataContext.AllowSelectedCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding PlacementTarget.SelectedItems, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              ToolTip="Allow every selected domain — remove from hosts AND whitelist against future blocklists (multi-select with Ctrl/Shift)" />
                                    <MenuItem Header="Unblock (remove from hosts)"
                                              Command="{Binding PlacementTarget.DataContext.UnblockSelectedCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding PlacementTarget.SelectedItems, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              ToolTip="Remove the selected domains' 0.0.0.0 entries from the hosts file so they resolve again — for troubleshooting a page you may have over-blocked" />
                                    <MenuItem Header="Temp allow">
                                        <MenuItem Header="15 minutes"
                                                  Command="{Binding PlacementTarget.DataContext.TempAllow15Command, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding PlacementTarget.SelectedItem.Domain, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                        <MenuItem Header="1 hour"
                                                  Command="{Binding PlacementTarget.DataContext.TempAllow60Command, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding PlacementTarget.SelectedItem.Domain, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                        <MenuItem Header="8 hours"
                                                  Command="{Binding PlacementTarget.DataContext.TempAllow480Command, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding PlacementTarget.SelectedItem.Domain, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                    </MenuItem>
                                    <Separator />
                                    <MenuItem Header="Hide domain(s)"
                                              Command="{Binding PlacementTarget.DataContext.HideSelectedCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding PlacementTarget.SelectedItems, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              ToolTip="Hide every selected domain from the feed (remembered) — multi-select with Ctrl/Shift" />
                                    <MenuItem Header="Hide root"
                                              Command="{Binding PlacementTarget.DataContext.HideRootCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding PlacementTarget.SelectedItem.Domain, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              ToolTip="Hide the whole root, including future subdomains (remembered)" />
                                    <MenuItem Header="Hide this group"
                                              Command="{Binding PlacementTarget.DataContext.HideGroupCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding PlacementTarget.SelectedItem.Root, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              ToolTip="Hide every domain currently listed under this row's root (keyboard-accessible group hide)" />
                                    <MenuItem Header="Unhide root"
                                              Command="{Binding PlacementTarget.DataContext.UnhideRootCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding PlacementTarget.SelectedItem.Domain, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                    <Separator />
                                    <MenuItem Header="Fix purpose…"
                                              Command="{Binding PlacementTarget.DataContext.FixPurposeCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              ToolTip="Correct this domain's purpose — remembered as a user override that beats the AI" />
                                    <MenuItem Header="Fix category…"
                                              Command="{Binding PlacementTarget.DataContext.FixCategoryCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              ToolTip="Correct this domain's category — remembered as a user override that beats the AI" />
                                    <Separator />
                                    <MenuItem Header="Research online">
                                        <MenuItem Header="Google"
                                                  Command="{Binding PlacementTarget.DataContext.ResearchGoogleCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding PlacementTarget.SelectedItem.Domain, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                        <MenuItem Header="VirusTotal"
                                                  Command="{Binding PlacementTarget.DataContext.ResearchVirusTotalCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding PlacementTarget.SelectedItem.Domain, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                        <MenuItem Header="who.is"
                                                  Command="{Binding PlacementTarget.DataContext.ResearchWhoisCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding PlacementTarget.SelectedItem.Domain, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                    </MenuItem>
                                </ContextMenu>
                            </DataGrid.ContextMenu>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Domain" Binding="{Binding Domain}" Width="170">
                                    <DataGridTextColumn.ElementStyle>
                                        <!-- Yellow = undecided domain the reference blocklists would
                                             block: a candidate worth reviewing. -->
                                        <Style TargetType="TextBlock">
                                            <Setter Property="ToolTip" Value="{Binding BlocklistsTip}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding BlocklistsText}" Value="">
                                                    <Setter Property="ToolTip" Value="{x:Null}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsBlockCandidate}" Value="True">
                                                    <Setter Property="Foreground" Value="{DynamicResource Hg.Yellow}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Purpose" Binding="{Binding Purpose}" Width="135">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource Hg.Dim}" />
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Status" Binding="{Binding StatusText}" Width="80">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource Hg.Dim}" />
                                            <Style.Triggers>
                                                <!-- Blocked stands out red so an over-block is easy to spot when troubleshooting. -->
                                                <DataTrigger Binding="{Binding Status}" Value="allowed">
                                                    <Setter Property="Foreground" Value="{DynamicResource Hg.Green}" />
                                                    <Setter Property="FontWeight" Value="SemiBold" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="blocked">
                                                    <Setter Property="Foreground" Value="{DynamicResource Hg.Red}" />
                                                    <Setter Property="FontWeight" Value="SemiBold" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="">
                                                    <Setter Property="Foreground" Value="{DynamicResource Hg.Sub}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Process" Binding="{Binding Process}" Width="95" />
                                <DataGridTextColumn Header="Hits" Binding="{Binding Hits}" Width="45" />
                                <DataGridTextColumn Header="Data" Binding="{Binding DataText}" Width="64" IsReadOnly="True" />
                                <DataGridTemplateColumn Header="24h" Width="96">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Viewbox Width="84" Height="18" Stretch="Fill" HorizontalAlignment="Left"
                                                     ToolTip="{Binding SparklineTip}">
                                                <Canvas Width="120" Height="20">
                                                    <Polyline Points="{Binding SparklinePoints, Converter={StaticResource PointsConverter}}"
                                                              Stroke="{DynamicResource Hg.Series1}"
                                                              StrokeThickness="1.2" StrokeLineJoin="Round" />
                                                </Canvas>
                                            </Viewbox>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Last seen" Binding="{Binding LastSeenText}" Width="75" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <Border Grid.Column="0"
                                Style="{StaticResource Hg.EmptyState}"
                                Visibility="{Binding Rows.Count, Converter={StaticResource EmptyStateVis}}">
                            <StackPanel>
                                <TextBlock Text="No DNS activity yet"
                                           Style="{StaticResource Hg.SectionTitle}"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,4" />
                                <TextBlock Text="HostsGuard will fill this feed as DNS events arrive. Check the service connection, then refresh if activity should already be available."
                                           Style="{StaticResource Hg.EmptyText}" />
                            </StackPanel>
                        </Border>

                            <Border Grid.Column="1"
                                    Style="{StaticResource Hg.Inspector}"
                                    Margin="10,0,0,0"
                                    DataContext="{Binding SelectedItem, ElementName=ActivityGrid}">
                                <Grid>
                                    <StackPanel>
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding}" Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>
                                        <DockPanel LastChildFill="True">
                                            <Button DockPanel.Dock="Right"
                                                    Content="×"
                                                    Style="{StaticResource Hg.CloseIconButton}"
                                                    ToolTip="Clear selection"
                                                    Click="OnClearActivitySelection" />
                                            <TextBlock DockPanel.Dock="Left"
                                                       Text="◎"
                                                       Foreground="{DynamicResource Hg.Teal}"
                                                       FontSize="18"
                                                       Margin="0,0,8,0"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Text="{Binding Domain, TargetNullValue='Select a DNS row'}"
                                                       FontSize="16"
                                                       FontWeight="SemiBold"
                                                       TextWrapping="Wrap" />
                                        </DockPanel>
                                        <TextBlock Text="{Binding Root, StringFormat='Root: {0}', TargetNullValue='Right-click rows for full action menu'}"
                                                   Style="{StaticResource Hg.DimText}"
                                                   Margin="0,5,0,0"
                                                   TextWrapping="Wrap" />

                                        <Grid Margin="0,12,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Style="{StaticResource Hg.Badge}" Margin="0,0,6,0">
                                                <TextBlock Text="{Binding Status, TargetNullValue='No status'}"
                                                           Style="{StaticResource Hg.DimText}" />
                                            </Border>
                                            <Border Grid.Column="1" Style="{StaticResource Hg.Badge}" Margin="6,0,0,0">
                                                <TextBlock Text="{Binding BlocklistsText, TargetNullValue='No list hits'}"
                                                           Style="{StaticResource Hg.DimText}" />
                                            </Border>
                                        </Grid>

                                        <DockPanel Margin="0,10,0,3" LastChildFill="True">
                                            <Button DockPanel.Dock="Right"
                                                    Content="AI analyze"
                                                    Command="{Binding DataContext.ResearchPurposesCommand, ElementName=ActivityGrid}"
                                                    Padding="8,2"
                                                    MinHeight="24" />
                                            <TextBlock Text="Purpose" Style="{StaticResource Hg.InspectorLabel}" Margin="0" />
                                        </DockPanel>
                                        <TextBlock Text="{Binding Purpose, TargetNullValue='Not classified yet'}"
                                                   Style="{StaticResource Hg.InspectorValue}" />

                                        <UniformGrid Columns="2" Margin="0,12,0,0">
                                            <Border Style="{StaticResource Hg.MetricTile}">
                                                <StackPanel>
                                                    <TextBlock Text="HITS" Style="{StaticResource Hg.Kicker}" />
                                                    <TextBlock Text="{Binding Hits}" Style="{StaticResource Hg.MetricValue}" />
                                                </StackPanel>
                                            </Border>
                                            <Border Style="{StaticResource Hg.MetricTile}" Margin="0,0,0,8">
                                                <StackPanel>
                                                    <TextBlock Text="LAST SEEN" Style="{StaticResource Hg.Kicker}" />
                                                    <TextBlock Text="{Binding LastSeenText, TargetNullValue='-'}"
                                                               Style="{StaticResource Hg.InspectorValue}" />
                                                </StackPanel>
                                            </Border>
                                        </UniformGrid>

                                        <TextBlock Text="Actions" Style="{StaticResource Hg.InspectorLabel}" />
                                        <StackPanel>
                                            <Button Content="Allow domain"
                                                    Style="{StaticResource Hg.SuccessButton}"
                                                    Margin="0,0,0,6"
                                                    HorizontalAlignment="Stretch"
                                                    Command="{Binding DataContext.AllowSelectedCommand, ElementName=ActivityGrid}"
                                                    CommandParameter="{Binding SelectedItems, ElementName=ActivityGrid}"
                                                    IsEnabled="{Binding SelectedItem, ElementName=ActivityGrid, Converter={StaticResource ObjectPresentBool}}" />
                                            <Button Content="Block domain"
                                                    Style="{StaticResource Hg.DangerButton}"
                                                    Margin="0,0,0,6"
                                                    HorizontalAlignment="Stretch"
                                                    Command="{Binding DataContext.BlockSelectedCommand, ElementName=ActivityGrid}"
                                                    CommandParameter="{Binding SelectedItems, ElementName=ActivityGrid}"
                                                    IsEnabled="{Binding SelectedItem, ElementName=ActivityGrid, Converter={StaticResource ObjectPresentBool}}" />
                                            <Button Content="Temp allow..."
                                                    Margin="0,0,0,6"
                                                    HorizontalAlignment="Stretch"
                                                    Command="{Binding DataContext.TempAllow60Command, ElementName=ActivityGrid}"
                                                    CommandParameter="{Binding Domain}"
                                                    IsEnabled="{Binding SelectedItem, ElementName=ActivityGrid, Converter={StaticResource ObjectPresentBool}}" />
                                            <Button Content="Hide domain"
                                                    Margin="0,0,0,6"
                                                    HorizontalAlignment="Stretch"
                                                    Command="{Binding DataContext.HideSelectedCommand, ElementName=ActivityGrid}"
                                                    CommandParameter="{Binding SelectedItems, ElementName=ActivityGrid}"
                                                    IsEnabled="{Binding SelectedItem, ElementName=ActivityGrid, Converter={StaticResource ObjectPresentBool}}" />
                                            <Button Content="Research"
                                                    HorizontalAlignment="Stretch"
                                                    Command="{Binding DataContext.ResearchGoogleCommand, ElementName=ActivityGrid}"
                                                    CommandParameter="{Binding Domain}"
                                                    IsEnabled="{Binding SelectedItem, ElementName=ActivityGrid, Converter={StaticResource ObjectPresentBool}}" />
                                        </StackPanel>
                                    </StackPanel>

                                    <Border Style="{StaticResource Hg.EmptyState}"
                                            Visibility="{Binding Converter={StaticResource EmptyStateVis}}">
                                        <StackPanel>
                                            <TextBlock Text="Select a domain"
                                                       Style="{StaticResource Hg.SectionTitle}"
                                                       HorizontalAlignment="Center"
                                                       Margin="0,0,0,4" />
                                            <TextBlock Text="The inspector keeps row details and frequent actions visible while the feed keeps updating."
                                                       Style="{StaticResource Hg.EmptyText}" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>
                        </Grid>

                        <TextBlock Grid.Row="2" Margin="2,6,0,0"
                                   Text="{Binding StatusText}" Style="{StaticResource Hg.DimText}" />
                    </Grid>
                </TabItem>

                <TabItem>
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="▤" Style="{StaticResource Hg.MainTabIcon}" />
                            <TextBlock Text="{svc:Loc Key=Tab_HostsFile, Default=Hosts File}" />
                        </StackPanel>
                    </TabItem.Header>
                    <TabControl Margin="0,4,0,0">
                        <TabItem Header="{svc:Loc Key=Tab_ManagedDomains, Default=Managed Domains}">
                            <Grid Margin="4" DataContext="{Binding Hosts}">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" Style="{StaticResource Hg.CommandBar}" Margin="0,0,0,8">
                                <DockPanel>
                                    <Button DockPanel.Dock="Right" Content="Refresh"
                                            Command="{Binding RefreshCommand}" Margin="8,0,0,0" />
                                    <Button DockPanel.Dock="Right" Content="AI Categorize"
                                            Command="{Binding AiCategorizeCommand}" Margin="8,0,0,0"
                                            ToolTip="Have DeepSeek categorize every hosts-file entry and organize the file under '# Category' sections (existing sections are reused)" />
                                    <Button DockPanel.Dock="Right" Content="Block"
                                            Style="{StaticResource Hg.AccentButton}"
                                            Command="{Binding BlockCommand}" Margin="8,0,0,0"
                                            ToolTip="Enter a domain, then add it to managed blocks" />
                                    <TextBox DockPanel.Dock="Right" Width="220" Margin="8,0,0,0"
                                             Text="{Binding NewDomain, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource Hg.HintBox}"
                                             Tag="Domain to block"
                                             AutomationProperties.Name="Domain to block"
                                             ToolTip="Domain to block" />
                                    <ComboBox DockPanel.Dock="Right" Width="120" Margin="8,0,0,0"
                                              ItemsSource="{x:Static vm:HostsViewModel.StatusFilters}"
                                              AutomationProperties.Name="Managed-domain status filter"
                                              SelectedItem="{Binding StatusFilter}" />
                                    <TextBox Text="{Binding Filter, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource Hg.HintBox}"
                                             Tag="Search managed domains — try field:value or !term"
                                             AutomationProperties.Name="Search managed domains"
                                             ToolTip="Filters as you type — supports field:value, !term, and field!=value" />
                                </DockPanel>
                                </Border>

                                <DataGrid Grid.Row="1" x:Name="DomainsGrid" ItemsSource="{Binding Domains}"
                                          AutomationProperties.Name="Managed domains"
                                          IsVisibleChanged="OnGridVisible">
                                    <DataGrid.RowStyle>
                                        <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                                            <Setter Property="ToolTip" Value="{Binding Reason}" />
                                        </Style>
                                    </DataGrid.RowStyle>
                                    <DataGrid.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="Block selected"
                                                      Command="{Binding PlacementTarget.DataContext.BlockSelectedCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding PlacementTarget.SelectedItems, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                            <MenuItem Header="Allow selected"
                                                      Command="{Binding PlacementTarget.DataContext.AllowSelectedCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding PlacementTarget.SelectedItems, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                            <MenuItem Header="Remove selected"
                                                      Command="{Binding PlacementTarget.DataContext.RemoveSelectedCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding PlacementTarget.SelectedItems, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                            <Separator />
                                            <MenuItem Header="Block root"
                                                      Command="{Binding PlacementTarget.DataContext.BlockRootCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding PlacementTarget.SelectedItem.Domain, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                            <Separator />
                                            <MenuItem Header="Research online">
                                                <MenuItem Header="Google"
                                                          Command="{Binding PlacementTarget.DataContext.ResearchGoogleCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                          CommandParameter="{Binding PlacementTarget.SelectedItem.Domain, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                                <MenuItem Header="VirusTotal"
                                                          Command="{Binding PlacementTarget.DataContext.ResearchVirusTotalCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                          CommandParameter="{Binding PlacementTarget.SelectedItem.Domain, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                                <MenuItem Header="who.is"
                                                          Command="{Binding PlacementTarget.DataContext.ResearchWhoisCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                          CommandParameter="{Binding PlacementTarget.SelectedItem.Domain, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                            </MenuItem>
                                        </ContextMenu>
                                    </DataGrid.ContextMenu>
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Domain" Binding="{Binding Domain}" Width="2*" />
                                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="110" />
                                        <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="140" />
                                        <DataGridTextColumn Header="Source" Binding="{Binding Source}" Width="110" />
                                        <DataGridTextColumn Header="Reason" Binding="{Binding Reason}" Width="2*" />
                                        <DataGridTextColumn Header="Hits" Binding="{Binding Hits}" Width="70" />
                                        <DataGridTemplateColumn Header="Actions" Width="170">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal">
                                                        <Button Content="Allow" Padding="8,2" Margin="0,0,6,0"
                                                                Command="{Binding DataContext.AllowCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                                CommandParameter="{Binding Domain}" />
                                                        <Button Content="Remove" Padding="8,2"
                                                                Style="{StaticResource Hg.DangerButton}"
                                                                Command="{Binding DataContext.UnblockCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                                CommandParameter="{Binding Domain}" />
                                                    </StackPanel>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>

                                <Border Grid.Row="1"
                                        Style="{StaticResource Hg.EmptyState}"
                                        Visibility="{Binding Domains.Count, Converter={StaticResource EmptyStateVis}}">
                                    <StackPanel>
                                        <TextBlock Text="No managed domains"
                                                   Style="{StaticResource Hg.SectionTitle}"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,0,0,4" />
                                        <TextBlock Text="Add a domain above or import a blocklist. If you are filtering, clear the filter and refresh."
                                                   Style="{StaticResource Hg.EmptyText}" />
                                    </StackPanel>
                                </Border>

                                <TextBlock Grid.Row="2" Margin="2,6,0,0"
                                           Text="{Binding StatusText}" Style="{StaticResource Hg.DimText}" />
                            </Grid>
                        </TabItem>

                        <TabItem Header="{svc:Loc Key=Tab_Blocklists, Default=Blocklists}">
                            <Grid Margin="4" DataContext="{Binding Blocklists}">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <DataGrid Grid.Row="0" ItemsSource="{Binding Sources}"
                                          AutomationProperties.Name="Blocklist sources">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="120" />
                                        <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
                                        <DataGridCheckBoxColumn Header="Subscribed" Binding="{Binding Subscribed}" Width="90" IsReadOnly="True" />
                                        <DataGridTextColumn Header="Domains" Binding="{Binding DomainCount}" Width="90" />
                                        <DataGridTextColumn Header="Last refresh" Binding="{Binding LastRefresh}" Width="160" />
                                        <DataGridTextColumn Header="Health" Binding="{Binding Flags}" Width="90">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{DynamicResource Hg.Peach}" />
                                                    <Setter Property="ToolTip" Value="Source-health flags: very large lists and mirror fallbacks" />
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTemplateColumn Header="Actions" Width="190">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal">
                                                        <Button Content="Import" Padding="8,2" Margin="0,0,6,0"
                                                                Style="{StaticResource Hg.AccentButton}"
                                                                Command="{Binding DataContext.ImportCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                                CommandParameter="{Binding}" />
                                                        <Button Content="Unsubscribe" Padding="8,2"
                                                                Visibility="{Binding Subscribed, Converter={StaticResource BoolToVis}}"
                                                                Command="{Binding DataContext.UnsubscribeCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                                CommandParameter="{Binding}" />
                                                    </StackPanel>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>

                                <Border Grid.Row="0"
                                        Style="{StaticResource Hg.EmptyState}"
                                        Visibility="{Binding Sources.Count, Converter={StaticResource EmptyStateVis}}">
                                    <StackPanel>
                                        <TextBlock Text="No blocklist sources"
                                                   Style="{StaticResource Hg.SectionTitle}"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,0,0,4" />
                                        <TextBlock Text="The service did not return the curated catalog. Reconnect to the service, then refresh subscriptions."
                                                   Style="{StaticResource Hg.EmptyText}" />
                                    </StackPanel>
                                </Border>

                                <Border Grid.Row="1" Style="{StaticResource Hg.Card}" Margin="0,8,0,0">
                                    <DockPanel>
                                        <Button DockPanel.Dock="Right" Content="Save + apply allowlists"
                                                Style="{StaticResource Hg.AccentButton}"
                                                Command="{Binding SaveAllowlistsCommand}" Margin="8,0,0,0"
                                                VerticalAlignment="Top" />
                                        <Button DockPanel.Dock="Right" Content="Refresh all subscriptions"
                                                Command="{Binding RefreshAllListsCommand}" Margin="8,0,0,0"
                                                VerticalAlignment="Top" />
                                        <StackPanel>
                                            <TextBlock Text="Allowlist URLs (one per line — whitelisted domains always win over blocklists)"
                                                       Style="{StaticResource Hg.SubText}" Margin="0,0,0,4" />
                                            <TextBox Text="{Binding AllowlistUrlsText, UpdateSourceTrigger=PropertyChanged}"
                                                     AutomationProperties.Name="Allowlist subscription URLs"
                                                     AcceptsReturn="True" MinHeight="52" MaxHeight="110"
                                                     VerticalScrollBarVisibility="Auto" FontFamily="Consolas" />
                                        </StackPanel>
                                    </DockPanel>
                                </Border>

                                <TextBlock Grid.Row="2" Margin="2,6,0,0"
                                           Text="{Binding StatusText}" Style="{StaticResource Hg.DimText}" />
                            </Grid>
                        </TabItem>

                        <TabItem Header="{svc:Loc Key=Tab_RawEditor, Default=Raw Editor}">
                            <Grid Margin="4" DataContext="{Binding RawHosts}">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" Style="{StaticResource Hg.CommandBar}" Margin="0,0,0,8">
                                <DockPanel LastChildFill="False">
                                    <Button DockPanel.Dock="Right" Content="Save"
                                            Style="{StaticResource Hg.AccentButton}"
                                            Command="{Binding SaveCommand}" IsEnabled="{Binding IsDirty}"
                                            ToolTip="Write the edited text back to the hosts file (enabled once the text changes)" />
                                    <Button DockPanel.Dock="Right" Content="Reload"
                                            Command="{Binding LoadCommand}" Margin="0,0,8,0"
                                            ToolTip="Discard edits and reload the hosts file from disk" />
                                    <Button DockPanel.Dock="Right" Content="AI Categorize"
                                            Command="{Binding AiCategorizeCommand}" Margin="0,0,8,0"
                                            ToolTip="Have DeepSeek categorize every hosts-file entry and organize the file under '# Category' sections (existing sections are reused)" />
                                    <TextBlock DockPanel.Dock="Right" Margin="0,0,12,0" VerticalAlignment="Center"
                                               Text="● Unsaved changes" Foreground="{DynamicResource Hg.Peach}"
                                               Visibility="{Binding IsDirty, Converter={StaticResource BoolToVis}}" />
                                </DockPanel>
                                </Border>

                                <TextBox Grid.Row="1"
                                         Text="{Binding Text, UpdateSourceTrigger=PropertyChanged}"
                                         AutomationProperties.Name="Raw hosts file editor"
                                         AcceptsReturn="True" AcceptsTab="True"
                                         FontFamily="Consolas"
                                         VerticalScrollBarVisibility="Auto"
                                         HorizontalScrollBarVisibility="Auto" />

                                <TextBlock Grid.Row="2" Margin="2,6,0,0"
                                           Text="{Binding StatusText}" Style="{StaticResource Hg.DimText}" />
                            </Grid>
                        </TabItem>
                    </TabControl>
                </TabItem>

                <TabItem>
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="◈" Style="{StaticResource Hg.MainTabIcon}" />
                            <TextBlock Text="{svc:Loc Key=Tab_FirewallActivity, Default=Firewall Activity}" />
                        </StackPanel>
                    </TabItem.Header>
                    <Grid Margin="4" DataContext="{Binding FwActivity}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" MinHeight="220" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Modes: lockdown = default-outbound Block; learning/observe persist to config -->
                        <Border Grid.Row="0" Style="{StaticResource Hg.CommandBar}" Margin="0,0,0,8">
                        <WrapPanel>
                            <CheckBox DockPanel.Dock="Left" Content="Lockdown" Margin="0,0,14,0" VerticalAlignment="Center"
                                      IsChecked="{Binding Lockdown}"
                                      ToolTip="Set the default outbound action to Block on all firewall profiles" />
                            <CheckBox DockPanel.Dock="Left" Content="Learning" Margin="0,0,14,0" VerticalAlignment="Center"
                                      IsChecked="{Binding LearningMode}"
                                      ToolTip="Surface trust prompts for processes making new connections" />
                            <CheckBox DockPanel.Dock="Left" Content="Observe" Margin="0,0,14,0" VerticalAlignment="Center"
                                      IsChecked="{Binding ObserveMode}"
                                      ToolTip="Record new processes silently instead of prompting" />
                            <CheckBox DockPanel.Dock="Left" Content="Inherit to children" Margin="0,0,14,0" VerticalAlignment="Center"
                                      IsChecked="{Binding DataContext.ChildInherit, RelativeSource={RelativeSource AncestorType=Window}}"
                                      AutomationProperties.Name="Child-process auto-allow"
                                      ToolTip="Child-process auto-allow: a direct child of an app that already has an allow rule inherits its allow for 1 hour instead of prompting (opt-in; deny-by-default when off)" />
                            <CheckBox DockPanel.Dock="Left" Content="Inbound prompts" Margin="0,0,14,0" VerticalAlignment="Center"
                                      IsChecked="{Binding DataContext.InboundConsent, RelativeSource={RelativeSource AncestorType=Window}}"
                                      AutomationProperties.Name="Inbound-connection consent"
                                      ToolTip="Inbound-connection consent: also prompt on unruled inbound connections and let you create inbound rules (opt-in; off by default because unsolicited inbound is noisy)" />
                            <TextBlock DockPanel.Dock="Right" Text="{Binding PostureText}"
                                       Style="{StaticResource Hg.DimText}" VerticalAlignment="Center" />
                            <Button DockPanel.Dock="Right" Content="AI identify" Margin="10,0,0,0" Padding="10,3"
                                    Command="{Binding IdentifyConnectionsCommand}"
                                    ToolTip="Have DeepSeek explain what each connection is likely for (fills the Info column; results are saved to the AI knowledge log)" />
                            <CheckBox DockPanel.Dock="Right" Content="Resolve IPs" Margin="10,0,0,0" VerticalAlignment="Center"
                                      IsChecked="{Binding ResolveIps}"
                                      AutomationProperties.Name="Resolve remote IPs with reverse DNS"
                                      ToolTip="Reverse-DNS remote IPs the live DNS cache didn't cover, filling the Site column" />
                            <CheckBox DockPanel.Dock="Right" Content="Group by app" Margin="10,0,10,0" VerticalAlignment="Center"
                                      IsChecked="{Binding GroupByApp}"
                                      AutomationProperties.Name="Group connections by app"
                                      ToolTip="Group the live connections under their owning process" />
                            <CheckBox DockPanel.Dock="Right" Content="Group by country" Margin="10,0,0,0" VerticalAlignment="Center"
                                      IsChecked="{Binding GroupByCountry}"
                                      AutomationProperties.Name="Group connections by country"
                                      ToolTip="Group the live connections by remote country (triage axis); combine with Group by app to nest" />
                            <TextBox Margin="0,0,0,0" VerticalAlignment="Center"
                                     Text="{Binding Filter, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource Hg.HintBox}"
                                     MinWidth="260"
                                     Tag="Search connections — try process:chrome, port:443, or !svchost"
                                     AutomationProperties.Name="Search live connections"
                                     ToolTip="Search: process:chrome  port:443  country!=US  !svchost" />
                        </WrapPanel>
                        </Border>

                        <Grid Grid.Row="1" MinHeight="180">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="248" />
                            </Grid.ColumnDefinitions>

                        <DataGrid Grid.Column="0" x:Name="ConnectionsGrid" ItemsSource="{Binding ConnectionsView}"
                                  AutomationProperties.Name="Live firewall connections"
                                  IsVisibleChanged="OnGridVisible">
                            <DataGrid.GroupStyle>
                                <GroupStyle>
                                    <GroupStyle.ContainerStyle>
                                        <Style TargetType="{x:Type GroupItem}">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="{x:Type GroupItem}">
                                                        <Expander IsExpanded="True" Margin="0,2,0,0">
                                                            <Expander.Header>
                                                                <StackPanel Orientation="Horizontal">
                                                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                                                    <TextBlock Text="{Binding ItemCount, StringFormat=' ({0})'}"
                                                                               Style="{StaticResource Hg.DimText}" />
                                                                </StackPanel>
                                                            </Expander.Header>
                                                            <ItemsPresenter />
                                                        </Expander>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </GroupStyle.ContainerStyle>
                                </GroupStyle>
                            </DataGrid.GroupStyle>
                            <DataGrid.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Block this site (domain)"
                                              Command="{Binding PlacementTarget.DataContext.BlockSiteCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              ToolTip="Block the resolved domain via the hosts file (durable — survives IP rotation); falls back to the IP when unresolved" />
                                    <MenuItem Header="Allow this site (domain)"
                                              Command="{Binding PlacementTarget.DataContext.AllowSiteCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              ToolTip="Whitelist the resolved domain via the hosts file" />
                                    <MenuItem Header="Block remote IP"
                                              Command="{Binding PlacementTarget.DataContext.QuickBlockIpCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding PlacementTarget.SelectedItem.RemoteAddr, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                    <MenuItem Header="Block program"
                                              Command="{Binding PlacementTarget.DataContext.QuickBlockProcessCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                    <MenuItem Header="Block app scope">
                                        <MenuItem Header="Internet (public IPs)"
                                                  Command="{Binding PlacementTarget.DataContext.BlockScopeCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding PlacementTarget.SelectedItem.Pid, StringFormat='internet|{0}', RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                        <MenuItem Header="LAN (private ranges)"
                                                  Command="{Binding PlacementTarget.DataContext.BlockScopeCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding PlacementTarget.SelectedItem.Pid, StringFormat='lan|{0}', RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                        <MenuItem Header="Localhost (loopback)"
                                                  Command="{Binding PlacementTarget.DataContext.BlockScopeCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding PlacementTarget.SelectedItem.Pid, StringFormat='localhost|{0}', RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                        <MenuItem Header="Inbound"
                                                  Command="{Binding PlacementTarget.DataContext.BlockScopeCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding PlacementTarget.SelectedItem.Pid, StringFormat='inbound|{0}', RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                    </MenuItem>
                                    <Separator />
                                    <MenuItem Header="Explain / look up connection"
                                              ToolTip="Look up the connection's resolved domain (or IP) on threat-intel sites">
                                        <MenuItem Header="VirusTotal (site)"
                                                  Command="{Binding PlacementTarget.DataContext.ResearchVirusTotalCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding PlacementTarget.SelectedItem.ResearchTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                        <MenuItem Header="who.is (site)"
                                                  Command="{Binding PlacementTarget.DataContext.ResearchWhoisCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding PlacementTarget.SelectedItem.ResearchTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                        <MenuItem Header="Google"
                                                  Command="{Binding PlacementTarget.DataContext.ResearchGoogleCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding PlacementTarget.SelectedItem.ResearchTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                        <MenuItem Header="AbuseIPDB (IP)"
                                                  Command="{Binding PlacementTarget.DataContext.ResearchAbuseIpdbCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding PlacementTarget.SelectedItem.RemoteAddr, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                    </MenuItem>
                                </ContextMenu>
                            </DataGrid.ContextMenu>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Process" Binding="{Binding Process}" Width="90" />
                                <DataGridTextColumn Header="Service" Binding="{Binding Service}" Width="72" />
                                <DataGridTextColumn Header="PID" Binding="{Binding Pid}" Width="42" />
                                <DataGridTextColumn Header="Proto" Binding="{Binding Protocol}" Width="44" />
                                <DataGridTextColumn Header="Remote" Binding="{Binding RemoteAddr}" Width="100" />
                                <DataGridTextColumn Header="Site" Binding="{Binding Host}" Width="*" MinWidth="90">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="ToolTip" Value="Domain this IP was resolved as (live DNS)" />
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Info" Binding="{Binding Info}" Width="*" MinWidth="90">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource Hg.Teal}" />
                                            <Setter Property="ToolTip" Value="{Binding Info}" />
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Port" Binding="{Binding RemotePort}" Width="42" />
                                <DataGridTextColumn Header="State" Binding="{Binding State}" Width="66" />
                                <DataGridTextColumn Header="Country" Binding="{Binding Country}" Width="48" />
                                <DataGridTextColumn Header="FW" Binding="{Binding FwStatus}" Width="50" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <Border Grid.Column="0"
                                Style="{StaticResource Hg.EmptyState}"
                                Visibility="{Binding Rows.Count, Converter={StaticResource EmptyStateVis}}">
                            <StackPanel>
                                <TextBlock Text="No live connections"
                                           Style="{StaticResource Hg.SectionTitle}"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,4" />
                                <TextBlock Text="Connections appear here when the monitor is running and applications open network sessions. The status bar shows whether the service is connected."
                                           Style="{StaticResource Hg.EmptyText}" />
                            </StackPanel>
                        </Border>

                            <Border Grid.Column="1"
                                    Style="{StaticResource Hg.Inspector}"
                                    Margin="10,0,0,0"
                                    DataContext="{Binding SelectedItem, ElementName=ConnectionsGrid}">
                                <Grid>
                                    <StackPanel>
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding}" Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>
                                        <TextBlock Text="Selected connection" Style="{StaticResource Hg.Kicker}" />
                                        <TextBlock Text="{Binding Process, TargetNullValue='Select a connection'}"
                                                   FontSize="16"
                                                   FontWeight="SemiBold"
                                                   TextWrapping="Wrap"
                                                   Margin="0,4,0,0" />
                                        <TextBlock Text="{Binding ResearchTarget, StringFormat='Target: {0}', TargetNullValue='Choose a live row to inspect'}"
                                                   Style="{StaticResource Hg.DimText}"
                                                   Margin="0,3,0,0"
                                                   TextWrapping="Wrap" />

                                        <Grid Margin="0,12,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Style="{StaticResource Hg.Badge}" Margin="0,0,6,0">
                                                <TextBlock Text="{Binding State, TargetNullValue='No state'}"
                                                           Style="{StaticResource Hg.DimText}" />
                                            </Border>
                                            <Border Grid.Column="1" Style="{StaticResource Hg.Badge}" Margin="6,0,0,0">
                                                <TextBlock Text="{Binding FwStatus, TargetNullValue='No FW flag'}"
                                                           Style="{StaticResource Hg.DimText}" />
                                            </Border>
                                        </Grid>

                                        <TextBlock Text="Remote" Style="{StaticResource Hg.InspectorLabel}" />
                                        <TextBlock Style="{StaticResource Hg.InspectorValue}">
                                            <Run Text="{Binding Protocol, TargetNullValue='-'}" />
                                            <Run Text=" " />
                                            <Run Text="{Binding RemoteAddr, TargetNullValue='-'}" />
                                            <Run Text=":" />
                                            <Run Text="{Binding RemotePort}" />
                                        </TextBlock>

                                        <TextBlock Text="Resolved site" Style="{StaticResource Hg.InspectorLabel}" />
                                        <TextBlock Text="{Binding Host, TargetNullValue='No DNS match yet'}"
                                                   Style="{StaticResource Hg.InspectorValue}" />

                                        <TextBlock Text="Service / location" Style="{StaticResource Hg.InspectorLabel}" />
                                        <TextBlock Text="{Binding Service, TargetNullValue='No service attribution'}"
                                                   Style="{StaticResource Hg.InspectorValue}" />
                                        <TextBlock Text="{Binding Country, StringFormat='Country: {0}', TargetNullValue='Country: unknown'}"
                                                   Style="{StaticResource Hg.DimText}"
                                                   Margin="0,4,0,0" />

                                        <TextBlock Text="Info" Style="{StaticResource Hg.InspectorLabel}" />
                                        <TextBlock Text="{Binding Info, TargetNullValue='Run AI identify or use the lookup menu for context'}"
                                                   Style="{StaticResource Hg.InspectorValue}"
                                                   Foreground="{DynamicResource Hg.Teal}"
                                                   MaxHeight="72" />

                                        <UniformGrid Columns="2" Margin="0,12,0,0">
                                            <Border Style="{StaticResource Hg.MetricTile}">
                                                <StackPanel>
                                                    <TextBlock Text="PID" Style="{StaticResource Hg.Kicker}" />
                                                    <TextBlock Text="{Binding Pid}" Style="{StaticResource Hg.MetricValue}" />
                                                </StackPanel>
                                            </Border>
                                            <Border Style="{StaticResource Hg.MetricTile}" Margin="0,0,0,8">
                                                <StackPanel>
                                                    <TextBlock Text="LOCAL" Style="{StaticResource Hg.Kicker}" />
                                                    <TextBlock Text="{Binding LocalPort}"
                                                               Style="{StaticResource Hg.InspectorValue}" />
                                                </StackPanel>
                                            </Border>
                                        </UniformGrid>

                                        <TextBlock Text="Actions" Style="{StaticResource Hg.InspectorLabel}" />
                                        <WrapPanel>
                                            <Button Content="Block site"
                                                    Style="{StaticResource Hg.ActionChip}"
                                                    Margin="0,0,6,6"
                                                    Command="{Binding DataContext.BlockSiteCommand, ElementName=ConnectionsGrid}"
                                                    CommandParameter="{Binding}"
                                                    IsEnabled="{Binding SelectedItem, ElementName=ConnectionsGrid, Converter={StaticResource ObjectPresentBool}}" />
                                            <Button Content="Allow site"
                                                    Style="{StaticResource Hg.ActionChip}"
                                                    Margin="0,0,6,6"
                                                    Command="{Binding DataContext.AllowSiteCommand, ElementName=ConnectionsGrid}"
                                                    CommandParameter="{Binding}"
                                                    IsEnabled="{Binding SelectedItem, ElementName=ConnectionsGrid, Converter={StaticResource ObjectPresentBool}}" />
                                            <Button Content="Block IP"
                                                    Style="{StaticResource Hg.ActionChip}"
                                                    Margin="0,0,6,6"
                                                    Command="{Binding DataContext.QuickBlockIpCommand, ElementName=ConnectionsGrid}"
                                                    CommandParameter="{Binding RemoteAddr}"
                                                    IsEnabled="{Binding SelectedItem, ElementName=ConnectionsGrid, Converter={StaticResource ObjectPresentBool}}" />
                                            <Button Content="Block app"
                                                    Style="{StaticResource Hg.ActionChip}"
                                                    Margin="0,0,6,6"
                                                    Command="{Binding DataContext.QuickBlockProcessCommand, ElementName=ConnectionsGrid}"
                                                    CommandParameter="{Binding}"
                                                    IsEnabled="{Binding SelectedItem, ElementName=ConnectionsGrid, Converter={StaticResource ObjectPresentBool}}" />
                                        </WrapPanel>
                                    </StackPanel>

                                    <Border Style="{StaticResource Hg.EmptyState}"
                                            Visibility="{Binding Converter={StaticResource EmptyStateVis}}">
                                        <StackPanel>
                                            <TextBlock Text="Select a connection"
                                                       Style="{StaticResource Hg.SectionTitle}"
                                                       HorizontalAlignment="Center"
                                                       Margin="0,0,0,4" />
                                            <TextBlock Text="The inspector keeps endpoint identity, service attribution, and block actions visible during live triage."
                                                       Style="{StaticResource Hg.EmptyText}" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>
                        </Grid>

                        <!-- Per-app activity timeline (new connections per minute) -->
                        <Border Grid.Row="2" Style="{StaticResource Hg.Card}" Margin="0,8,0,0">
                            <StackPanel>
                                <DockPanel LastChildFill="False">
                                    <TextBlock DockPanel.Dock="Left" Text="Per-app activity" FontWeight="SemiBold" />
                                    <TextBlock DockPanel.Dock="Right" Text="{Binding TimelineStatus}"
                                               Style="{StaticResource Hg.DimText}" />
                                </DockPanel>
                                <Grid Height="86" Margin="0,6,0,0" ClipToBounds="True">
                                    <ItemsControl ItemsSource="{Binding Timeline}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <Grid />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Viewbox Stretch="Fill">
                                                    <Canvas Width="600" Height="100">
                                                        <Polyline Points="{Binding PointsText, Converter={StaticResource PointsConverter}}"
                                                                  Stroke="{Binding ColorIndex, Converter={StaticResource SeriesBrush}}"
                                                                  StrokeThickness="1.6" StrokeLineJoin="Round" />
                                                    </Canvas>
                                                </Viewbox>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>
                                <ItemsControl ItemsSource="{Binding Timeline}" Margin="0,4,0,0">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,14,0">
                                                <Rectangle Width="10" Height="3" VerticalAlignment="Center" Margin="0,0,5,0"
                                                           Fill="{Binding ColorIndex, Converter={StaticResource SeriesBrush}}" />
                                                <TextBlock Text="{Binding Name}" Style="{StaticResource Hg.DimText}" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- Recent consent decisions with re-decide (WFCP-021) + learning review (NET-074) -->
                        <Border Grid.Row="3" Style="{StaticResource Hg.Card}" Margin="0,8,0,0" MaxHeight="300">
                            <StackPanel>
                                <DockPanel LastChildFill="False">
                                    <TextBlock DockPanel.Dock="Left" Text="Learning review" FontWeight="SemiBold" />
                                    <Button DockPanel.Dock="Right" Content="Discard all" Padding="10,2" Margin="6,0,0,0"
                                            Command="{Binding DiscardAllLearnedCommand}"
                                            ToolTip="Remove every auto-allow — apps prompt again next time" />
                                    <Button DockPanel.Dock="Right" Content="Keep all" Padding="10,2" Margin="6,0,0,0"
                                            Command="{Binding PromoteAllLearnedCommand}"
                                            ToolTip="Promote every auto-allow to a permanent allow rule" />
                                    <Button DockPanel.Dock="Right" Content="Refresh" Padding="10,2"
                                            Command="{Binding LoadLearnedCommand}" />
                                </DockPanel>
                                <DataGrid ItemsSource="{Binding Learned}" MaxHeight="130" Margin="0,6,0,0"
                                          AutomationProperties.Name="Learning-mode auto-allow decisions">
                                    <DataGrid.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="Keep (permanent allow)"
                                                      Command="{Binding PlacementTarget.DataContext.PromoteLearnedCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                            <MenuItem Header="Reverse (permanent block)"
                                                      Command="{Binding PlacementTarget.DataContext.BlockLearnedCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                            <MenuItem Header="Discard (prompt again)"
                                                      Command="{Binding PlacementTarget.DataContext.DiscardLearnedCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                        </ContextMenu>
                                    </DataGrid.ContextMenu>
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Application" Binding="{Binding Application}" Width="2*" />
                                        <DataGridTextColumn Header="Service" Binding="{Binding ServiceName}" Width="120" />
                                        <DataGridTextColumn Header="Dir" Binding="{Binding Direction}" Width="46" />
                                        <DataGridTextColumn Header="Rule" Binding="{Binding RuleName}" Width="*" />
                                    </DataGrid.Columns>
                                </DataGrid>
                                <TextBlock Text="{Binding LearnedStatus}" Style="{StaticResource Hg.DimText}" Margin="0,4,0,6" />

                                <DockPanel LastChildFill="False">
                                    <TextBlock DockPanel.Dock="Left" Text="Recent connection decisions" FontWeight="SemiBold" />
                                    <Button DockPanel.Dock="Right" Content="Refresh"
                                            Command="{Binding LoadConsentHistoryCommand}" Padding="10,2" />
                                    <CheckBox DockPanel.Dock="Right" Content="Sound on block" VerticalAlignment="Center" Margin="0,0,12,0"
                                              IsChecked="{Binding SoundOnBlock}"
                                              AutomationProperties.Name="Play a sound when a connection is blocked"
                                              ToolTip="Play a system sound when a new connection is blocked or prompts" />
                                </DockPanel>
                                <ItemsControl ItemsSource="{Binding TopTriggered}" Margin="0,4,0,0">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate><WrapPanel Orientation="Horizontal" /></ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource Hg.Badge}" Margin="0,0,6,0">
                                                <TextBlock Text="{Binding}" Style="{StaticResource Hg.DimText}" />
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <DataGrid ItemsSource="{Binding ConsentHistory}" MaxHeight="150" Margin="0,6,0,0"
                                          AutomationProperties.Name="Recent connection decisions">
                                    <DataGrid.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="Allow permanently"
                                                      Command="{Binding PlacementTarget.DataContext.ReAllowCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                            <MenuItem Header="Block permanently"
                                                      Command="{Binding PlacementTarget.DataContext.ReBlockCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                        </ContextMenu>
                                    </DataGrid.ContextMenu>
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="When" Binding="{Binding DecidedAtText}" Width="110" />
                                        <DataGridTextColumn Header="Application" Binding="{Binding Application}" Width="2*" />
                                        <DataGridTextColumn Header="Dir" Binding="{Binding Direction}" Width="46" />
                                        <DataGridTextColumn Header="Remote" Binding="{Binding RemoteAddress}" Width="*" />
                                        <DataGridTextColumn Header="Proto" Binding="{Binding Protocol}" Width="56" />
                                        <DataGridTextColumn Header="Verdict" Binding="{Binding Verdict}" Width="76" />
                                        <DataGridTextColumn Header="Scope" Binding="{Binding Scope}" Width="86" />
                                    </DataGrid.Columns>
                                </DataGrid>
                                <TextBlock Text="No decisions yet — switch to Notify mode to get consent prompts for new connections."
                                           Style="{StaticResource Hg.DimText}" Margin="0,4,0,0"
                                           Visibility="{Binding ConsentHistory.Count, Converter={StaticResource EmptyStateVis}}" />
                            </StackPanel>
                        </Border>

                        <!-- Persistent connection history + per-app bandwidth (NET-070) -->
                        <Expander Grid.Row="4" Margin="0,8,0,0" Header="History &amp; bandwidth"
                                  AutomationProperties.Name="Connection history and bandwidth">
                            <Border Style="{StaticResource Hg.Card}">
                                <StackPanel>
                                    <DockPanel LastChildFill="True">
                                        <Button DockPanel.Dock="Right" Content="Load" Padding="10,2" Margin="6,0,0,0"
                                                Command="{Binding LoadHistoryCommand}" />
                                        <Button DockPanel.Dock="Right" Content="Export CSV" Padding="10,2" Margin="6,0,0,0"
                                                Command="{Binding ExportHistoryCsvCommand}"
                                                ToolTip="Save the loaded connection history to a CSV file (opens in Excel)" />
                                        <Button DockPanel.Dock="Right" Content="Set retention" Padding="10,2" Margin="6,0,0,0"
                                                Command="{Binding SaveRetentionCommand}" />
                                        <TextBox DockPanel.Dock="Right" Width="46" Margin="6,0,0,0" VerticalAlignment="Center"
                                                 Text="{Binding RetentionDays, UpdateSourceTrigger=PropertyChanged}"
                                                 AutomationProperties.Name="History retention days"
                                                 ToolTip="History retention in days (1-365)" />
                                        <TextBox Text="{Binding HistorySearch, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource Hg.HintBox}"
                                                 Tag="Search history by process, remote address, or country"
                                                 AutomationProperties.Name="Search connection history"
                                                 ToolTip="Substring match on process, remote address, or country" />
                                    </DockPanel>
                                    <DataGrid ItemsSource="{Binding HistoryRows}" MaxHeight="180" Margin="0,6,0,0"
                                              AutomationProperties.Name="Connection history">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="When" Binding="{Binding TsText}" Width="120" />
                                            <DataGridTextColumn Header="Process" Binding="{Binding Process}" Width="150" />
                                            <DataGridTextColumn Header="PID" Binding="{Binding Pid}" Width="56" />
                                            <DataGridTextColumn Header="Proto" Binding="{Binding Protocol}" Width="56" />
                                            <DataGridTextColumn Header="Remote address" Binding="{Binding RemoteAddr}" Width="*" />
                                            <DataGridTextColumn Header="Port" Binding="{Binding RemotePort}" Width="56" />
                                            <DataGridTextColumn Header="Country" Binding="{Binding Country}" Width="70" />
                                            <DataGridTextColumn Header="FW" Binding="{Binding FwStatus}" Width="80" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                    <TextBlock Text="{Binding HistoryStatus}" Style="{StaticResource Hg.DimText}" Margin="0,4,0,0" />

                                    <DockPanel LastChildFill="False" Margin="0,10,0,0">
                                        <TextBlock DockPanel.Dock="Left" Text="Per-app bandwidth" FontWeight="SemiBold" />
                                        <TextBlock DockPanel.Dock="Right" Text="{Binding BandwidthStatus}"
                                                   Style="{StaticResource Hg.DimText}" />
                                    </DockPanel>
                                    <Grid Height="86" Margin="0,6,0,0" ClipToBounds="True">
                                        <ItemsControl ItemsSource="{Binding Bandwidth}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <Grid />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Viewbox Stretch="Fill">
                                                        <Canvas Width="600" Height="100">
                                                            <Polyline Points="{Binding PointsText, Converter={StaticResource PointsConverter}}"
                                                                      Stroke="{Binding ColorIndex, Converter={StaticResource SeriesBrush}}"
                                                                      StrokeThickness="1.6" StrokeLineJoin="Round" />
                                                        </Canvas>
                                                    </Viewbox>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Grid>
                                    <ItemsControl ItemsSource="{Binding Bandwidth}" Margin="0,4,0,0">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel Orientation="Horizontal" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,14,0">
                                                    <Rectangle Width="10" Height="3" VerticalAlignment="Center" Margin="0,0,5,0"
                                                               Fill="{Binding ColorIndex, Converter={StaticResource SeriesBrush}}" />
                                                    <TextBlock Text="{Binding Name}" Style="{StaticResource Hg.DimText}" />
                                                    <TextBlock Text="{Binding LegendText}" Style="{StaticResource Hg.DimText}" Margin="5,0,0,0" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </Expander>

                        <TextBlock Grid.Row="5" Margin="2,6,0,0"
                                   Text="{Binding StatusText}" Style="{StaticResource Hg.DimText}" />
                    </Grid>
                </TabItem>

                <TabItem>
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="☷" Style="{StaticResource Hg.MainTabIcon}" />
                            <TextBlock Text="{svc:Loc Key=Tab_FirewallRules, Default=Firewall Rules}" />
                        </StackPanel>
                    </TabItem.Header>
                    <Grid Margin="4" DataContext="{Binding FwRules}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Style="{StaticResource Hg.CommandBar}" Margin="0,0,0,8">
                        <DockPanel>
                            <Button DockPanel.Dock="Right" Content="Refresh"
                                    Command="{Binding RefreshCommand}" Margin="8,0,0,0" />
                            <Button DockPanel.Dock="Right" Content="Import existing rules"
                                    Command="{Binding AdoptRulesCommand}" Margin="8,0,0,0"
                                    ToolTip="Read the machine's current Windows Firewall rules into HostsGuard's view (read-only; adopted rules are marked ★)" />
                            <CheckBox DockPanel.Dock="Right" Content="HostsGuard rules only" Margin="8,0,0,0"
                                      VerticalAlignment="Center" IsChecked="{Binding HostsGuardOnly}" />
                            <TextBox Text="{Binding Filter, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource Hg.HintBox}"
                                     Tag="Search rules by name, remote address, service, or program"
                                     AutomationProperties.Name="Search firewall rules"
                                     ToolTip="Filters as you type — matches rule name, remote address, service, or program" />
                        </DockPanel>
                        </Border>

                        <DataGrid Grid.Row="1" ItemsSource="{Binding Rules}"
                                  AutomationProperties.Name="Firewall rules"
                                  IsVisibleChanged="OnGridVisible">
                            <DataGrid.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Enable / disable"
                                              Command="{Binding PlacementTarget.DataContext.ToggleRuleCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                    <MenuItem Header="Delete"
                                              Command="{Binding PlacementTarget.DataContext.DeleteRuleCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding PlacementTarget.SelectedItem.Name, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                    <MenuItem Header="Delete selected"
                                              Command="{Binding PlacementTarget.DataContext.DeleteSelectedCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding PlacementTarget.SelectedItems, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                    <Separator />
                                    <MenuItem Header="Assign to group…"
                                              Command="{Binding PlacementTarget.DataContext.AssignToGroupCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding PlacementTarget.SelectedItems, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              ToolTip="Assign the selected HG_ rules to a named group you can enable/disable as a unit (blank name removes them)" />
                                    <MenuItem Header="Suggest / rebind program…"
                                              Command="{Binding PlacementTarget.DataContext.RebindRuleCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                </ContextMenu>
                            </DataGrid.ContextMenu>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="2*" />
                                <DataGridTextColumn Header="Dir" Binding="{Binding Direction}" Width="50" />
                                <DataGridTextColumn Header="Action" Binding="{Binding Action}" Width="70" />
                                <DataGridTextColumn Header="Origin" Binding="{Binding Origin}" Width="90" IsReadOnly="True" />
                                <DataGridCheckBoxColumn Header="On" Binding="{Binding Enabled}" Width="46" IsReadOnly="True" />
                                <DataGridTextColumn Header="Remote" Binding="{Binding RemoteAddr}" Width="*" />
                                <DataGridTextColumn Header="Proto" Binding="{Binding Protocol}" Width="60" />
                                <DataGridTextColumn Header="Program" Binding="{Binding Program}" Width="*" />
                                <DataGridTextColumn Header="Service" Binding="{Binding ServiceName}" Width="110" />
                                <DataGridTextColumn Header="Flags" Binding="{Binding Flags}" Width="110">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource Hg.Peach}" />
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <Border Grid.Row="1"
                                Style="{StaticResource Hg.EmptyState}"
                                Visibility="{Binding Rules.Count, Converter={StaticResource EmptyStateVis}}">
                            <StackPanel>
                                <TextBlock Text="No firewall rules match"
                                           Style="{StaticResource Hg.SectionTitle}"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,4" />
                                <TextBlock Text="Clear the filter, turn off HostsGuard-only, or refresh to load current Windows Firewall rules."
                                           Style="{StaticResource Hg.EmptyText}" />
                            </StackPanel>
                        </Border>

                        <!-- Rule groups (NET-103): enable/disable a named set atomically -->
                        <ItemsControl Grid.Row="2" ItemsSource="{Binding RuleGroups}" Margin="0,8,0,0">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource Hg.Card}" Padding="8,4" Margin="0,0,8,0">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Label}" VerticalAlignment="Center" Margin="0,0,8,0" />
                                            <Button Content="On" Padding="8,1" Margin="0,0,4,0"
                                                    Command="{Binding DataContext.EnableGroupCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}" />
                                            <Button Content="Off" Padding="8,1"
                                                    Command="{Binding DataContext.DisableGroupCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Inline custom-rule form -->
                        <Border Grid.Row="3" Style="{StaticResource Hg.Card}" Margin="0,8,0,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <DockPanel Grid.Row="0" LastChildFill="True">
                                    <Button DockPanel.Dock="Right" Content="Create rule"
                                            Style="{StaticResource Hg.AccentButton}"
                                            Command="{Binding CreateRuleCommand}" Margin="12,0,0,0"
                                            ToolTip="Enter a rule name before creating a firewall rule" />
                                    <StackPanel>
                                        <TextBlock Text="Create HostsGuard rule" Style="{StaticResource Hg.SectionTitle}" />
                                        <TextBlock Text="Rules created here use the HG_ prefix, are owned by HostsGuard, and can be protected by Secure Rules."
                                                   Style="{StaticResource Hg.HelperText}" Margin="0,3,0,0" />
                                    </StackPanel>
                                </DockPanel>

                                <Grid Grid.Row="1" Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="180" />
                                        <ColumnDefinition Width="76" />
                                        <ColumnDefinition Width="92" />
                                        <ColumnDefinition Width="82" />
                                        <ColumnDefinition Width="180" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Name" Style="{StaticResource Hg.FieldLabel}" />
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="Dir" Style="{StaticResource Hg.FieldLabel}" Margin="0,0,8,4" />
                                    <TextBlock Grid.Row="0" Grid.Column="2" Text="Action" Style="{StaticResource Hg.FieldLabel}" Margin="0,0,8,4" />
                                    <TextBlock Grid.Row="0" Grid.Column="3" Text="Protocol" Style="{StaticResource Hg.FieldLabel}" Margin="0,0,8,4" />
                                    <TextBlock Grid.Row="0" Grid.Column="4" Text="Remote" Style="{StaticResource Hg.FieldLabel}" Margin="0,0,8,4" />
                                    <TextBlock Grid.Row="0" Grid.Column="5" Text="Program path" Style="{StaticResource Hg.FieldLabel}" />

                                    <TextBox Grid.Row="1" Grid.Column="0" Margin="0,0,8,0"
                                             Text="{Binding NewRuleName, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource Hg.HintBox}"
                                             Tag="Required"
                                             AutomationProperties.Name="New firewall rule name"
                                             ToolTip="Rule name (HG_ prefix added automatically)" />
                                    <ComboBox Grid.Row="1" Grid.Column="1" Margin="0,0,8,0"
                                              ItemsSource="{x:Static vm:FwRulesViewModel.Directions}"
                                              AutomationProperties.Name="New firewall rule direction"
                                              SelectedItem="{Binding NewRuleDirection}" />
                                    <ComboBox Grid.Row="1" Grid.Column="2" Margin="0,0,8,0"
                                              ItemsSource="{x:Static vm:FwRulesViewModel.Actions}"
                                              AutomationProperties.Name="New firewall rule action"
                                              SelectedItem="{Binding NewRuleAction}" />
                                    <ComboBox Grid.Row="1" Grid.Column="3" Margin="0,0,8,0"
                                              ItemsSource="{x:Static vm:FwRulesViewModel.Protocols}"
                                              AutomationProperties.Name="New firewall rule protocol"
                                              SelectedItem="{Binding NewRuleProtocol}" />
                                    <TextBox Grid.Row="1" Grid.Column="4" Margin="0,0,8,0"
                                             Text="{Binding NewRuleRemoteAddr, UpdateSourceTrigger=PropertyChanged}"
                                             AutomationProperties.Name="New firewall rule remote address"
                                             ToolTip="Remote address: IP, CIDR, or range (empty = Any)" />
                                    <TextBox Grid.Row="1" Grid.Column="5"
                                             Text="{Binding NewRuleProgram, UpdateSourceTrigger=PropertyChanged}"
                                             AutomationProperties.Name="New firewall rule program path"
                                             ToolTip="Program path (optional)" />
                                </Grid>
                            </Grid>
                        </Border>

                        <TextBlock Grid.Row="4" Margin="2,6,0,0"
                                   Text="{Binding StatusText}" Style="{StaticResource Hg.DimText}" />
                    </Grid>
                </TabItem>

                <TabItem>
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚙" Style="{StaticResource Hg.MainTabIcon}" />
                            <TextBlock Text="{svc:Loc Key=Tab_Tools, Default=Tools}" />
                        </StackPanel>
                    </TabItem.Header>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="8" DataContext="{Binding Tools}">

                            <!-- Settings lock (NET-079) -->
                            <Border Style="{StaticResource Hg.Card}" Margin="0,0,0,10">
                                <StackPanel>
                                    <DockPanel LastChildFill="False">
                                        <TextBlock DockPanel.Dock="Left" Text="Settings lock" FontWeight="SemiBold" />
                                        <TextBlock DockPanel.Dock="Right" Text="{Binding LockStatus}" Style="{StaticResource Hg.DimText}" />
                                    </DockPanel>
                                    <TextBlock Text="When locked, changing filtering mode, firewall posture, or HG_ rules requires the password."
                                               Style="{StaticResource Hg.DimText}" TextWrapping="Wrap" Margin="0,4,0,8" />
                                    <TextBlock Text="Lock password" Style="{StaticResource Hg.FieldLabel}" />
                                    <DockPanel LastChildFill="True">
                                        <Button DockPanel.Dock="Right" Content="Refresh" Command="{Binding LoadLockStateCommand}" Margin="6,0,0,0" Padding="10,2" />
                                        <Button DockPanel.Dock="Right" Content="Protect hosts file" Command="{Binding ProtectHostsCommand}" Margin="6,0,0,0" Padding="10,2"
                                                ToolTip="Enforce a SYSTEM+Admins-only DACL on the hosts file" />
                                        <PasswordBox x:Name="LockPasswordBox" VerticalAlignment="Center"
                                                     AutomationProperties.Name="Settings lock password" />
                                    </DockPanel>
                                    <DockPanel LastChildFill="False" Margin="0,8,0,0">
                                        <Button DockPanel.Dock="Left" Content="Arm lock" Command="{Binding EnableLockCommand}" Margin="0,0,6,0" Padding="10,2"
                                                CommandParameter="{Binding ElementName=LockPasswordBox}" Click="OnLockPasswordSync"
                                                ToolTip="Set the password that protects filtering, posture, and HG_ rule changes" />
                                        <Button DockPanel.Dock="Left" Content="Disarm" Command="{Binding DisableLockCommand}" Margin="0,0,6,0" Padding="10,2"
                                                Click="OnLockPasswordSync"
                                                ToolTip="Remove the settings lock after entering the password" />
                                        <Button DockPanel.Dock="Left" Content="Unlock" Command="{Binding UnlockCommand}" Margin="0,0,6,0" Padding="10,2"
                                                Click="OnLockPasswordSync"
                                                ToolTip="Temporarily unlock protected actions for the configured number of minutes" />
                                        <TextBox DockPanel.Dock="Left" Width="46" VerticalAlignment="Center"
                                                 Text="{Binding UnlockMinutes, UpdateSourceTrigger=PropertyChanged}"
                                                 AutomationProperties.Name="Unlock minutes" ToolTip="Timed-unlock window in minutes" />
                                        <TextBlock DockPanel.Dock="Left" Text="min" Style="{StaticResource Hg.DimText}"
                                                   VerticalAlignment="Center" Margin="5,0,0,0" />
                                    </DockPanel>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource Hg.Card}" Margin="0,0,0,10">
                                <StackPanel>
                                    <TextBlock Text="DNS" FontWeight="SemiBold" Margin="0,0,0,8" />
                                    <TextBlock Text="Flush resolver state, switch Windows DNS presets, and verify whether a domain is reachable or blocked."
                                               Style="{StaticResource Hg.HelperText}" Margin="0,0,0,10" />
                                    <DockPanel LastChildFill="False">
                                        <Button DockPanel.Dock="Left" Content="Flush DNS cache"
                                                Command="{Binding FlushDnsCommand}" Margin="0,0,10,0" />
                                        <ComboBox DockPanel.Dock="Left" Width="180" Margin="0,0,10,0"
                                                  ItemsSource="{x:Static vm:ToolsViewModel.ResolverNames}"
                                                  AutomationProperties.Name="DNS resolver preset"
                                                  SelectedItem="{Binding SelectedResolver}" />
                                        <Button DockPanel.Dock="Left" Content="Apply resolver"
                                                Command="{Binding ApplyResolverCommand}" />
                                    </DockPanel>
                                    <DockPanel Margin="0,10,0,0">
                                        <Button DockPanel.Dock="Right" Content="Inspect"
                                                Command="{Binding InspectCommand}" Margin="8,0,0,0"
                                                ToolTip="Enter a domain to resolve and check" />
                                        <TextBox Text="{Binding InspectDomain, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource Hg.HintBox}"
                                                 Tag="Domain to resolve and check — e.g. tracker.example.com"
                                                 AutomationProperties.Name="Domain to inspect"
                                                 ToolTip="Domain to resolve and check block state" />
                                    </DockPanel>
                                    <TextBlock Text="{Binding InspectResult}" Style="{StaticResource Hg.SubText}" Margin="0,6,0,0" />

                                    <Separator Margin="0,10" Background="{DynamicResource Hg.S0}" />
                                    <TextBlock Text="Close DNS bypass" FontWeight="SemiBold" Margin="0,0,0,2" />
                                    <TextBlock TextWrapping="Wrap" Style="{StaticResource Hg.HelperText}" Margin="0,0,0,6"
                                               Text="Browsers using their own Secure DNS (DoH) resolve ad/tracker domains past the OS resolver, so they never appear in the feed and the hosts file can't block them. Turn this on to force browser DNS back onto the OS resolver — then everything shows up and is blockable." />
                                    <DockPanel LastChildFill="False" Margin="0,0,0,6">
                                        <Button DockPanel.Dock="Left"
                                                Command="{Binding ToggleSeeEverythingCommand}"
                                                AutomationProperties.Name="See everything — force browser DNS to the OS resolver"
                                                ToolTip="One click: block QUIC/UDP-443 and the DoH bootstrap together so browser DNS falls back to the OS resolver and the activity feed can see (and block) what loads.">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource Hg.AccentButton}">
                                                    <Setter Property="Content" Value="See everything (force browser DNS to OS resolver)" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SeeEverythingActive}" Value="True">
                                                            <Setter Property="Content" Value="See-everything is ON — click to turn off" />
                                                            <Setter Property="Background" Value="{DynamicResource Hg.Danger2}" />
                                                            <Setter Property="Foreground" Value="{DynamicResource Hg.OnDanger}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </DockPanel>
                                    <DockPanel LastChildFill="False">
                                        <Button DockPanel.Dock="Left" Margin="0,0,10,0"
                                                Command="{Binding ToggleEncryptedDnsCommand}"
                                                ToolTip="Firewall-block known DoH resolver IPs + DoT/DoQ port 853 so apps and browsers can't tunnel DNS past hosts blocking. Your own resolvers stay exempt.">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                    <Setter Property="Content" Value="Block encrypted DNS" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding DohBlockingActive}" Value="True">
                                                            <Setter Property="Content" Value="Unblock encrypted DNS" />
                                                            <Setter Property="Background" Value="{DynamicResource Hg.Danger2}" />
                                                            <Setter Property="Foreground" Value="{DynamicResource Hg.OnDanger}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                        <TextBox DockPanel.Dock="Left" Width="240" Margin="0,0,8,0"
                                                 Text="{Binding DohUrl, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource Hg.HintBox}"
                                                 Tag="Resolver-list URL (optional, https)"
                                                 AutomationProperties.Name="DoH intelligence URL"
                                                 ToolTip="Optional remote resolver-list URL (https)" />
                                        <TextBox DockPanel.Dock="Left" Width="200" Margin="0,0,8,0"
                                                 Text="{Binding DohSha256, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource Hg.HintBox}"
                                                 Tag="SHA-256 of the list"
                                                 AutomationProperties.Name="DoH intelligence SHA-256"
                                                 ToolTip="Expected SHA-256 of the remote list (required with a URL)" />
                                        <Button DockPanel.Dock="Left" Content="Refresh DoH intelligence"
                                                Command="{Binding RefreshDohCommand}" />
                                    </DockPanel>
                                    <DockPanel LastChildFill="False" Margin="0,8,0,0">
                                        <Button DockPanel.Dock="Left" Margin="0,0,10,0"
                                                Command="{Binding ToggleQuicCommand}"
                                                ToolTip="Block outbound QUIC/HTTP3 (UDP port 443). Forces clients to fall back to TCP so DoH3 and QUIC can't bypass hosts/SNI blocking. Clean fallback — browsing keeps working.">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                    <Setter Property="Content" Value="Block QUIC / HTTP3" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding QuicBlockingActive}" Value="True">
                                                            <Setter Property="Content" Value="Unblock QUIC / HTTP3" />
                                                            <Setter Property="Background" Value="{DynamicResource Hg.Danger2}" />
                                                            <Setter Property="Foreground" Value="{DynamicResource Hg.OnDanger}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                        <TextBlock DockPanel.Dock="Left" VerticalAlignment="Center"
                                                   Style="{StaticResource Hg.DimText}"
                                                   Text="Forces TCP fallback so DoH3/QUIC can't bypass blocking" />
                                    </DockPanel>
                                    <DockPanel LastChildFill="False" Margin="0,8,0,0">
                                        <Button DockPanel.Dock="Left" Margin="0,0,10,0"
                                                Command="{Binding ToggleCnameCloakCommand}"
                                                ToolTip="CNAME-cloak defense: when a first-party host resolves via CNAME to a blocked tracker, block the fronting host too. Uses the live DNS resolution chain; requires the elevated DNS monitor.">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                    <Setter Property="Content" Value="Arm CNAME-cloak defense" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding CnameCloakActive}" Value="True">
                                                            <Setter Property="Content" Value="Disarm CNAME-cloak defense" />
                                                            <Setter Property="Background" Value="{DynamicResource Hg.Danger2}" />
                                                            <Setter Property="Foreground" Value="{DynamicResource Hg.OnDanger}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                        <TextBlock DockPanel.Dock="Left" VerticalAlignment="Center"
                                                   Style="{StaticResource Hg.DimText}"
                                                   Text="Blocks first-party hosts that alias to blocked trackers" />
                                    </DockPanel>
                                    <DockPanel LastChildFill="False" Margin="0,8,0,0">
                                        <Button DockPanel.Dock="Left" Margin="0,0,10,0"
                                                Command="{Binding ToggleSniCaptureCommand}"
                                                ToolTip="TLS SNI capture (NET-109): recover the hostname of HTTPS connections even when DNS was resolved over DoH, by reading the ClientHello SNI. Driver-free raw-socket capture; ECH-encrypted SNI stays unavailable.">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                    <Setter Property="Content" Value="Capture TLS SNI" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SniCaptureActive}" Value="True">
                                                            <Setter Property="Content" Value="Stop SNI capture" />
                                                            <Setter Property="Background" Value="{DynamicResource Hg.Danger2}" />
                                                            <Setter Property="Foreground" Value="{DynamicResource Hg.OnDanger}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                        <TextBlock DockPanel.Dock="Left" VerticalAlignment="Center"
                                                   Style="{StaticResource Hg.DimText}"
                                                   Text="Names HTTPS dials the OS resolver never saw (DoH), ECH excepted" />
                                    </DockPanel>
                                    <Border Style="{StaticResource Hg.StatusStrip}" Margin="0,8,0,0">
                                        <TextBlock Text="{Binding DohStatusText}"
                                                   Style="{StaticResource Hg.SubText}"
                                                   AutomationProperties.LiveSetting="Polite" />
                                    </Border>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource Hg.Card}" Margin="0,0,0,10">
                                <StackPanel>
                                    <TextBlock Text="Blocked services" FontWeight="SemiBold" Margin="0,0,0,4" />
                                    <TextBlock Text="One-click hosts blocking of a service's primary domains. Best-effort: exact hostnames only; DoH can bypass it."
                                               Style="{StaticResource Hg.DimText}" Margin="0,0,0,8" TextWrapping="Wrap" />
                                    <ItemsControl ItemsSource="{Binding Services}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Content="{Binding Label}" Margin="0,0,8,8" Padding="10,5"
                                                        ToolTip="{Binding Note}"
                                                        Command="{Binding DataContext.ToggleServiceCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}">
                                                    <Button.Style>
                                                        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Blocked}" Value="True">
                                                                    <Setter Property="Background" Value="{DynamicResource Hg.Danger2}" />
                                                                    <Setter Property="Foreground" Value="{DynamicResource Hg.OnDanger}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <!-- Blocklist intelligence (reference index for candidate flagging) -->
                            <Border Style="{StaticResource Hg.Card}" Margin="0,0,0,10">
                                <StackPanel>
                                    <TextBlock Text="Blocklist intelligence" FontWeight="SemiBold" Margin="0,0,0,4" />
                                    <TextBlock Text="Every catalog blocklist is downloaded into a local reference index (never imported as blocks). Feed domains found on these lists show yellow as block candidates."
                                               Style="{StaticResource Hg.HelperText}" Margin="0,0,0,8" />
                                    <DockPanel LastChildFill="True">
                                        <Button DockPanel.Dock="Right" Content="Refresh reference lists"
                                                Command="{Binding RefreshIntelCommand}" Margin="8,0,0,0"
                                                ToolTip="Re-download every catalog list into the index (runs for a few minutes)" />
                                        <Border Style="{StaticResource Hg.StatusStrip}">
                                            <TextBlock Text="{Binding IntelStatusText}"
                                                       Style="{StaticResource Hg.SubText}"
                                                       TextWrapping="Wrap"
                                                       AutomationProperties.LiveSetting="Polite" />
                                        </Border>
                                    </DockPanel>
                                </StackPanel>
                            </Border>

                            <!-- AI domain categorization (DeepSeek) -->
                            <Border Style="{StaticResource Hg.Card}" Margin="0,0,0,10">
                                <StackPanel>
                                    <TextBlock Text="AI categorization (DeepSeek)" FontWeight="SemiBold" Margin="0,0,0,4" />
                                    <TextBlock Text="Uses the DeepSeek API to bucket blocked domains into hosts-file categories (Google Ads, Microsoft Telemetry, …) and re-homes the entries under matching '# Category' sections. With auto-categorize on, every new manual block is filed automatically."
                                               Style="{StaticResource Hg.HelperText}" Margin="0,0,0,8" />
                                    <TextBlock Text="DeepSeek API key" Style="{StaticResource Hg.FieldLabel}" />
                                    <DockPanel LastChildFill="True">
                                        <Button DockPanel.Dock="Right" Content="Save AI settings"
                                                Style="{StaticResource Hg.AccentButton}"
                                                Command="{Binding SaveAiConfigCommand}" Click="OnAiKeySync"
                                                Margin="8,0,0,0"
                                                ToolTip="Store the key in the service's protected data folder (leave blank to keep the current key)" />
                                        <TextBox DockPanel.Dock="Right" Width="150" Margin="8,0,0,0" VerticalAlignment="Center"
                                                 Text="{Binding AiModel, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource Hg.HintBox}" Tag="Model"
                                                 AutomationProperties.Name="AI model"
                                                 ToolTip="DeepSeek model (deepseek-chat is the default)" />
                                        <PasswordBox x:Name="AiKeyBox" VerticalAlignment="Center"
                                                     AutomationProperties.Name="DeepSeek API key" />
                                    </DockPanel>
                                    <DockPanel LastChildFill="False" Margin="0,8,0,0">
                                        <CheckBox DockPanel.Dock="Left" Content="Auto-categorize new blocks" VerticalAlignment="Center"
                                                  IsChecked="{Binding AiEnabled}" Margin="0,0,12,0"
                                                  ToolTip="File every new manual block under its AI-assigned category (save settings to apply)" />
                                        <Button DockPanel.Dock="Left" Content="Categorize uncategorized domains"
                                                Command="{Binding CategorizeAllCommand}" Margin="0,0,12,0"
                                                ToolTip="Send every uncategorized blocked domain to DeepSeek and organize the hosts file by category" />
                                        <Button DockPanel.Dock="Left" Content="Export AI knowledge"
                                                Command="{Binding ExportAiKnowledgeCommand}"
                                                ToolTip="Save everything the AI has learned (purposes, categories, connection info) to a reviewable JSON file" />
                                    </DockPanel>
                                    <Border Style="{StaticResource Hg.StatusStrip}" Margin="0,8,0,0">
                                        <TextBlock Text="{Binding AiStatusText}"
                                                   Style="{StaticResource Hg.SubText}"
                                                   TextWrapping="Wrap"
                                                   AutomationProperties.LiveSetting="Polite" />
                                    </Border>
                                </StackPanel>
                            </Border>

                            <!-- AI knowledge review & promote (NET-107) -->
                            <Border Style="{StaticResource Hg.Card}" Margin="0,0,0,10">
                                <StackPanel>
                                    <TextBlock Text="AI knowledge review" FontWeight="SemiBold" Margin="0,0,0,4" />
                                    <TextBlock Text="Review what the AI has learned and promote good labels into a user-curated store that beats the AI and survives restart. Discard wrong guesses. Every promotion/correction is remembered."
                                               Style="{StaticResource Hg.HelperText}" Margin="0,0,0,8" />
                                    <DockPanel LastChildFill="False" Margin="0,0,0,8">
                                        <Button DockPanel.Dock="Left" Content="Load learned" Command="{Binding LoadKnowledgeCommand}"
                                                Margin="0,0,8,0" ToolTip="List what the AI has learned" />
                                        <Button DockPanel.Dock="Left" Content="Mark all reviewed" Command="{Binding MarkKnowledgeReviewedCommand}"
                                                Margin="0,0,8,0" ToolTip="Advance the 'new since last review' marker to now" />
                                        <CheckBox DockPanel.Dock="Left" Content="Only new since last review" VerticalAlignment="Center"
                                                  IsChecked="{Binding KnowledgeOnlyNew}"
                                                  ToolTip="Show only entries the AI learned since your last review" />
                                    </DockPanel>
                                    <DataGrid ItemsSource="{Binding Knowledge}" AutoGenerateColumns="False"
                                              MaxHeight="240" IsReadOnly="False" CanUserAddRows="False"
                                              HeadersVisibility="Column" Margin="0,0,0,8"
                                              AutomationProperties.Name="Learned AI knowledge">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Kind" Binding="{Binding Kind}" IsReadOnly="True" Width="80" />
                                            <DataGridTextColumn Header="Domain / key" Binding="{Binding Key}" IsReadOnly="True" Width="1.4*" />
                                            <DataGridTextColumn Header="AI label" Binding="{Binding Value}" IsReadOnly="True" Width="1.4*" />
                                            <DataGridTextColumn Header="Promote as" Binding="{Binding EditValue, UpdateSourceTrigger=PropertyChanged}" Width="1.4*" />
                                            <DataGridTemplateColumn Header="Override" Width="1*">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding UserOverride}" VerticalAlignment="Center"
                                                                   Foreground="{DynamicResource Hg.Mauve}" />
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTemplateColumn Header="Actions" Width="Auto">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Orientation="Horizontal">
                                                            <Button Content="Promote" Margin="2,1"
                                                                    Command="{Binding DataContext.PromoteKnowledgeCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                                    CommandParameter="{Binding}" />
                                                            <Button Content="Discard" Margin="2,1"
                                                                    Command="{Binding DataContext.DiscardKnowledgeCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                                    CommandParameter="{Binding}" />
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                    <TextBlock Text="Correct a domain directly (remembered override):" Style="{StaticResource Hg.FieldLabel}" />
                                    <DockPanel LastChildFill="False">
                                        <ComboBox DockPanel.Dock="Left" Width="110" VerticalAlignment="Center"
                                                  ItemsSource="{Binding CorrectionKinds}" SelectedItem="{Binding CorrectKind}"
                                                  AutomationProperties.Name="Correction kind" />
                                        <TextBox DockPanel.Dock="Left" Width="190" Margin="8,0,0,0" VerticalAlignment="Center"
                                                 Text="{Binding CorrectDomain, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource Hg.HintBox}" Tag="domain.example.com"
                                                 AutomationProperties.Name="Correction domain" />
                                        <TextBox DockPanel.Dock="Left" Width="220" Margin="8,0,0,0" VerticalAlignment="Center"
                                                 Text="{Binding CorrectValue, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource Hg.HintBox}" Tag="new label (blank clears)"
                                                 AutomationProperties.Name="Correction value" />
                                        <Button DockPanel.Dock="Left" Content="Apply" Margin="8,0,0,0"
                                                Style="{StaticResource Hg.AccentButton}" Command="{Binding CorrectDomainCommand}" />
                                    </DockPanel>
                                    <Border Style="{StaticResource Hg.StatusStrip}" Margin="0,8,0,0">
                                        <TextBlock Text="{Binding KnowledgeStatusText}"
                                                   Style="{StaticResource Hg.SubText}"
                                                   TextWrapping="Wrap"
                                                   AutomationProperties.LiveSetting="Polite" />
                                    </Border>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource Hg.Card}" Margin="0,0,0,10">
                                <StackPanel>
                                    <TextBlock Text="Scheduled blocking" FontWeight="SemiBold" Margin="0,0,0,4" />
                                    <TextBlock Text="Use a domain, service target, or fw:HG_RuleName. Days accept Mon,Tue or 0-6; 24-hour windows can cross midnight."
                                               Style="{StaticResource Hg.HelperText}" Margin="0,0,0,8" />
                                    <DataGrid ItemsSource="{Binding Schedules}" IsReadOnly="False" MinHeight="80" MaxHeight="220"
                                              CanUserAddRows="False"
                                              AutomationProperties.Name="Scheduled blocking windows">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Domain / target" Binding="{Binding Target, UpdateSourceTrigger=PropertyChanged}" Width="2*" />
                                            <DataGridTextColumn Header="Days" Binding="{Binding DaysText, UpdateSourceTrigger=PropertyChanged}" Width="2*" />
                                            <DataGridTextColumn Header="Start" Binding="{Binding Start, UpdateSourceTrigger=PropertyChanged}" Width="80" />
                                            <DataGridTextColumn Header="End" Binding="{Binding End, UpdateSourceTrigger=PropertyChanged}" Width="80" />
                                            <DataGridTemplateColumn Header="Actions" Width="90">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Button Content="Remove" Padding="8,2"
                                                                Style="{StaticResource Hg.DangerButton}"
                                                                Command="{Binding DataContext.RemoveScheduleCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                                CommandParameter="{Binding}" />
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                    <Border Style="{StaticResource Hg.EmptyState}"
                                            Margin="0,8,0,0"
                                            Visibility="{Binding Schedules.Count, Converter={StaticResource EmptyStateVis}}">
                                        <TextBlock Text="No schedules yet. Add a blocking window, then save schedules."
                                                   Style="{StaticResource Hg.EmptyText}" />
                                    </Border>
                                    <DockPanel Margin="0,8,0,0" LastChildFill="False">
                                        <Button DockPanel.Dock="Left" Content="Add window"
                                                Command="{Binding AddScheduleCommand}" Margin="0,0,10,0" />
                                        <Button DockPanel.Dock="Left" Content="Save schedules"
                                                Style="{StaticResource Hg.AccentButton}"
                                                Command="{Binding SaveSchedulesCommand}" />
                                    </DockPanel>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource Hg.Card}" Margin="0,0,0,10">
                                <StackPanel>
                                    <TextBlock Text="Network profiles" FontWeight="SemiBold" Margin="0,0,0,4" />
                                    <TextBlock Text="Save named snapshots of the current policy, then switch them manually or let HostsGuard switch by network fingerprint."
                                               Style="{StaticResource Hg.HelperText}" Margin="0,0,0,4" />
                                    <TextBlock Text="{Binding ActiveProfile}" Style="{StaticResource Hg.DimText}" Margin="0,0,0,8" />
                                    <WrapPanel>
                                        <ComboBox Width="180" Margin="0,0,8,8"
                                                  ItemsSource="{Binding Profiles}"
                                                  AutomationProperties.Name="Saved network profiles"
                                                  SelectedItem="{Binding SelectedProfile}" />
                                        <Button Content="Switch"
                                                Style="{StaticResource Hg.AccentButton}"
                                                Command="{Binding SwitchProfileCommand}" Margin="0,0,8,8"
                                                ToolTip="Choose a saved profile first" />
                                        <Button Content="Delete"
                                                Style="{StaticResource Hg.DangerButton}"
                                                Command="{Binding DeleteProfileCommand}" Margin="0,0,16,8"
                                                ToolTip="Choose a saved profile first" />
                                        <TextBox Width="180" Margin="0,0,8,8"
                                                 Text="{Binding NewProfileName, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource Hg.HintBox}"
                                                 Tag="New profile name"
                                                 AutomationProperties.Name="New profile name"
                                                 ToolTip="Name for a snapshot of the current rule set" />
                                        <Button Content="Save current as profile"
                                                Command="{Binding SaveProfileCommand}"
                                                Margin="0,0,8,8"
                                                ToolTip="Enter a profile name before saving" />
                                    </WrapPanel>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource Hg.Card}" Margin="0,0,0,10">
                                <StackPanel>
                                    <TextBlock Text="Maintenance" FontWeight="SemiBold" Margin="0,0,0,4" />
                                    <TextBlock Text="Back up, harden, export diagnostics, refresh local intelligence, or recover the hosts file from a known-good state."
                                               Style="{StaticResource Hg.HelperText}" Margin="0,0,0,8" />
                                    <WrapPanel>
                                        <Button DockPanel.Dock="Left" Content="Backup hosts file"
                                                Command="{Binding BackupHostsCommand}" Margin="0,0,10,8" />
                                        <Button DockPanel.Dock="Left" Content="Harden hosts ACL"
                                                Command="{Binding HardenAclCommand}" Margin="0,0,10,8" />
                                        <Button DockPanel.Dock="Left" Content="Export support bundle (redacted)"
                                                Command="{Binding ExportBundleCommand}" Margin="0,0,10,8" />
                                        <Button DockPanel.Dock="Left" Content="Apply known-safe baseline"
                                                Command="{Binding ApplyBaselineCommand}" Margin="0,0,10,8"
                                                ToolTip="Pre-allow essential Windows binaries (Update, Defender, kernel) so ask-to-connect targets interesting traffic instead of prompting for OS infrastructure." />
                                        <Button DockPanel.Dock="Left"
                                                Command="{Binding ToggleSecureRulesCommand}" Margin="0,0,10,8"
                                                ToolTip="Secure Rules: the service recreates or re-enables any HostsGuard rule deleted or disabled behind its back. Only touches HG_ rules.">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                    <Setter Property="Content" Value="Arm Secure Rules" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SecureRulesActive}" Value="True">
                                                            <Setter Property="Content" Value="Disarm Secure Rules" />
                                                            <Setter Property="Background" Value="{DynamicResource Hg.Danger2}" />
                                                            <Setter Property="Foreground" Value="{DynamicResource Hg.OnDanger}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                        <Button DockPanel.Dock="Left" Content="Refresh threat intel"
                                                Command="{Binding RefreshThreatIntelCommand}" Margin="0,0,10,8" />
                                        <Button DockPanel.Dock="Left" Content="Refresh GeoIP"
                                                Command="{Binding RefreshGeoIpCommand}" Margin="0,0,10,8" />
                                        <Button DockPanel.Dock="Left" Content="Exclude hosts in Defender"
                                                Command="{Binding AddDefenderExclusionCommand}" Margin="0,0,10,8" />
                                        <Button DockPanel.Dock="Left" Content="Emergency reset hosts"
                                                Style="{StaticResource Hg.DangerButton}"
                                                Command="{Binding EmergencyResetCommand}"
                                                Margin="0,0,10,8" />
                                    </WrapPanel>
                                    <WrapPanel Margin="0,2,0,0">
                                        <TextBlock Text="Restore backup:" VerticalAlignment="Center" Margin="0,0,8,8" />
                                        <ComboBox Width="320" Margin="0,0,8,8"
                                                  ItemsSource="{Binding Backups}"
                                                  SelectedItem="{Binding SelectedBackup}"
                                                  DisplayMemberPath="Label"
                                                  AutomationProperties.Name="Hosts backup to restore"
                                                  ToolTip="Hosts-file backups in the service data directory" />
                                        <Button Content="Restore"
                                                Style="{StaticResource Hg.DangerButton}"
                                                Command="{Binding RestoreBackupCommand}" Margin="0,0,10,8"
                                                ToolTip="Choose a backup before restoring" />
                                        <Button Content="Refresh list"
                                                Command="{Binding LoadBackupsCommand}"
                                                Margin="0,0,10,8" />
                                    </WrapPanel>
                                    <Border Style="{StaticResource Hg.StatusStrip}" Margin="0,8,0,0">
                                        <StackPanel>
                                            <TextBlock Text="{Binding SecureRulesText}"
                                                       Style="{StaticResource Hg.SubText}"
                                                       AutomationProperties.LiveSetting="Polite" />
                                            <TextBlock Text="{Binding DefenderStatusText}"
                                                       Style="{StaticResource Hg.DimText}"
                                                       Margin="0,3,0,0"
                                                       AutomationProperties.LiveSetting="Polite" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <!-- Trusted publishers (NET-113) -->
                            <Border Style="{StaticResource Hg.Card}" Margin="0,0,0,10">
                                <StackPanel>
                                    <DockPanel LastChildFill="False">
                                        <TextBlock DockPanel.Dock="Left" Text="Trusted publishers" FontWeight="SemiBold" />
                                        <Button DockPanel.Dock="Right" Content="Refresh"
                                                Command="{Binding LoadTrustedPublishersCommand}" Padding="10,2" />
                                    </DockPanel>
                                    <TextBlock Text="Software signed by these Authenticode publishers is auto-allowed without a prompt. Add one from a consent prompt's 'Trust all software signed by…' checkbox."
                                               Style="{StaticResource Hg.HelperText}" Margin="0,4,0,8" />
                                    <ItemsControl ItemsSource="{Binding TrustedPublishers}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <DockPanel LastChildFill="False" Margin="0,0,0,4">
                                                    <TextBlock DockPanel.Dock="Left" Text="{Binding}" VerticalAlignment="Center" />
                                                    <Button DockPanel.Dock="Right" Content="Remove" Padding="8,2"
                                                            Command="{Binding DataContext.RemoveTrustedPublisherCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            CommandParameter="{Binding}" />
                                                </DockPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <TextBlock Text="No trusted publishers yet." Style="{StaticResource Hg.DimText}"
                                               Visibility="{Binding TrustedPublishers.Count, Converter={StaticResource EmptyStateVis}}" />
                                </StackPanel>
                            </Border>

                            <!-- Trusted folders (NET-117) -->
                            <Border Style="{StaticResource Hg.Card}" Margin="0,0,0,10">
                                <StackPanel>
                                    <DockPanel LastChildFill="False">
                                        <TextBlock DockPanel.Dock="Left" Text="Trusted folders" FontWeight="SemiBold" />
                                        <Button DockPanel.Dock="Right" Content="Refresh"
                                                Command="{Binding LoadTrustedFoldersCommand}" Padding="10,2" />
                                    </DockPanel>
                                    <TextBlock Text="Any binary under these folders is auto-allowed without a prompt — the driver-free 'trust this whole install directory'. Add one from a consent prompt's 'Trust all software in…' checkbox."
                                               Style="{StaticResource Hg.HelperText}" Margin="0,4,0,8" />
                                    <ItemsControl ItemsSource="{Binding TrustedFolders}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <DockPanel LastChildFill="False" Margin="0,0,0,4">
                                                    <TextBlock DockPanel.Dock="Left" Text="{Binding}" VerticalAlignment="Center" />
                                                    <Button DockPanel.Dock="Right" Content="Remove" Padding="8,2"
                                                            Command="{Binding DataContext.RemoveTrustedFolderCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            CommandParameter="{Binding}" />
                                                </DockPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <TextBlock Text="No trusted folders yet." Style="{StaticResource Hg.DimText}"
                                               Visibility="{Binding TrustedFolders.Count, Converter={StaticResource EmptyStateVis}}" />
                                </StackPanel>
                            </Border>

                            <!-- VPN-presence kill-switch (NET-119) -->
                            <Border Style="{StaticResource Hg.Card}" Margin="0,0,0,10">
                                <StackPanel>
                                    <DockPanel LastChildFill="False">
                                        <TextBlock DockPanel.Dock="Left" Text="VPN kill-switch" FontWeight="SemiBold" />
                                        <Button DockPanel.Dock="Right" Content="Refresh"
                                                Command="{Binding LoadKillSwitchCommand}" Padding="10,2" />
                                    </DockPanel>
                                    <TextBlock Text="Block ALL outbound whenever the chosen VPN adapter is down, so nothing leaks outside the tunnel; the prior posture is restored on reconnect. Existing allow rules still apply — keep one for your VPN client so the tunnel can reconnect. Opt-in, off by default."
                                               Style="{StaticResource Hg.HelperText}" Margin="0,4,0,8" TextWrapping="Wrap" />
                                    <WrapPanel>
                                        <TextBlock Text="VPN adapter:" VerticalAlignment="Center" Margin="0,0,8,8" />
                                        <ComboBox Width="360" Margin="0,0,8,8"
                                                  ItemsSource="{Binding Adapters}"
                                                  SelectedItem="{Binding SelectedAdapter}"
                                                  DisplayMemberPath="Label"
                                                  AutomationProperties.Name="VPN adapter to watch"
                                                  ToolTip="Pick the network adapter your VPN creates; when it drops the kill-switch engages" />
                                        <Button Command="{Binding ToggleKillSwitchCommand}" Margin="0,0,10,8"
                                                ToolTip="Turn the VPN kill-switch on or off">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                    <Setter Property="Content" Value="Enable kill-switch" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding KillSwitchEnabled}" Value="True">
                                                            <Setter Property="Content" Value="Disable kill-switch" />
                                                            <Setter Property="Background" Value="{DynamicResource Hg.Danger2}" />
                                                            <Setter Property="Foreground" Value="{DynamicResource Hg.OnDanger}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </WrapPanel>
                                    <Border Style="{StaticResource Hg.StatusStrip}" Margin="0,4,0,0">
                                        <TextBlock Text="{Binding KillSwitchStatusText}"
                                                   Style="{StaticResource Hg.SubText}"
                                                   AutomationProperties.LiveSetting="Polite" />
                                    </Border>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource Hg.StatusStrip}" Margin="0,0,0,0">
                                <TextBlock Text="{Binding StatusText}"
                                           Style="{StaticResource Hg.SubText}"
                                           AutomationProperties.LiveSetting="Polite" />
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>

            <Grid Background="{DynamicResource Hg.Bg}"
                  Visibility="{Binding IsConnected, Converter={StaticResource InverseBoolToVis}}">
                <Border Style="{StaticResource Hg.Card}"
                        MaxWidth="520"
                        Padding="22,18"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <StackPanel>
                        <TextBlock Text="Service connection needed"
                                   Style="{StaticResource Hg.SectionTitle}"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,6" />
                        <TextBlock Text="{Binding ConnectionText}"
                                   Style="{StaticResource Hg.EmptyText}"
                                   AutomationProperties.LiveSetting="Polite" />
                        <Button Content="Reconnect"
                                Command="{Binding ConnectCommand}"
                                HorizontalAlignment="Center"
                                Margin="0,14,0,0"
                                MinWidth="120"
                                ToolTip="Try the service connection again" />
                    </StackPanel>
                </Border>
            </Grid>
                    </Grid>
                </Border>
            </Grid>
        </DockPanel>
    </Grid>
</Window>
