<Window x:Class="HostsGuard.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:tb="http://www.hardcodet.net/taskbar"
        xmlns:vm="clr-namespace:HostsGuard.App.ViewModels"
        x:Name="Root"
        Style="{StaticResource Hg.Window}"
        Title="HostsGuard" Height="720" Width="1180"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:svc="clr-namespace:HostsGuard.App.Services"
        mc:Ignorable="d">
    <Window.Resources>
        <svc:PointsTextConverter x:Key="PointsConverter" />
        <svc:SeriesBrushConverter x:Key="SeriesBrush" />
    </Window.Resources>
    <Grid>
        <tb:TaskbarIcon x:Name="Tray"
                        IconSource="pack://application:,,,/HostsGuard.App;component/Assets/icon.ico"
                        ToolTipText="HostsGuard"
                        TrayMouseDoubleClick="OnTrayOpen">
            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Open HostsGuard" Click="OnTrayOpen" />
                    <Separator />
                    <MenuItem Header="Filtering mode">
                        <MenuItem Header="Normal — enforce silently" Tag="normal" Click="OnTrayMode" />
                        <MenuItem Header="Notify — prompt on new connections" Tag="notify" Click="OnTrayMode" />
                        <MenuItem Header="Learning — auto-allow and record" Tag="learning" Click="OnTrayMode" />
                    </MenuItem>
                    <Separator />
                    <MenuItem Header="Exit" Click="OnTrayExit" />
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
        </tb:TaskbarIcon>

        <DockPanel>
            <DockPanel.LayoutTransform>
                <ScaleTransform ScaleX="{Binding UiScale}" ScaleY="{Binding UiScale}" />
            </DockPanel.LayoutTransform>

            <!-- Status bar -->
            <StatusBar DockPanel.Dock="Bottom">
                <StatusBarItem>
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="9" Height="9" Margin="4,0,7,0" VerticalAlignment="Center">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="{DynamicResource Hg.Red}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                            <Setter Property="Fill" Value="{DynamicResource Hg.Green}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock Text="{Binding ConnectionText}" Style="{StaticResource Hg.SubText}" />
                    </StackPanel>
                </StatusBarItem>
                <Separator />
                <StatusBarItem>
                    <TextBlock Style="{StaticResource Hg.SubText}">
                        <Run Text="Hosts blocked:" /><Run Text="{Binding HostsBlocked, Mode=OneWay}" />
                        <Run Text="   DB blocked:" /><Run Text="{Binding DbBlocked, Mode=OneWay}" />
                        <Run Text="   Allowed:" /><Run Text="{Binding DbAllowed, Mode=OneWay}" />
                    </TextBlock>
                </StatusBarItem>
                <Separator />
                <StatusBarItem>
                    <TextBlock Text="{Binding FilteringModeText}" Style="{StaticResource Hg.SubText}"
                               ToolTip="Filtering mode — switch from the tray menu" />
                </StatusBarItem>
                <StatusBarItem HorizontalAlignment="Right">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Scale" Style="{StaticResource Hg.DimText}" VerticalAlignment="Center" Margin="0,0,6,0" />
                        <ComboBox ItemsSource="{x:Static vm:MainViewModel.UiScaleChoices}"
                                  SelectedItem="{Binding UiScalePct}"
                                  Width="64" Margin="0,0,10,0" />
                        <Button Content="Theme" Command="{Binding ToggleThemeCommand}" Padding="10,3" />
                    </StackPanel>
                </StatusBarItem>
            </StatusBar>

            <!-- Main tabs -->
            <TabControl Margin="8">
                <TabItem Header="Hosts Activity">
                    <Grid Margin="4" DataContext="{Binding Activity}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <DockPanel Grid.Row="0" Margin="0,0,0,8">
                            <Button DockPanel.Dock="Right" Content="Refresh"
                                    Command="{Binding RefreshCommand}" Margin="8,0,0,0" />
                            <CheckBox DockPanel.Dock="Right" Content="Show hidden" Margin="8,0,0,0"
                                      VerticalAlignment="Center"
                                      IsChecked="{Binding ShowHidden}" />
                            <TextBox Text="{Binding Filter, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Filter — supports field:value, !term, field!=value. Enter applies.">
                                <TextBox.InputBindings>
                                    <KeyBinding Key="Return" Command="{Binding RefreshCommand}" />
                                </TextBox.InputBindings>
                            </TextBox>
                        </DockPanel>

                        <DataGrid Grid.Row="1" x:Name="ActivityGrid" ItemsSource="{Binding Rows}">
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                                    <Setter Property="ToolTip" Value="{Binding Reason}" />
                                </Style>
                            </DataGrid.RowStyle>
                            <DataGrid.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Block"
                                              Command="{Binding PlacementTarget.DataContext.BlockCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding PlacementTarget.SelectedItem.Domain, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                    <MenuItem Header="Block root"
                                              Command="{Binding PlacementTarget.DataContext.BlockRootCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding PlacementTarget.SelectedItem.Domain, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                    <MenuItem Header="Allow"
                                              Command="{Binding PlacementTarget.DataContext.AllowCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding PlacementTarget.SelectedItem.Domain, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                    <MenuItem Header="Temp allow">
                                        <MenuItem Header="15 minutes"
                                                  Command="{Binding PlacementTarget.DataContext.TempAllow15Command, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding PlacementTarget.SelectedItem.Domain, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                        <MenuItem Header="1 hour"
                                                  Command="{Binding PlacementTarget.DataContext.TempAllow60Command, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding PlacementTarget.SelectedItem.Domain, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                        <MenuItem Header="8 hours"
                                                  Command="{Binding PlacementTarget.DataContext.TempAllow480Command, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding PlacementTarget.SelectedItem.Domain, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                    </MenuItem>
                                    <Separator />
                                    <MenuItem Header="Hide root"
                                              Command="{Binding PlacementTarget.DataContext.HideRootCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding PlacementTarget.SelectedItem.Domain, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                    <MenuItem Header="Unhide root"
                                              Command="{Binding PlacementTarget.DataContext.UnhideRootCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding PlacementTarget.SelectedItem.Domain, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                    <Separator />
                                    <MenuItem Header="Research online">
                                        <MenuItem Header="Google"
                                                  Command="{Binding PlacementTarget.DataContext.ResearchGoogleCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding PlacementTarget.SelectedItem.Domain, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                        <MenuItem Header="VirusTotal"
                                                  Command="{Binding PlacementTarget.DataContext.ResearchVirusTotalCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding PlacementTarget.SelectedItem.Domain, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                        <MenuItem Header="who.is"
                                                  Command="{Binding PlacementTarget.DataContext.ResearchWhoisCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding PlacementTarget.SelectedItem.Domain, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                    </MenuItem>
                                </ContextMenu>
                            </DataGrid.ContextMenu>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Domain" Binding="{Binding Domain}" Width="2*" />
                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="110" />
                                <DataGridTextColumn Header="Process" Binding="{Binding Process}" Width="160" />
                                <DataGridTextColumn Header="Hits" Binding="{Binding Hits}" Width="70" />
                                <DataGridTemplateColumn Header="24h" Width="132">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Viewbox Width="120" Height="20" Stretch="Fill" HorizontalAlignment="Left"
                                                     ToolTip="{Binding SparklineTip}">
                                                <Canvas Width="120" Height="20">
                                                    <Polyline Points="{Binding SparklinePoints, Converter={StaticResource PointsConverter}}"
                                                              Stroke="{DynamicResource Hg.Series1}"
                                                              StrokeThickness="1.2" StrokeLineJoin="Round" />
                                                </Canvas>
                                            </Viewbox>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Last seen" Binding="{Binding LastSeen}" Width="170" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <TextBlock Grid.Row="2" Margin="2,6,0,0"
                                   Text="{Binding StatusText}" Style="{StaticResource Hg.DimText}" />
                    </Grid>
                </TabItem>

                <TabItem Header="FW Activity">
                    <Grid Margin="4" DataContext="{Binding FwActivity}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Modes: lockdown = default-outbound Block; learning/observe persist to config -->
                        <DockPanel Grid.Row="0" Margin="0,0,0,8" LastChildFill="False">
                            <CheckBox DockPanel.Dock="Left" Content="Lockdown" Margin="0,0,14,0" VerticalAlignment="Center"
                                      IsChecked="{Binding Lockdown}"
                                      ToolTip="Set the default outbound action to Block on all firewall profiles" />
                            <CheckBox DockPanel.Dock="Left" Content="Learning" Margin="0,0,14,0" VerticalAlignment="Center"
                                      IsChecked="{Binding LearningMode}"
                                      ToolTip="Surface trust prompts for processes making new connections" />
                            <CheckBox DockPanel.Dock="Left" Content="Observe" Margin="0,0,14,0" VerticalAlignment="Center"
                                      IsChecked="{Binding ObserveMode}"
                                      ToolTip="Record new processes silently instead of prompting" />
                            <TextBlock DockPanel.Dock="Right" Text="{Binding PostureText}"
                                       Style="{StaticResource Hg.DimText}" VerticalAlignment="Center" />
                        </DockPanel>

                        <DataGrid Grid.Row="1" ItemsSource="{Binding Rows}">
                            <DataGrid.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Block remote IP"
                                              Command="{Binding PlacementTarget.DataContext.QuickBlockIpCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding PlacementTarget.SelectedItem.RemoteAddr, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                    <MenuItem Header="Block program"
                                              Command="{Binding PlacementTarget.DataContext.QuickBlockProcessCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                    <Separator />
                                    <MenuItem Header="Research online">
                                        <MenuItem Header="Google"
                                                  Command="{Binding PlacementTarget.DataContext.ResearchGoogleCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding PlacementTarget.SelectedItem.RemoteAddr, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                        <MenuItem Header="AbuseIPDB"
                                                  Command="{Binding PlacementTarget.DataContext.ResearchAbuseIpdbCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding PlacementTarget.SelectedItem.RemoteAddr, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                    </MenuItem>
                                </ContextMenu>
                            </DataGrid.ContextMenu>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Process" Binding="{Binding Process}" Width="160" />
                                <DataGridTextColumn Header="PID" Binding="{Binding Pid}" Width="60" />
                                <DataGridTextColumn Header="Proto" Binding="{Binding Protocol}" Width="60" />
                                <DataGridTextColumn Header="Remote address" Binding="{Binding RemoteAddr}" Width="*" />
                                <DataGridTextColumn Header="Port" Binding="{Binding RemotePort}" Width="60" />
                                <DataGridTextColumn Header="State" Binding="{Binding State}" Width="110" />
                                <DataGridTextColumn Header="Country" Binding="{Binding Country}" Width="80" />
                                <DataGridTextColumn Header="FW" Binding="{Binding FwStatus}" Width="90" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- Per-app activity timeline (new connections per minute) -->
                        <Border Grid.Row="2" Style="{StaticResource Hg.Card}" Margin="0,8,0,0">
                            <StackPanel>
                                <DockPanel LastChildFill="False">
                                    <TextBlock DockPanel.Dock="Left" Text="Per-app activity" FontWeight="SemiBold" />
                                    <TextBlock DockPanel.Dock="Right" Text="{Binding TimelineStatus}"
                                               Style="{StaticResource Hg.DimText}" />
                                </DockPanel>
                                <Grid Height="86" Margin="0,6,0,0" ClipToBounds="True">
                                    <ItemsControl ItemsSource="{Binding Timeline}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <Grid />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Viewbox Stretch="Fill">
                                                    <Canvas Width="600" Height="100">
                                                        <Polyline Points="{Binding PointsText, Converter={StaticResource PointsConverter}}"
                                                                  Stroke="{Binding ColorIndex, Converter={StaticResource SeriesBrush}}"
                                                                  StrokeThickness="1.6" StrokeLineJoin="Round" />
                                                    </Canvas>
                                                </Viewbox>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>
                                <ItemsControl ItemsSource="{Binding Timeline}" Margin="0,4,0,0">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,14,0">
                                                <Rectangle Width="10" Height="3" VerticalAlignment="Center" Margin="0,0,5,0"
                                                           Fill="{Binding ColorIndex, Converter={StaticResource SeriesBrush}}" />
                                                <TextBlock Text="{Binding Name}" Style="{StaticResource Hg.DimText}" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- Recent consent decisions with re-decide (WFCP-021) -->
                        <Border Grid.Row="3" Style="{StaticResource Hg.Card}" Margin="0,8,0,0">
                            <StackPanel>
                                <DockPanel LastChildFill="False">
                                    <TextBlock DockPanel.Dock="Left" Text="Recent connection decisions" FontWeight="SemiBold" />
                                    <Button DockPanel.Dock="Right" Content="Refresh"
                                            Command="{Binding LoadConsentHistoryCommand}" Padding="10,2" />
                                </DockPanel>
                                <DataGrid ItemsSource="{Binding ConsentHistory}" MaxHeight="150" Margin="0,6,0,0">
                                    <DataGrid.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="Allow permanently"
                                                      Command="{Binding PlacementTarget.DataContext.ReAllowCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                            <MenuItem Header="Block permanently"
                                                      Command="{Binding PlacementTarget.DataContext.ReBlockCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                        </ContextMenu>
                                    </DataGrid.ContextMenu>
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="When" Binding="{Binding DecidedAt}" Width="150" />
                                        <DataGridTextColumn Header="Application" Binding="{Binding Application}" Width="2*" />
                                        <DataGridTextColumn Header="Dir" Binding="{Binding Direction}" Width="46" />
                                        <DataGridTextColumn Header="Remote" Binding="{Binding RemoteAddress}" Width="*" />
                                        <DataGridTextColumn Header="Proto" Binding="{Binding Protocol}" Width="56" />
                                        <DataGridTextColumn Header="Verdict" Binding="{Binding Verdict}" Width="76" />
                                        <DataGridTextColumn Header="Scope" Binding="{Binding Scope}" Width="86" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </Border>

                        <TextBlock Grid.Row="4" Margin="2,6,0,0"
                                   Text="{Binding StatusText}" Style="{StaticResource Hg.DimText}" />
                    </Grid>
                </TabItem>

                <TabItem Header="Hosts File">
                    <TabControl Margin="0,4,0,0">
                        <TabItem Header="Managed Domains">
                            <Grid Margin="4" DataContext="{Binding Hosts}">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <DockPanel Grid.Row="0" Margin="0,0,0,8">
                                    <Button DockPanel.Dock="Right" Content="Refresh"
                                            Command="{Binding RefreshCommand}" Margin="8,0,0,0" />
                                    <Button DockPanel.Dock="Right" Content="Block"
                                            Style="{StaticResource Hg.AccentButton}"
                                            Command="{Binding BlockCommand}" Margin="8,0,0,0" />
                                    <TextBox DockPanel.Dock="Right" Width="220" Margin="8,0,0,0"
                                             Text="{Binding NewDomain, UpdateSourceTrigger=PropertyChanged}"
                                             ToolTip="Domain to block" />
                                    <ComboBox DockPanel.Dock="Right" Width="120" Margin="8,0,0,0"
                                              ItemsSource="{x:Static vm:HostsViewModel.StatusFilters}"
                                              SelectedItem="{Binding StatusFilter}" />
                                    <TextBox Text="{Binding Filter, UpdateSourceTrigger=PropertyChanged}"
                                             ToolTip="Filter — supports field:value, !term, field!=value. Enter applies.">
                                        <TextBox.InputBindings>
                                            <KeyBinding Key="Return" Command="{Binding RefreshCommand}" />
                                        </TextBox.InputBindings>
                                    </TextBox>
                                </DockPanel>

                                <DataGrid Grid.Row="1" x:Name="DomainsGrid" ItemsSource="{Binding Domains}">
                                    <DataGrid.RowStyle>
                                        <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                                            <Setter Property="ToolTip" Value="{Binding Reason}" />
                                        </Style>
                                    </DataGrid.RowStyle>
                                    <DataGrid.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="Block selected"
                                                      Command="{Binding PlacementTarget.DataContext.BlockSelectedCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding PlacementTarget.SelectedItems, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                            <MenuItem Header="Allow selected"
                                                      Command="{Binding PlacementTarget.DataContext.AllowSelectedCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding PlacementTarget.SelectedItems, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                            <MenuItem Header="Remove selected"
                                                      Command="{Binding PlacementTarget.DataContext.RemoveSelectedCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding PlacementTarget.SelectedItems, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                            <Separator />
                                            <MenuItem Header="Block root"
                                                      Command="{Binding PlacementTarget.DataContext.BlockRootCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding PlacementTarget.SelectedItem.Domain, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                            <Separator />
                                            <MenuItem Header="Research online">
                                                <MenuItem Header="Google"
                                                          Command="{Binding PlacementTarget.DataContext.ResearchGoogleCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                          CommandParameter="{Binding PlacementTarget.SelectedItem.Domain, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                                <MenuItem Header="VirusTotal"
                                                          Command="{Binding PlacementTarget.DataContext.ResearchVirusTotalCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                          CommandParameter="{Binding PlacementTarget.SelectedItem.Domain, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                                <MenuItem Header="who.is"
                                                          Command="{Binding PlacementTarget.DataContext.ResearchWhoisCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                          CommandParameter="{Binding PlacementTarget.SelectedItem.Domain, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                            </MenuItem>
                                        </ContextMenu>
                                    </DataGrid.ContextMenu>
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Domain" Binding="{Binding Domain}" Width="2*" />
                                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="110" />
                                        <DataGridTextColumn Header="Source" Binding="{Binding Source}" Width="110" />
                                        <DataGridTextColumn Header="Reason" Binding="{Binding Reason}" Width="2*" />
                                        <DataGridTextColumn Header="Hits" Binding="{Binding Hits}" Width="70" />
                                        <DataGridTemplateColumn Header="" Width="170">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal">
                                                        <Button Content="Allow" Padding="8,2" Margin="0,0,6,0"
                                                                Command="{Binding DataContext.AllowCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                                CommandParameter="{Binding Domain}" />
                                                        <Button Content="Remove" Padding="8,2"
                                                                Style="{StaticResource Hg.DangerButton}"
                                                                Command="{Binding DataContext.UnblockCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                                CommandParameter="{Binding Domain}" />
                                                    </StackPanel>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>

                                <TextBlock Grid.Row="2" Margin="2,6,0,0"
                                           Text="{Binding StatusText}" Style="{StaticResource Hg.DimText}" />
                            </Grid>
                        </TabItem>

                        <TabItem Header="Blocklists">
                            <Grid Margin="4" DataContext="{Binding Blocklists}">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <DataGrid Grid.Row="0" ItemsSource="{Binding Sources}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="120" />
                                        <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
                                        <DataGridCheckBoxColumn Header="Subscribed" Binding="{Binding Subscribed}" Width="90" IsReadOnly="True" />
                                        <DataGridTextColumn Header="Domains" Binding="{Binding DomainCount}" Width="90" />
                                        <DataGridTextColumn Header="Last refresh" Binding="{Binding LastRefresh}" Width="160" />
                                        <DataGridTextColumn Header="" Binding="{Binding Flags}" Width="70">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{DynamicResource Hg.Peach}" />
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTemplateColumn Header="" Width="190">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal">
                                                        <Button Content="Import" Padding="8,2" Margin="0,0,6,0"
                                                                Style="{StaticResource Hg.AccentButton}"
                                                                Command="{Binding DataContext.ImportCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                                CommandParameter="{Binding}" />
                                                        <Button Content="Unsubscribe" Padding="8,2"
                                                                Visibility="{Binding Subscribed, Converter={StaticResource BoolToVis}}"
                                                                Command="{Binding DataContext.UnsubscribeCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                                CommandParameter="{Binding}" />
                                                    </StackPanel>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>

                                <Border Grid.Row="1" Style="{StaticResource Hg.Card}" Margin="0,8,0,0">
                                    <DockPanel>
                                        <Button DockPanel.Dock="Right" Content="Save + apply allowlists"
                                                Style="{StaticResource Hg.AccentButton}"
                                                Command="{Binding SaveAllowlistsCommand}" Margin="8,0,0,0"
                                                VerticalAlignment="Top" />
                                        <Button DockPanel.Dock="Right" Content="Refresh all subscriptions"
                                                Command="{Binding RefreshAllListsCommand}" Margin="8,0,0,0"
                                                VerticalAlignment="Top" />
                                        <StackPanel>
                                            <TextBlock Text="Allowlist URLs (one per line — whitelisted domains always win over blocklists)"
                                                       Style="{StaticResource Hg.SubText}" Margin="0,0,0,4" />
                                            <TextBox Text="{Binding AllowlistUrlsText, UpdateSourceTrigger=PropertyChanged}"
                                                     AcceptsReturn="True" MinHeight="52" MaxHeight="110"
                                                     VerticalScrollBarVisibility="Auto" FontFamily="Consolas" />
                                        </StackPanel>
                                    </DockPanel>
                                </Border>

                                <TextBlock Grid.Row="2" Margin="2,6,0,0"
                                           Text="{Binding StatusText}" Style="{StaticResource Hg.DimText}" />
                            </Grid>
                        </TabItem>

                        <TabItem Header="Raw Editor">
                            <Grid Margin="4" DataContext="{Binding RawHosts}">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <DockPanel Grid.Row="0" Margin="0,0,0,8" LastChildFill="False">
                                    <Button DockPanel.Dock="Right" Content="Save"
                                            Style="{StaticResource Hg.AccentButton}"
                                            Command="{Binding SaveCommand}" IsEnabled="{Binding IsDirty}" />
                                    <Button DockPanel.Dock="Right" Content="Reload"
                                            Command="{Binding LoadCommand}" Margin="0,0,8,0" />
                                </DockPanel>

                                <TextBox Grid.Row="1"
                                         Text="{Binding Text, UpdateSourceTrigger=PropertyChanged}"
                                         AcceptsReturn="True" AcceptsTab="True"
                                         FontFamily="Consolas"
                                         VerticalScrollBarVisibility="Auto"
                                         HorizontalScrollBarVisibility="Auto" />

                                <TextBlock Grid.Row="2" Margin="2,6,0,0"
                                           Text="{Binding StatusText}" Style="{StaticResource Hg.DimText}" />
                            </Grid>
                        </TabItem>
                    </TabControl>
                </TabItem>

                <TabItem Header="FW Rules">
                    <Grid Margin="4" DataContext="{Binding FwRules}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <DockPanel Grid.Row="0" Margin="0,0,0,8">
                            <Button DockPanel.Dock="Right" Content="Refresh"
                                    Command="{Binding RefreshCommand}" Margin="8,0,0,0" />
                            <CheckBox DockPanel.Dock="Right" Content="HostsGuard rules only" Margin="8,0,0,0"
                                      VerticalAlignment="Center" IsChecked="{Binding HostsGuardOnly}" />
                            <TextBox Text="{Binding Filter, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Filter by name, address, or program. Enter applies.">
                                <TextBox.InputBindings>
                                    <KeyBinding Key="Return" Command="{Binding RefreshCommand}" />
                                </TextBox.InputBindings>
                            </TextBox>
                        </DockPanel>

                        <DataGrid Grid.Row="1" ItemsSource="{Binding Rules}">
                            <DataGrid.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Enable / disable"
                                              Command="{Binding PlacementTarget.DataContext.ToggleRuleCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                    <MenuItem Header="Delete"
                                              Command="{Binding PlacementTarget.DataContext.DeleteRuleCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding PlacementTarget.SelectedItem.Name, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                    <MenuItem Header="Delete selected"
                                              Command="{Binding PlacementTarget.DataContext.DeleteSelectedCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding PlacementTarget.SelectedItems, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                    <Separator />
                                    <MenuItem Header="Suggest / rebind program…"
                                              Command="{Binding PlacementTarget.DataContext.RebindRuleCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                </ContextMenu>
                            </DataGrid.ContextMenu>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="2*" />
                                <DataGridTextColumn Header="Dir" Binding="{Binding Direction}" Width="50" />
                                <DataGridTextColumn Header="Action" Binding="{Binding Action}" Width="70" />
                                <DataGridCheckBoxColumn Header="On" Binding="{Binding Enabled}" Width="46" IsReadOnly="True" />
                                <DataGridTextColumn Header="Remote" Binding="{Binding RemoteAddr}" Width="*" />
                                <DataGridTextColumn Header="Proto" Binding="{Binding Protocol}" Width="60" />
                                <DataGridTextColumn Header="Program" Binding="{Binding Program}" Width="*" />
                                <DataGridTextColumn Header="Flags" Binding="{Binding Flags}" Width="110">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource Hg.Peach}" />
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- Inline custom-rule form -->
                        <Border Grid.Row="2" Style="{StaticResource Hg.Card}" Margin="0,8,0,0">
                            <DockPanel>
                                <Button DockPanel.Dock="Right" Content="Create rule"
                                        Style="{StaticResource Hg.AccentButton}"
                                        Command="{Binding CreateRuleCommand}" Margin="8,0,0,0" />
                                <TextBox DockPanel.Dock="Left" Width="180" Margin="0,0,8,0"
                                         Text="{Binding NewRuleName, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="Rule name (HG_ prefix added automatically)" />
                                <ComboBox DockPanel.Dock="Left" Width="64" Margin="0,0,8,0"
                                          ItemsSource="{x:Static vm:FwRulesViewModel.Directions}"
                                          SelectedItem="{Binding NewRuleDirection}" />
                                <ComboBox DockPanel.Dock="Left" Width="80" Margin="0,0,8,0"
                                          ItemsSource="{x:Static vm:FwRulesViewModel.Actions}"
                                          SelectedItem="{Binding NewRuleAction}" />
                                <ComboBox DockPanel.Dock="Left" Width="70" Margin="0,0,8,0"
                                          ItemsSource="{x:Static vm:FwRulesViewModel.Protocols}"
                                          SelectedItem="{Binding NewRuleProtocol}" />
                                <TextBox DockPanel.Dock="Left" Width="180" Margin="0,0,8,0"
                                         Text="{Binding NewRuleRemoteAddr, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="Remote address: IP, CIDR, or range (empty = Any)" />
                                <TextBox Text="{Binding NewRuleProgram, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="Program path (optional)" />
                            </DockPanel>
                        </Border>

                        <TextBlock Grid.Row="3" Margin="2,6,0,0"
                                   Text="{Binding StatusText}" Style="{StaticResource Hg.DimText}" />
                    </Grid>
                </TabItem>

                <TabItem Header="Tools">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="8" DataContext="{Binding Tools}">

                            <Border Style="{StaticResource Hg.Card}" Margin="0,0,0,10">
                                <StackPanel>
                                    <TextBlock Text="DNS" FontWeight="SemiBold" Margin="0,0,0,8" />
                                    <DockPanel LastChildFill="False">
                                        <Button DockPanel.Dock="Left" Content="Flush DNS cache"
                                                Command="{Binding FlushDnsCommand}" Margin="0,0,10,0" />
                                        <ComboBox DockPanel.Dock="Left" Width="180" Margin="0,0,10,0"
                                                  ItemsSource="{x:Static vm:ToolsViewModel.ResolverNames}"
                                                  SelectedItem="{Binding SelectedResolver}" />
                                        <Button DockPanel.Dock="Left" Content="Apply resolver"
                                                Command="{Binding ApplyResolverCommand}" />
                                    </DockPanel>
                                    <DockPanel Margin="0,10,0,0">
                                        <Button DockPanel.Dock="Right" Content="Inspect"
                                                Command="{Binding InspectCommand}" Margin="8,0,0,0" />
                                        <TextBox Text="{Binding InspectDomain, UpdateSourceTrigger=PropertyChanged}"
                                                 ToolTip="Domain to resolve and check block state">
                                            <TextBox.InputBindings>
                                                <KeyBinding Key="Return" Command="{Binding InspectCommand}" />
                                            </TextBox.InputBindings>
                                        </TextBox>
                                    </DockPanel>
                                    <TextBlock Text="{Binding InspectResult}" Style="{StaticResource Hg.SubText}" Margin="0,6,0,0" />

                                    <Separator Margin="0,10" Background="{DynamicResource Hg.S0}" />
                                    <DockPanel LastChildFill="False">
                                        <Button DockPanel.Dock="Left" Margin="0,0,10,0"
                                                Command="{Binding ToggleEncryptedDnsCommand}"
                                                ToolTip="Firewall-block known DoH resolver IPs + DoT/DoQ port 853 so apps and browsers can't tunnel DNS past hosts blocking. Your own resolvers stay exempt.">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                    <Setter Property="Content" Value="Block encrypted DNS" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding DohBlockingActive}" Value="True">
                                                            <Setter Property="Content" Value="Unblock encrypted DNS" />
                                                            <Setter Property="Background" Value="{DynamicResource Hg.Danger2}" />
                                                            <Setter Property="Foreground" Value="{DynamicResource Hg.OnDanger}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                        <TextBox DockPanel.Dock="Left" Width="240" Margin="0,0,8,0"
                                                 Text="{Binding DohUrl, UpdateSourceTrigger=PropertyChanged}"
                                                 ToolTip="Optional remote resolver-list URL (https)" />
                                        <TextBox DockPanel.Dock="Left" Width="200" Margin="0,0,8,0"
                                                 Text="{Binding DohSha256, UpdateSourceTrigger=PropertyChanged}"
                                                 ToolTip="Expected SHA-256 of the remote list (required with a URL)" />
                                        <Button DockPanel.Dock="Left" Content="Refresh DoH intelligence"
                                                Command="{Binding RefreshDohCommand}" />
                                    </DockPanel>
                                    <DockPanel LastChildFill="False" Margin="0,8,0,0">
                                        <Button DockPanel.Dock="Left" Margin="0,0,10,0"
                                                Command="{Binding ToggleQuicCommand}"
                                                ToolTip="Block outbound QUIC/HTTP3 (UDP port 443). Forces clients to fall back to TCP so DoH3 and QUIC can't bypass hosts/SNI blocking. Clean fallback — browsing keeps working.">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                    <Setter Property="Content" Value="Block QUIC / HTTP3" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding QuicBlockingActive}" Value="True">
                                                            <Setter Property="Content" Value="Unblock QUIC / HTTP3" />
                                                            <Setter Property="Background" Value="{DynamicResource Hg.Danger2}" />
                                                            <Setter Property="Foreground" Value="{DynamicResource Hg.OnDanger}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                        <TextBlock DockPanel.Dock="Left" VerticalAlignment="Center"
                                                   Style="{StaticResource Hg.DimText}"
                                                   Text="Forces TCP fallback so DoH3/QUIC can't bypass blocking" />
                                    </DockPanel>
                                    <TextBlock Text="{Binding DohStatusText}" Style="{StaticResource Hg.DimText}" Margin="0,6,0,0" />
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource Hg.Card}" Margin="0,0,0,10">
                                <StackPanel>
                                    <TextBlock Text="Blocked services" FontWeight="SemiBold" Margin="0,0,0,4" />
                                    <TextBlock Text="One-click hosts blocking of a service's primary domains. Best-effort: exact hostnames only; DoH can bypass it."
                                               Style="{StaticResource Hg.DimText}" Margin="0,0,0,8" TextWrapping="Wrap" />
                                    <ItemsControl ItemsSource="{Binding Services}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Content="{Binding Label}" Margin="0,0,8,8" Padding="10,5"
                                                        ToolTip="{Binding Note}"
                                                        Command="{Binding DataContext.ToggleServiceCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}">
                                                    <Button.Style>
                                                        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Blocked}" Value="True">
                                                                    <Setter Property="Background" Value="{DynamicResource Hg.Danger2}" />
                                                                    <Setter Property="Foreground" Value="{DynamicResource Hg.OnDanger}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource Hg.Card}" Margin="0,0,0,10">
                                <StackPanel>
                                    <TextBlock Text="Scheduled blocking" FontWeight="SemiBold" Margin="0,0,0,8" />
                                    <DataGrid ItemsSource="{Binding Schedules}" IsReadOnly="False" MinHeight="80" MaxHeight="220"
                                              CanUserAddRows="False">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Domain / target" Binding="{Binding Target, UpdateSourceTrigger=PropertyChanged}" Width="2*" />
                                            <DataGridTextColumn Header="Days (Mon,Tue…)" Binding="{Binding DaysText, UpdateSourceTrigger=PropertyChanged}" Width="2*" />
                                            <DataGridTextColumn Header="Start" Binding="{Binding Start, UpdateSourceTrigger=PropertyChanged}" Width="80" />
                                            <DataGridTextColumn Header="End" Binding="{Binding End, UpdateSourceTrigger=PropertyChanged}" Width="80" />
                                            <DataGridTemplateColumn Header="" Width="90">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Button Content="Remove" Padding="8,2"
                                                                Style="{StaticResource Hg.DangerButton}"
                                                                Command="{Binding DataContext.RemoveScheduleCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                                CommandParameter="{Binding}" />
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                    <DockPanel Margin="0,8,0,0" LastChildFill="False">
                                        <Button DockPanel.Dock="Left" Content="Add window"
                                                Command="{Binding AddScheduleCommand}" Margin="0,0,10,0" />
                                        <Button DockPanel.Dock="Left" Content="Save schedules"
                                                Style="{StaticResource Hg.AccentButton}"
                                                Command="{Binding SaveSchedulesCommand}" />
                                    </DockPanel>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource Hg.Card}" Margin="0,0,0,10">
                                <StackPanel>
                                    <TextBlock Text="Network profiles" FontWeight="SemiBold" Margin="0,0,0,4" />
                                    <TextBlock Text="{Binding ActiveProfile}" Style="{StaticResource Hg.DimText}" Margin="0,0,0,8" />
                                    <DockPanel LastChildFill="False">
                                        <ComboBox DockPanel.Dock="Left" Width="180" Margin="0,0,8,0"
                                                  ItemsSource="{Binding Profiles}"
                                                  SelectedItem="{Binding SelectedProfile}" />
                                        <Button DockPanel.Dock="Left" Content="Switch"
                                                Style="{StaticResource Hg.AccentButton}"
                                                Command="{Binding SwitchProfileCommand}" Margin="0,0,8,0" />
                                        <Button DockPanel.Dock="Left" Content="Delete"
                                                Style="{StaticResource Hg.DangerButton}"
                                                Command="{Binding DeleteProfileCommand}" Margin="0,0,16,0" />
                                        <TextBox DockPanel.Dock="Left" Width="180" Margin="0,0,8,0"
                                                 Text="{Binding NewProfileName, UpdateSourceTrigger=PropertyChanged}"
                                                 ToolTip="Name for a snapshot of the current rule set" />
                                        <Button DockPanel.Dock="Left" Content="Save current as profile"
                                                Command="{Binding SaveProfileCommand}" />
                                    </DockPanel>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource Hg.Card}" Margin="0,0,0,10">
                                <StackPanel>
                                    <TextBlock Text="Maintenance" FontWeight="SemiBold" Margin="0,0,0,8" />
                                    <DockPanel LastChildFill="False">
                                        <Button DockPanel.Dock="Left" Content="Backup hosts file"
                                                Command="{Binding BackupHostsCommand}" Margin="0,0,10,0" />
                                        <Button DockPanel.Dock="Left" Content="Harden hosts ACL"
                                                Command="{Binding HardenAclCommand}" Margin="0,0,10,0" />
                                        <Button DockPanel.Dock="Left" Content="Export support bundle (redacted)"
                                                Command="{Binding ExportBundleCommand}" Margin="0,0,10,0" />
                                        <Button DockPanel.Dock="Left" Content="Apply known-safe baseline"
                                                Command="{Binding ApplyBaselineCommand}" Margin="0,0,10,0"
                                                ToolTip="Pre-allow essential Windows binaries (Update, Defender, kernel) so ask-to-connect targets interesting traffic instead of prompting for OS infrastructure." />
                                        <Button DockPanel.Dock="Left"
                                                Command="{Binding ToggleSecureRulesCommand}" Margin="0,0,10,0"
                                                ToolTip="Secure Rules: the service recreates or re-enables any HostsGuard rule deleted or disabled behind its back. Only touches HG_ rules.">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                    <Setter Property="Content" Value="Arm Secure Rules" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SecureRulesActive}" Value="True">
                                                            <Setter Property="Content" Value="Disarm Secure Rules" />
                                                            <Setter Property="Background" Value="{DynamicResource Hg.Danger2}" />
                                                            <Setter Property="Foreground" Value="{DynamicResource Hg.OnDanger}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                        <Button DockPanel.Dock="Left" Content="Refresh threat intel"
                                                Command="{Binding RefreshThreatIntelCommand}" Margin="0,0,10,0" />
                                        <Button DockPanel.Dock="Left" Content="Refresh GeoIP"
                                                Command="{Binding RefreshGeoIpCommand}" Margin="0,0,10,0" />
                                        <Button DockPanel.Dock="Left" Content="Exclude hosts in Defender"
                                                Command="{Binding AddDefenderExclusionCommand}" Margin="0,0,10,0" />
                                        <Button DockPanel.Dock="Left" Content="Emergency reset hosts"
                                                Style="{StaticResource Hg.DangerButton}"
                                                Command="{Binding EmergencyResetCommand}" />
                                    </DockPanel>
                                    <DockPanel LastChildFill="False" Margin="0,8,0,0">
                                        <TextBlock DockPanel.Dock="Left" Text="Restore backup:" VerticalAlignment="Center" Margin="0,0,8,0" />
                                        <ComboBox DockPanel.Dock="Left" Width="320" Margin="0,0,8,0"
                                                  ItemsSource="{Binding Backups}"
                                                  SelectedItem="{Binding SelectedBackup}"
                                                  DisplayMemberPath="Label"
                                                  ToolTip="Hosts-file backups in the service data directory" />
                                        <Button DockPanel.Dock="Left" Content="Restore"
                                                Style="{StaticResource Hg.DangerButton}"
                                                Command="{Binding RestoreBackupCommand}" Margin="0,0,10,0" />
                                        <Button DockPanel.Dock="Left" Content="Refresh list"
                                                Command="{Binding LoadBackupsCommand}" />
                                    </DockPanel>
                                    <TextBlock Text="{Binding DefenderStatusText}" Style="{StaticResource Hg.DimText}" Margin="0,6,0,0" />
                                </StackPanel>
                            </Border>

                            <TextBlock Text="{Binding StatusText}" Style="{StaticResource Hg.DimText}" Margin="2,0,0,0" />
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </DockPanel>
    </Grid>
</Window>
