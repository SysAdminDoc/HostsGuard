<Window x:Class="HostsGuard.App.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:svc="clr-namespace:HostsGuard.App.Services"
        Style="{StaticResource Hg.Window}"
        Title="{svc:Loc Key=Xaml_Enter_a_value_cd8763c9}"
        Width="460"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        AutomationProperties.Name="{svc:Loc Key=Xaml_HostsGuard_input_cfced166}">
    <Border BorderBrush="{DynamicResource Hg.S1}"
            BorderThickness="1"
            Background="{DynamicResource Hg.Base}">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0">
                <Border DockPanel.Dock="Left"
                        Width="6"
                        Height="28"
                        CornerRadius="4"
                        Background="{DynamicResource Hg.Mauve}"
                        Margin="0,0,10,0" />
                <TextBlock x:Name="TitleText"
                           FontSize="17"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center" />
            </DockPanel>

            <TextBlock Grid.Row="1"
                       x:Name="MessageText"
                       Margin="0,12,0,0"
                       Style="{StaticResource Hg.SubText}"
                       TextWrapping="Wrap"
                       LineHeight="20" />

            <TextBox Grid.Row="2"
                     x:Name="InputBox"
                     Margin="0,14,0,0"
                     MinWidth="360"
                     SpellCheck.IsEnabled="False"
                     AutomationProperties.Name="{svc:Loc Key=Xaml_Input_value_a9e020d6}" />

            <Border Grid.Row="3"
                    Style="{StaticResource Hg.StatusStrip}"
                    Margin="0,12,0,0">
                <TextBlock Text="{svc:Loc Key=Xaml_Save_applies_the_value_immediately_Cancel_bb5061bb}"
                           Style="{StaticResource Hg.DimText}"
                           TextWrapping="Wrap" />
            </Border>

            <Grid Grid.Row="4" Margin="0,18,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="1"
                        x:Name="CancelButton"
                        Content="{svc:Loc Key=Xaml_Cancel_77dfd213}"
                        MinWidth="92"
                        Margin="0,0,8,0"
                        IsCancel="True"
                        Click="OnCancel" />
                <Button Grid.Column="2"
                        x:Name="OkButton"
                        Content="{svc:Loc Key=Xaml_Save_efc007a3}"
                        MinWidth="104"
                        Style="{StaticResource Hg.AccentButton}"
                        IsDefault="True"
                        Click="OnOk" />
            </Grid>
        </Grid>
    </Border>
</Window>
