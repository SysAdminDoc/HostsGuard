<views:MajorTabPage x:Class="HostsGuard.App.Views.AlertsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:svc="clr-namespace:HostsGuard.App.Services"
             xmlns:vm="clr-namespace:HostsGuard.App.ViewModels"
             xmlns:views="clr-namespace:HostsGuard.App.Views"
             d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
             mc:Ignorable="d">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/HostsGuard.App;component/Views/MajorTabResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <Grid Margin="4" DataContext="{Binding Alerts}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0" Grid.RowSpan="2" x:Name="AlertsTabs"
                    Style="{StaticResource Hg.PrimaryTabs}"
                    ItemContainerStyle="{StaticResource Hg.SecondaryTabItem}">
            <TabItem Header="{svc:Loc Key=AllowlistReview_InboxTab}">
                <Grid Margin="4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource Hg.CommandBar}" Margin="0,0,0,8">
            <WrapPanel VerticalAlignment="Center">
                <TextBox Text="{Binding TypeFilter, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource Hg.HintBox}"
                         MinWidth="160" Margin="0,0,8,6"
                         Tag="{svc:Loc Key=Xaml_Type_filter_6e3b3ab7}"
                         AutomationProperties.Name="{svc:Loc Key=Xaml_Type_filter_6e3b3ab7}"
                         ToolTip="{svc:Loc Key=Xaml_Alert_type_exact_filter_095a0f53}" />
                <CheckBox Content="{svc:Loc Key=Xaml_Surface_only_5f216e59}" Margin="0,0,8,6"
                          VerticalAlignment="Center"
                          IsChecked="{Binding SurfaceOnly}"
                          ToolTip="{svc:Loc Key=Xaml_Show_only_alert_types_configured_to_baa98b18}" />
                <CheckBox Margin="0,0,8,6" VerticalAlignment="Center"
                          IsChecked="{Binding IncludeRead}"
                          ToolTip="{svc:Loc Key=Xaml_Include_acknowledged_alerts_c79eea1f}">
                    <TextBlock Text="{svc:Loc Key=Xaml_Include_read_23a80646}" TextWrapping="Wrap" MaxWidth="120" />
                </CheckBox>
                <Button Command="{Binding AckCommand}"
                        CommandParameter="{Binding SelectedItem, ElementName=AlertsGrid}"
                        Margin="0,0,8,6">
                    <TextBlock Text="{svc:Loc Key=Xaml_Acknowledge_selected_01567827}" TextWrapping="Wrap" TextAlignment="Center" />
                </Button>
                <Button Command="{Binding AckAllCommand}" Margin="0,0,8,6">
                    <TextBlock Text="{svc:Loc Key=Xaml_Acknowledge_all_40e0718f}" TextWrapping="Wrap" TextAlignment="Center" />
                </Button>
                <Button Content="{svc:Loc Key=Xaml_Refresh_56e3badc}"
                        Command="{Binding RefreshCommand}" Margin="8,0,0,0" />
            </WrapPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="400" />
            </Grid.ColumnDefinitions>

            <DataGrid Grid.Column="0" x:Name="AlertsGrid" ItemsSource="{Binding Alerts}"
                      SelectedItem="{Binding SelectedAlert, Mode=TwoWay}"
                      AutomationProperties.Name="{svc:Loc Key=Xaml_Low_volume_alerts_cad2ca46}"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                      IsVisibleChanged="OnGridVisible">
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Foreground" Value="{DynamicResource Hg.Text}" />
                        <Setter Property="MinHeight" Value="32" />
                        <Setter Property="FontWeight" Value="SemiBold" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsRead}" Value="True">
                                <Setter Property="FontWeight" Value="Normal" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Severity}" Value="critical">
                                <Setter Property="Background" Value="{DynamicResource Hg.DangerRow}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Severity}" Value="warning">
                                <Setter Property="Background" Value="{DynamicResource Hg.WarnRow}" />
                            </DataTrigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource Hg.RowSelected}" />
                                <Setter Property="Foreground" Value="{DynamicResource Hg.OnRowSelected}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{DynamicResource Hg.RowSelected}" />
                                <Setter Property="Foreground" Value="{DynamicResource Hg.OnRowSelected}" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="{svc:Loc Key=Xaml_When_769bb19e}" Binding="{Binding UpdatedText}" Width="118" />
                    <DataGridTextColumn Header="{svc:Loc Key=Xaml_Severity_2de3cb85}" Binding="{Binding Severity}" Width="82">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="SemiBold" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Severity}" Value="warning">
                                        <Setter Property="Foreground" Value="{DynamicResource Hg.Yellow}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Severity}" Value="critical">
                                        <Setter Property="Foreground" Value="{DynamicResource Hg.Red}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="{svc:Loc Key=Xaml_Title_b78a3223}" Binding="{Binding Title}" Width="150" />
                    <DataGridTextColumn Header="{svc:Loc Key=Xaml_Subject_8d183dbd}" Binding="{Binding Subject}" Width="1.2*" />
                    <DataGridTextColumn Header="{svc:Loc Key=Xaml_Details_dc3decbb}" Binding="{Binding Details}" Width="1.8*" />
                    <DataGridTextColumn Header="{svc:Loc Key=Xaml_Process_12f4c13a}" Binding="{Binding Process}" Width="1*" />
                    <DataGridTextColumn Header="{svc:Loc Key=Xaml_Type_4f6f5f0b}" Binding="{Binding Type}" Width="110" />
                    <DataGridCheckBoxColumn Header="{svc:Loc Key=Xaml_Read_d8e2f72f}" Binding="{Binding IsRead}" Width="54" IsReadOnly="True" />
                </DataGrid.Columns>
            </DataGrid>

            <Border Grid.Column="0"
                    Style="{StaticResource Hg.EmptyState}"
                    Visibility="{Binding Alerts.Count, Converter={StaticResource EmptyStateVis}}">
                <StackPanel>
                    <TextBlock Text="{svc:Loc Key=Xaml_No_alerts_yet_69542c8a}"
                               Style="{StaticResource Hg.SectionTitle}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,4" />
                    <TextBlock Text="{svc:Loc Key=Xaml_Alerts_will_appear_here_when_3f0d73ac}"
                               Style="{StaticResource Hg.EmptyText}" />
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource Hg.Card}" Margin="10,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="{svc:Loc Key=Xaml_Alert_type_settings_8e403573}" FontWeight="SemiBold" />
                    <Border Grid.Row="1" Margin="0,8,0,2" Style="{StaticResource Hg.StatusStrip}"
                            Visibility="{Binding SelectedAlert.IsIdnHomograph, Converter={StaticResource BoolToVis}}"
                            AutomationProperties.Name="{svc:Loc Key=IdnHomograph_AlertExplainerName}">
                        <StackPanel>
                            <TextBlock Text="{svc:Loc Key=IdnHomograph_AlertExplainerTitle}"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="{svc:Loc Key=IdnHomograph_ObservedLabel}"
                                       Style="{StaticResource Hg.FieldLabel}" Margin="0,7,0,2" />
                            <TextBlock Text="{Binding SelectedAlert.Subject}" TextWrapping="Wrap"
                                       AutomationProperties.Name="{svc:Loc Key=IdnHomograph_ObservedName}" />
                            <TextBlock Text="{svc:Loc Key=IdnHomograph_EvidenceLabel}"
                                       Style="{StaticResource Hg.FieldLabel}" Margin="0,7,0,2" />
                            <TextBlock Text="{Binding SelectedAlert.Details}" TextWrapping="Wrap"
                                       AutomationProperties.Name="{svc:Loc Key=IdnHomograph_EvidenceName}" />
                            <TextBlock Text="{svc:Loc Key=IdnHomograph_NoBlockAlert}"
                                       Style="{StaticResource Hg.HelperText}" Margin="0,7,0,0"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Row="1" Margin="0,8,0,2" Style="{StaticResource Hg.StatusStrip}"
                            Visibility="{Binding SelectedAlert.HasDgaEvidence, Converter={StaticResource BoolToVis}}"
                            AutomationProperties.Name="{svc:Loc Key=Dga_AlertExplainerName}">
                        <StackPanel>
                            <TextBlock Text="{svc:Loc Key=Dga_AlertExplainerTitle}"
                                       FontWeight="SemiBold" TextWrapping="Wrap" />
                            <TextBlock Text="{svc:Loc Key=Dga_DefaultOffAlertOnly}"
                                       Style="{StaticResource Hg.HelperText}" Margin="0,4,0,8"
                                       TextWrapping="Wrap" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="{svc:Loc Key=Dga_Label}" Style="{StaticResource Hg.FieldLabel}" Margin="0,0,12,4" />
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedAlert.DgaRegistrableLabel}" TextWrapping="Wrap"
                                           AutomationProperties.Name="{svc:Loc Key=Dga_LabelName}" />
                                <TextBlock Grid.Row="1" Text="{svc:Loc Key=Dga_Score}" Style="{StaticResource Hg.FieldLabel}" Margin="0,0,12,4" />
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedAlert.DgaScoreText}" TextWrapping="Wrap"
                                           AutomationProperties.Name="{svc:Loc Key=Dga_ScoreName}" />
                                <TextBlock Grid.Row="2" Text="{svc:Loc Key=Dga_Entropy}" Style="{StaticResource Hg.FieldLabel}" Margin="0,0,12,4" />
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedAlert.DgaEntropyText}" TextWrapping="Wrap" />
                                <TextBlock Grid.Row="3" Text="{svc:Loc Key=Dga_VowelRatio}" Style="{StaticResource Hg.FieldLabel}" Margin="0,0,12,4" />
                                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SelectedAlert.DgaVowelRatioText}" TextWrapping="Wrap" />
                                <TextBlock Grid.Row="4" Text="{svc:Loc Key=Dga_DigitRatio}" Style="{StaticResource Hg.FieldLabel}" Margin="0,0,12,4" />
                                <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding SelectedAlert.DgaDigitRatioText}" TextWrapping="Wrap" />
                                <TextBlock Grid.Row="5" Text="{svc:Loc Key=Dga_ConsonantRun}" Style="{StaticResource Hg.FieldLabel}" Margin="0,0,12,4" />
                                <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding SelectedAlert.DgaConsonantRunText}" TextWrapping="Wrap" />
                                <TextBlock Grid.Row="6" Text="{svc:Loc Key=Dga_Reason}" Style="{StaticResource Hg.FieldLabel}" Margin="0,0,12,0" />
                                <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding SelectedAlert.DgaReason}" TextWrapping="Wrap"
                                           AutomationProperties.Name="{svc:Loc Key=Dga_ReasonName}" />
                            </Grid>
                        </StackPanel>
                    </Border>
                    <DataGrid Grid.Row="2" ItemsSource="{Binding AlertTypes}" Margin="0,8,0,0"
                              AutomationProperties.Name="{svc:Loc Key=Xaml_Alert_type_settings_8e403573}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="{svc:Loc Key=Xaml_Type_4f6f5f0b}" Binding="{Binding Label}" Width="*" />
                            <DataGridCheckBoxColumn Header="{svc:Loc Key=Xaml_Surface_5e1f39da}" Binding="{Binding Surface}" Width="64" />
                            <DataGridTextColumn Header="{svc:Loc Key=Xaml_Unread_alerts_0f4f2d44}" Binding="{Binding Unread}" Width="100" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>
                </Grid>
            </TabItem>
            <TabItem Header="{svc:Loc Key=AllowlistReview_Tab}">
                <Grid Margin="4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Style="{StaticResource Hg.CommandBar}" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Text="{svc:Loc Key=AllowlistReview_Title}" Style="{StaticResource Hg.SectionTitle}" />
                            <TextBlock Text="{svc:Loc Key=AllowlistReview_Help}" Style="{StaticResource Hg.HelperText}"
                                       TextWrapping="Wrap" Margin="0,3,0,0" />
                        </StackPanel>
                    </Border>
                    <Grid Grid.Row="1">
                        <DataGrid x:Name="AllowlistReviewGrid"
                                  ItemsSource="{Binding AllowlistRecommendations}"
                                  AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                                  CanUserSortColumns="True"
                                  HeadersVisibility="Column" SelectionMode="Single"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                  AutomationProperties.Name="{svc:Loc Key=AllowlistReview_TableName}"
                                  IsVisibleChanged="OnGridVisible">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="{svc:Loc Key=AllowlistReview_Score}" Binding="{Binding Score}" Width="74" />
                                <DataGridTextColumn Header="{svc:Loc Key=AllowlistReview_Domain}" Binding="{Binding Domain}" Width="1.3*" />
                                <DataGridTextColumn Header="{svc:Loc Key=AllowlistReview_Hits}" Binding="{Binding Hits}" Width="72" />
                                <DataGridTextColumn Header="{svc:Loc Key=AllowlistReview_Process}" Binding="{Binding Process}" Width="120" />
                                <DataGridTextColumn Header="{svc:Loc Key=AllowlistReview_Parent}" Binding="{Binding ParentApp}" Width="130" />
                                <DataGridTextColumn Header="{svc:Loc Key=AllowlistReview_CdnEvidence}" Binding="{Binding CdnEvidence}" Width="1.5*" />
                                <DataGridTextColumn Header="{svc:Loc Key=AllowlistReview_TrustEvidence}" Binding="{Binding TrustEvidence}" Width="1.2*" />
                                <DataGridTemplateColumn Header="{svc:Loc Key=AllowlistReview_Action}" Width="100">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="{svc:Loc Key=AllowlistReview_Allow}"
                                                    Style="{StaticResource Hg.SuccessButton}" Padding="8,2"
                                                    Command="{Binding DataContext.AllowRecommendationCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}"
                                                    AutomationProperties.Name="{svc:Loc Key=AllowlistReview_AllowName}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                        <Border Style="{StaticResource Hg.EmptyState}"
                                Visibility="{Binding AllowlistRecommendations.Count, Converter={StaticResource EmptyStateVis}}">
                            <StackPanel>
                                <TextBlock Text="{svc:Loc Key=AllowlistReview_EmptyTitle}"
                                           Style="{StaticResource Hg.SectionTitle}" HorizontalAlignment="Center" Margin="0,0,0,4" />
                                <TextBlock Text="{svc:Loc Key=AllowlistReview_EmptyHelp}" Style="{StaticResource Hg.EmptyText}" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>
        </TabControl>

        <TextBlock Grid.Row="2" Margin="2,6,0,0"
                   Text="{Binding StatusText}"
                   Style="{StaticResource Hg.DimText}"
                   AutomationProperties.LiveSetting="Polite" />
    </Grid>
</views:MajorTabPage>
