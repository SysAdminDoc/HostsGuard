                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="{svc:Loc Key=RuleAnalysis_Remediation}" Binding="{Binding Remediation}" Width="116" />
