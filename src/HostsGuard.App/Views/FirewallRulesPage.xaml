                            <TextBlock Text="{svc:Loc Key=RuleAnalysis_Empty}" Style="{StaticResource Hg.EmptyText}" />
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>
        </Expander>

        <TextBlock Grid.Row="5" Margin="2,6,0,0"
                   Text="{Binding StatusText}"
                   Style="{StaticResource Hg.DimText}"
                   AutomationProperties.LiveSetting="Polite" />
    </Grid>
</views:MajorTabPage>
