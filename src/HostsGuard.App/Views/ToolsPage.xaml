<views:MajorTabPage x:Class="HostsGuard.App.Views.ToolsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:svc="clr-namespace:HostsGuard.App.Services"
             xmlns:vm="clr-namespace:HostsGuard.App.ViewModels"
             xmlns:views="clr-namespace:HostsGuard.App.Views"
             d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
             mc:Ignorable="d">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/HostsGuard.App;component/Views/MajorTabResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
        <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <DataTemplate x:Key="ToolsWrappedContent">
            <TextBlock Text="{Binding}" TextWrapping="Wrap" TextAlignment="Center" />
        </DataTemplate>
        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="ContentTemplate" Value="{StaticResource ToolsWrappedContent}" />
        </Style>
        <Style TargetType="CheckBox" BasedOn="{StaticResource {x:Type CheckBox}}">
            <Setter Property="ContentTemplate" Value="{StaticResource ToolsWrappedContent}" />
        </Style>
        <Style TargetType="ComboBoxItem" BasedOn="{StaticResource {x:Type ComboBoxItem}}">
            <Setter Property="ContentTemplate" Value="{StaticResource ToolsWrappedContent}" />
        </Style>
        </ResourceDictionary>
    </UserControl.Resources>
    <Grid x:Name="ToolsSurface" Margin="8" DataContext="{Binding Tools}">
        <TabControl x:Name="ToolsTabs"
                    Style="{StaticResource Hg.PrimaryTabs}"
                    ItemContainerStyle="{StaticResource Hg.SecondaryTabItem}"
                    AutomationProperties.Name="{svc:Loc Key=ToolsNav_Name}">
            <TabItem Header="{svc:Loc Key=ToolsNav_Overview}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="4">

            <!-- Service-health glance (NET-186) -->
            <Border Style="{StaticResource Hg.Card}" Margin="0,0,0,10">
                <StackPanel>
                    <DockPanel LastChildFill="False">
                        <TextBlock DockPanel.Dock="Left"
                                   Text="{svc:Loc Key=Health_Title}"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,4" />
                        <Button DockPanel.Dock="Right"
                                Content="{svc:Loc Key=Xaml_Refresh_56e3badc}"
                                Command="{Binding LoadHealthCommand}"
                                Padding="10,2" />
                    </DockPanel>
                    <TextBlock Text="{svc:Loc Key=Health_Help}"
                               Style="{StaticResource Hg.HelperText}"
                               Margin="0,0,0,8"
                               TextWrapping="Wrap" />
                    <DataGrid ItemsSource="{Binding HealthRows}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              HeadersVisibility="Column"
                              MaxHeight="230"
                              AutomationProperties.Name="{svc:Loc Key=Health_TableName}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="{svc:Loc Key=Health_ColAspect}" Binding="{Binding Aspect}" Width="1.2*" />
                            <DataGridTextColumn Header="{svc:Loc Key=Health_ColState}" Binding="{Binding State}" Width="110">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{DynamicResource Hg.Green}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Healthy}" Value="False">
                                                <Setter Property="Foreground" Value="{DynamicResource Hg.Peach}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="{svc:Loc Key=Health_ColDetail}" Binding="{Binding Detail}" Width="2.4*" />
                        </DataGrid.Columns>
                    </DataGrid>
                    <Border Style="{StaticResource Hg.EmptyState}"
                            Margin="0,8,0,0"
                            Visibility="{Binding HealthRows.Count, Converter={StaticResource EmptyStateVis}}">
                        <TextBlock Text="{svc:Loc Key=Health_Empty}"
                                   Style="{StaticResource Hg.EmptyText}" />
                    </Border>
                    <Border Style="{StaticResource Hg.StatusStrip}" Margin="0,8,0,0">
                        <TextBlock Text="{Binding HealthStatusText}"
                                   Style="{StaticResource Hg.SubText}"
                                   TextWrapping="Wrap"
                                   AutomationProperties.LiveSetting="Polite" />
                    </Border>
                </StackPanel>
            </Border>

            <!-- Proxy/PAC tamper baseline -->
            <Border Style="{StaticResource Hg.Card}" Margin="0,0,0,10">
                <StackPanel>
                    <DockPanel LastChildFill="False">
                        <TextBlock DockPanel.Dock="Left"
                                   Text="{svc:Loc Key=Proxy_Title}"
                                   FontWeight="SemiBold" />
                        <Button DockPanel.Dock="Right"
                                Content="{svc:Loc Key=Proxy_Accept}"
                                Command="{Binding AcceptProxyBaselineCommand}"
                                AutomationProperties.Name="{svc:Loc Key=Proxy_AcceptName}"
                                ToolTip="{svc:Loc Key=Proxy_AcceptTip}"
                                Margin="8,0,0,0"
                                Padding="10,2" />
                        <Button DockPanel.Dock="Right"
                                Content="{svc:Loc Key=Proxy_Check}"
                                Command="{Binding InspectProxyBaselineCommand}"
                                AutomationProperties.Name="{svc:Loc Key=Proxy_CheckName}"
                                Padding="10,2" />
                    </DockPanel>
                    <TextBlock Text="{svc:Loc Key=Proxy_Help}"
                               Style="{StaticResource Hg.HelperText}"
                               Margin="0,4,0,8"
                               TextWrapping="Wrap" />
                    <DataGrid ItemsSource="{Binding ProxyBaselineRows}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              HeadersVisibility="Column"
                              MaxHeight="190"
                              AutomationProperties.Name="{svc:Loc Key=Proxy_TableName}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="{svc:Loc Key=Proxy_ColScope}" Binding="{Binding Scope}" Width="88" />
                            <DataGridTextColumn Header="{svc:Loc Key=Proxy_ColIdentity}" Binding="{Binding Identity}" Width="1.1*" />
                            <DataGridTextColumn Header="{svc:Loc Key=Proxy_ColSetting}" Binding="{Binding Setting}" Width="1.1*" />
                            <DataGridTextColumn Header="{svc:Loc Key=Proxy_ColState}" Binding="{Binding State}" Width="82" />
                            <DataGridTextColumn Header="{svc:Loc Key=Proxy_ColBaseline}" Binding="{Binding Baseline}" Width="1.4*" />
                            <DataGridTextColumn Header="{svc:Loc Key=Proxy_ColCurrent}" Binding="{Binding Current}" Width="1.4*" />
                        </DataGrid.Columns>
                    </DataGrid>
                    <Border Style="{StaticResource Hg.EmptyState}"
                            Margin="0,8,0,0"
                            Visibility="{Binding ProxyBaselineRows.Count, Converter={StaticResource EmptyStateVis}}">
                        <TextBlock Text="{svc:Loc Key=Proxy_Empty}" Style="{StaticResource Hg.EmptyText}" />
                    </Border>
                    <Border Style="{StaticResource Hg.StatusStrip}" Margin="0,8,0,0">
                        <TextBlock Text="{Binding ProxyBaselineStatus}"
                                   Style="{StaticResource Hg.SubText}"
                                   TextWrapping="Wrap"
                                   AutomationProperties.LiveSetting="Polite" />
                    </Border>
                </StackPanel>
            </Border>

            <!-- SHA-256-verified self-update (NET-187) -->
            <Border Style="{StaticResource Hg.Card}" Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="{svc:Loc Key=Update_Title}" FontWeight="SemiBold" Margin="0,0,0,4" />
                    <TextBlock Text="{svc:Loc Key=Update_Help}"
                               Style="{StaticResource Hg.HelperText}"
                               Margin="0,0,0,8"
                               TextWrapping="Wrap" />
                    <WrapPanel>
                        <Button Content="{svc:Loc Key=Update_Check}"
                                Command="{Binding CheckUpdateCommand}"
                                Margin="0,0,8,8" />
                        <Button Style="{StaticResource Hg.AccentButton}"
                                Command="{Binding StageUpdateCommand}"
                                ToolTip="{svc:Loc Key=Update_StageTip}"
                                Margin="0,0,8,8">
                            <TextBlock Text="{svc:Loc Key=Update_Stage}" TextWrapping="Wrap" TextAlignment="Center" />
                        </Button>
                    </WrapPanel>
                    <Border Style="{StaticResource Hg.StatusStrip}">
                        <TextBlock Text="{Binding UpdateStatusText}"
                                   Style="{StaticResource Hg.SubText}"
                                   TextWrapping="Wrap"
                                   AutomationProperties.LiveSetting="Polite" />
                    </Border>
                </StackPanel>
            </Border>

            <!-- Settings lock (NET-079) -->
            <Border Style="{StaticResource Hg.Card}" Margin="0,0,0,10">
                <StackPanel>
                    <DockPanel LastChildFill="False">
                        <TextBlock DockPanel.Dock="Left" Text="{svc:Loc Key=Xaml_Settings_lock_424ef42a}" FontWeight="SemiBold" />
                        <TextBlock DockPanel.Dock="Right" Text="{Binding LockStatus}" Style="{StaticResource Hg.DimText}" />
                    </DockPanel>
                    <TextBlock Text="{svc:Loc Key=Xaml_When_locked_changing_filtering_mode_firewall_234ed002}"
                               Style="{StaticResource Hg.DimText}" TextWrapping="Wrap" Margin="0,4,0,8" />
                    <TextBlock Text="{svc:Loc Key=Xaml_Lock_password_4cd91ac2}" Style="{StaticResource Hg.FieldLabel}" />
                    <DockPanel LastChildFill="True">
                        <Button DockPanel.Dock="Right" Content="{svc:Loc Key=Xaml_Refresh_56e3badc}" Command="{Binding LoadLockStateCommand}" Margin="6,0,0,0" Padding="10,2" />
                        <Button DockPanel.Dock="Right" Content="{svc:Loc Key=Xaml_Protect_hosts_file_41db1809}" Command="{Binding ProtectHostsCommand}" Margin="6,0,0,0" Padding="10,2"
                                ToolTip="{svc:Loc Key=Xaml_Enforce_a_SYSTEM_Admins_only_DACL_680f041b}" />
                        <PasswordBox x:Name="LockPasswordBox" VerticalAlignment="Center"
                                     Style="{StaticResource Hg.LockPasswordBox}"
                                     svc:PasswordBoxHelper.Watermark="{svc:Loc Key=Lock_PasswordWatermark}"
                                     AutomationProperties.Name="{svc:Loc Key=Xaml_Settings_lock_password_c745c4ae}" />
                    </DockPanel>
                    <DockPanel LastChildFill="False" Margin="0,8,0,0">
                        <Button DockPanel.Dock="Left" Content="{svc:Loc Key=Xaml_Arm_lock_82cc9364}" Command="{Binding EnableLockCommand}" Margin="0,0,6,0" Padding="10,2"
                                CommandParameter="{Binding ElementName=LockPasswordBox}" Click="OnLockPasswordSync"
                                ToolTip="{svc:Loc Key=Xaml_Set_the_password_that_protects_filtering_1de59e66}" />
                        <Button DockPanel.Dock="Left" Content="{svc:Loc Key=Xaml_Disarm_f26d27b0}" Command="{Binding DisableLockCommand}" Margin="0,0,6,0" Padding="10,2"
                                Click="OnLockPasswordSync"
                                ToolTip="{svc:Loc Key=Xaml_Remove_the_settings_lock_after_entering_3792232c}" />
                        <Button DockPanel.Dock="Left" Content="{svc:Loc Key=Xaml_Unlock_1526a17e}" Command="{Binding UnlockCommand}" Margin="0,0,6,0" Padding="10,2"
                                Click="OnLockPasswordSync"
                                ToolTip="{svc:Loc Key=Xaml_Temporarily_unlock_protected_actions_for_the_5440dfe8}" />
                        <TextBox DockPanel.Dock="Left" Width="46" VerticalAlignment="Center"
                                 Text="{Binding UnlockMinutes, UpdateSourceTrigger=PropertyChanged}"
                                 AutomationProperties.Name="{svc:Loc Key=Xaml_Unlock_minutes_12cfd14d}" ToolTip="{svc:Loc Key=Xaml_Timed_unlock_window_in_minutes_0caa0a13}" />
                        <TextBlock DockPanel.Dock="Left" Text="{svc:Loc Key=Xaml_min_b6c935d4}" Style="{StaticResource Hg.DimText}"
                                   VerticalAlignment="Center" Margin="5,0,0,0" />
                    </DockPanel>
                </StackPanel>
            </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="{svc:Loc Key=ToolsNav_Network}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="4">
            <Border Style="{StaticResource Hg.Card}" Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="{svc:Loc Key=Xaml_DNS_3ddc21b1}" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <TextBlock Text="{svc:Loc Key=Xaml_Flush_resolver_state_switch_Windows_DNS_dbece2f0}"
                               Style="{StaticResource Hg.HelperText}" Margin="0,0,0,10" />
                    <DockPanel LastChildFill="False">
                        <Button DockPanel.Dock="Left" Content="{svc:Loc Key=Xaml_Flush_DNS_cache_58856a23}"
                                Command="{Binding FlushDnsCommand}" Margin="0,0,10,0" />
                        <ComboBox DockPanel.Dock="Left" Width="180" Margin="0,0,10,0"
                                  ItemsSource="{x:Static vm:ToolsViewModel.ResolverNames}"
                                  ItemTemplate="{StaticResource ToolsWrappedContent}"
                                  AutomationProperties.Name="{svc:Loc Key=Xaml_DNS_resolver_preset_df5e62bd}"
                                  SelectedItem="{Binding SelectedResolver}" />
                        <Button DockPanel.Dock="Left" Content="{svc:Loc Key=Xaml_Apply_resolver_2382d7f6}"
                                Command="{Binding ApplyResolverCommand}" />
                    </DockPanel>
                    <DockPanel Margin="0,10,0,0">
                        <Button DockPanel.Dock="Right" Content="{svc:Loc Key=Xaml_Refresh_56e3badc}"
                                Command="{Binding LoadDnsAdaptersCommand}"
                                AutomationProperties.Name="{svc:Loc Key=Xaml_Refresh_56e3badc}"
                                Padding="10,2" />
                        <TextBlock Text="{svc:Loc Key=DnsAdapters_Help}"
                                   Style="{StaticResource Hg.HelperText}"
                                   TextWrapping="Wrap" VerticalAlignment="Center" />
                    </DockPanel>
                    <ItemsControl ItemsSource="{Binding DnsAdapters}" Margin="0,6,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsSelected}"
                                          Content="{Binding Label}"
                                          AutomationProperties.Name="{Binding Label}"
                                          Margin="0,3,0,0" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Border Style="{StaticResource Hg.StatusStrip}" Margin="0,10,0,0">
                        <StackPanel>
                            <DockPanel LastChildFill="True">
                                <Button DockPanel.Dock="Right"
                                        Content="{svc:Loc Key=ResolverHealth_Run}"
                                        Command="{Binding RunResolverHealthCommand}"
                                        AutomationProperties.Name="{svc:Loc Key=ResolverHealth_RunName}"
                                        ToolTip="{svc:Loc Key=ResolverHealth_RunTip}"
                                        Margin="8,0,0,0"
                                        Padding="10,2" />
                                <Button DockPanel.Dock="Right"
                                        Content="{svc:Loc Key=ResolverHealth_Load}"
                                        Command="{Binding LoadResolverHealthCommand}"
                                        AutomationProperties.Name="{svc:Loc Key=ResolverHealth_LoadName}"
                                        ToolTip="{svc:Loc Key=ResolverHealth_LoadTip}"
                                        Margin="8,0,0,0"
                                        Padding="10,2" />
                                <StackPanel>
                                    <TextBlock Text="{svc:Loc Key=ResolverHealth_Title}" FontWeight="SemiBold" />
                                    <TextBlock Text="{svc:Loc Key=ResolverHealth_Help}"
                                               Style="{StaticResource Hg.HelperText}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </DockPanel>
                            <TextBox Text="{Binding ResolverHealthHost, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource Hg.HintBox}"
                                     Tag="{svc:Loc Key=ResolverHealth_HostHint}"
                                     AutomationProperties.Name="{svc:Loc Key=ResolverHealth_HostName}"
                                     ToolTip="{svc:Loc Key=ResolverHealth_HostTip}"
                                     Margin="0,8,0,6" />
                            <DockPanel LastChildFill="False" Margin="0,0,0,6">
                                <CheckBox DockPanel.Dock="Left"
                                          IsChecked="{Binding ResolverHealthScheduleEnabled}"
                                          Content="{svc:Loc Key=ResolverHealth_ScheduleEnabled}"
                                          AutomationProperties.Name="{svc:Loc Key=ResolverHealth_ScheduleEnabledName}"
                                          VerticalAlignment="Center"
                                          Margin="0,0,8,0" />
                                <TextBox DockPanel.Dock="Left"
                                         Width="58"
                                         Text="{Binding ResolverHealthScheduleIntervalMinutes, UpdateSourceTrigger=PropertyChanged}"
                                         AutomationProperties.Name="{svc:Loc Key=ResolverHealth_ScheduleIntervalName}"
                                         ToolTip="{svc:Loc Key=ResolverHealth_ScheduleIntervalTip}"
                                         VerticalAlignment="Center" />
                                <TextBlock DockPanel.Dock="Left"
                                           Text="{svc:Loc Key=ResolverHealth_Minutes}"
                                           Style="{StaticResource Hg.DimText}"
                                           VerticalAlignment="Center"
                                           Margin="5,0,8,0" />
                                <Button DockPanel.Dock="Left"
                                        Content="{svc:Loc Key=ResolverHealth_ApplySchedule}"
                                        Command="{Binding ApplyResolverHealthScheduleCommand}"
                                        AutomationProperties.Name="{svc:Loc Key=ResolverHealth_ApplyScheduleName}"
                                        ToolTip="{svc:Loc Key=ResolverHealth_ApplyScheduleTip}"
                                        Padding="10,2" />
                            </DockPanel>
                            <DataGrid ItemsSource="{Binding ResolverHealthEntries}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      HeadersVisibility="Column"
                                      MaxHeight="190"
                                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                      AutomationProperties.Name="{svc:Loc Key=ResolverHealth_TableName}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="{svc:Loc Key=ResolverHealth_Adapter}" Binding="{Binding Adapter}" Width="150" />
                                    <DataGridTextColumn Header="{svc:Loc Key=ResolverHealth_Endpoint}" Binding="{Binding Endpoint}" Width="145" />
                                    <DataGridTextColumn Header="{svc:Loc Key=ResolverHealth_Protocol}" Binding="{Binding Protocol}" Width="76" />
                                    <DataGridTextColumn Header="{svc:Loc Key=ResolverHealth_A}" Binding="{Binding AResult}" Width="96" />
                                    <DataGridTextColumn Header="{svc:Loc Key=ResolverHealth_Aaaa}" Binding="{Binding AaaaResult}" Width="96" />
                                    <DataGridTextColumn Header="{svc:Loc Key=ResolverHealth_Rtt}" Binding="{Binding RttText}" Width="78" />
                                    <DataGridTextColumn Header="{svc:Loc Key=ResolverHealth_Tls}" Binding="{Binding TlsStatus}" Width="110" />
                                    <DataGridTextColumn Header="{svc:Loc Key=ResolverHealth_Certificate}" Binding="{Binding CertificateStatus}" Width="120" />
                                    <DataGridTextColumn Header="{svc:Loc Key=ResolverHealth_Result}" Binding="{Binding ResultText}" Width="220" />
                                </DataGrid.Columns>
                            </DataGrid>
                            <TextBlock Text="{Binding ResolverHealthStatusText}"
                                       Style="{StaticResource Hg.DimText}"
                                       TextWrapping="Wrap"
                                       Margin="0,6,0,0"
                                       AutomationProperties.Name="{Binding ResolverHealthStatusText}"
                                       AutomationProperties.LiveSetting="Polite" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource Hg.StatusStrip}" Margin="0,10,0,0">
                        <StackPanel>
                            <DockPanel LastChildFill="True">
                                <Button DockPanel.Dock="Right"
                                        Content="{svc:Loc Key=EncryptedResolver_Accept}"
                                        Command="{Binding AcceptEncryptedResolverBaselineCommand}"
                                        AutomationProperties.Name="{svc:Loc Key=EncryptedResolver_AcceptName}"
                                        ToolTip="{svc:Loc Key=EncryptedResolver_AcceptTip}"
                                        Margin="8,0,0,0"
                                        Padding="10,2" />
                                <Button DockPanel.Dock="Right"
                                        Content="{svc:Loc Key=EncryptedResolver_Run}"
                                        Command="{Binding RunEncryptedResolverDiscoveryCommand}"
                                        AutomationProperties.Name="{svc:Loc Key=EncryptedResolver_RunName}"
                                        ToolTip="{svc:Loc Key=EncryptedResolver_RunTip}"
                                        Margin="8,0,0,0"
                                        Padding="10,2" />
                                <Button DockPanel.Dock="Right"
                                        Content="{svc:Loc Key=EncryptedResolver_Load}"
                                        Command="{Binding LoadEncryptedResolverDiscoveryCommand}"
                                        AutomationProperties.Name="{svc:Loc Key=EncryptedResolver_LoadName}"
                                        ToolTip="{svc:Loc Key=EncryptedResolver_LoadTip}"
                                        Margin="8,0,0,0"
                                        Padding="10,2" />
                                <StackPanel>
                                    <TextBlock Text="{svc:Loc Key=EncryptedResolver_Title}" FontWeight="SemiBold" />
                                    <TextBlock Text="{svc:Loc Key=EncryptedResolver_Help}"
                                               Style="{StaticResource Hg.HelperText}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </DockPanel>
                            <DataGrid ItemsSource="{Binding EncryptedResolverDiscoveryEntries}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      HeadersVisibility="Column"
                                      MaxHeight="190"
                                      Margin="0,8,0,0"
                                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                      AutomationProperties.Name="{svc:Loc Key=EncryptedResolver_TableName}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="{svc:Loc Key=EncryptedResolver_Adapter}" Binding="{Binding Adapter}" Width="130" />
                                    <DataGridTextColumn Header="{svc:Loc Key=EncryptedResolver_Source}" Binding="{Binding Source}" Width="66" />
                                    <DataGridTextColumn Header="{svc:Loc Key=EncryptedResolver_Resolver}" Binding="{Binding Resolver}" Width="120" />
                                    <DataGridTextColumn Header="{svc:Loc Key=EncryptedResolver_Outcome}" Binding="{Binding Outcome}" Width="92" />
                                    <DataGridTextColumn Header="{svc:Loc Key=EncryptedResolver_Target}" Binding="{Binding Target}" Width="220" />
                                    <DataGridTextColumn Header="{svc:Loc Key=EncryptedResolver_Protocols}" Binding="{Binding Protocols}" Width="100" />
                                    <DataGridTextColumn Header="{svc:Loc Key=EncryptedResolver_Addresses}" Binding="{Binding Addresses}" Width="145" />
                                    <DataGridTextColumn Header="{svc:Loc Key=EncryptedResolver_Drift}" Binding="{Binding Drift}" Width="86" />
                                    <DataGridTextColumn Header="{svc:Loc Key=EncryptedResolver_Detail}" Binding="{Binding Detail}" Width="240" />
                                </DataGrid.Columns>
                            </DataGrid>
                            <TextBlock Text="{Binding EncryptedResolverDiscoveryStatusText}"
                                       Style="{StaticResource Hg.DimText}"
                                       TextWrapping="Wrap"
                                       Margin="0,6,0,0"
                                       AutomationProperties.Name="{Binding EncryptedResolverDiscoveryStatusText}"
                                       AutomationProperties.LiveSetting="Polite" />
                        </StackPanel>
                    </Border>
                    <DockPanel Margin="0,10,0,0">
                        <Button DockPanel.Dock="Right" Content="{svc:Loc Key=Xaml_Inspect_18ca87af}"
                                Command="{Binding InspectCommand}" Margin="8,0,0,0"
                                ToolTip="{svc:Loc Key=Xaml_Enter_a_domain_to_resolve_and_bdf20a48}" />
                        <TextBox Text="{Binding InspectDomain, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource Hg.HintBox}"
                                 Tag="{svc:Loc Key=Xaml_InspectDomainHint}"
                                 AutomationProperties.Name="{svc:Loc Key=Xaml_Domain_to_inspect_ea69d8b4}"
                                 ToolTip="{svc:Loc Key=Xaml_Domain_to_resolve_and_check_block_be2f0bc0}" />
                    </DockPanel>
                    <TextBlock Text="{Binding InspectResult}" Style="{StaticResource Hg.SubText}" Margin="0,6,0,0"
                               TextWrapping="Wrap" />
                    <TextBlock Text="{svc:Loc Key=ServiceBinding_Title}" FontWeight="SemiBold" Margin="0,10,0,0" />
                    <TextBlock Text="{Binding ServiceBindingStatusText}"
                               Style="{StaticResource Hg.HelperText}"
                               TextWrapping="Wrap"
                               Margin="0,2,0,4"
                               AutomationProperties.LiveSetting="Polite" />
                    <DataGrid ItemsSource="{Binding ServiceBindings}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              HeadersVisibility="Column"
                              MaxHeight="154"
                              ScrollViewer.HorizontalScrollBarVisibility="Auto"
                              AutomationProperties.Name="{svc:Loc Key=ServiceBinding_TableName}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="{svc:Loc Key=ServiceBinding_Owner}" Binding="{Binding OwnerName}" Width="180" />
                            <DataGridTextColumn Header="{svc:Loc Key=ServiceBinding_Type}" Binding="{Binding DnsType}" Width="68" />
                            <DataGridTextColumn Header="{svc:Loc Key=ServiceBinding_Priority}" Binding="{Binding Priority}" Width="72" />
                            <DataGridTextColumn Header="{svc:Loc Key=ServiceBinding_Target}" Binding="{Binding Target}" Width="180" />
                            <DataGridTextColumn Header="{svc:Loc Key=ServiceBinding_Mode}" Binding="{Binding ModeText}" Width="76" />
                            <DataGridTextColumn Header="{svc:Loc Key=ServiceBinding_Parameters}" Binding="{Binding ParametersText}" Width="320" />
                            <DataGridTextColumn Header="{svc:Loc Key=ServiceBinding_Ech}" Binding="{Binding EchText}" Width="104" />
                            <DataGridTextColumn Header="{svc:Loc Key=ServiceBinding_Ttl}" Binding="{Binding TtlSeconds}" Width="68" />
                            <DataGridTextColumn Header="{svc:Loc Key=ServiceBinding_Health}" Binding="{Binding HealthText}" Width="240" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <Border Style="{StaticResource Hg.StatusStrip}" Margin="0,10,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <DockPanel Grid.Row="0" LastChildFill="True">
                                <Button DockPanel.Dock="Right"
                                        Content="{svc:Loc Key=DnsCache_FlushSelected}"
                                        Command="{Binding FlushDnsCacheEntryCommand}"
                                        AutomationProperties.Name="{svc:Loc Key=DnsCache_FlushSelectedName}"
                                        ToolTip="{svc:Loc Key=DnsCache_FlushSelectedTip}"
                                        Padding="10,2" />
                                <Button DockPanel.Dock="Right"
                                        Content="{svc:Loc Key=DnsCache_Load}"
                                        Command="{Binding LoadDnsCacheCommand}"
                                        AutomationProperties.Name="{svc:Loc Key=DnsCache_LoadName}"
                                        ToolTip="{svc:Loc Key=DnsCache_LoadTip}"
                                        Margin="0,0,8,0"
                                        Padding="10,2" />
                                <StackPanel>
