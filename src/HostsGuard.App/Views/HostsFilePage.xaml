<views:MajorTabPage x:Class="HostsGuard.App.Views.HostsFilePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:svc="clr-namespace:HostsGuard.App.Services"
             xmlns:vm="clr-namespace:HostsGuard.App.ViewModels"
             xmlns:views="clr-namespace:HostsGuard.App.Views"
             d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
             mc:Ignorable="d">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/HostsGuard.App;component/Views/MajorTabResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <TabControl x:Name="HostsTabs" Margin="0,4,0,0"
                Style="{StaticResource Hg.PrimaryTabs}"
                ItemContainerStyle="{StaticResource Hg.SecondaryTabItem}">
        <TabItem Header="{svc:Loc Key=Tab_ManagedDomains, Default=Managed Domains}">
            <Grid Margin="4" DataContext="{Binding Hosts}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource Hg.CommandBar}" Margin="0,0,0,8">
                <DockPanel>
                    <Button DockPanel.Dock="Right" Content="{svc:Loc Key=Xaml_Refresh_56e3badc}"
                            Command="{Binding RefreshCommand}" Margin="8,0,0,0" />
                    <Button DockPanel.Dock="Right" Content="{svc:Loc Key=Xaml_AI_Categorize_27b3527f}"
                            Command="{Binding AiCategorizeCommand}" Margin="8,0,0,0"
                            ToolTip="{svc:Loc Key=Xaml_Have_DeepSeek_categorize_every_hosts_file_3b37a22a}" />
                    <Button DockPanel.Dock="Right" Content="{svc:Loc Key=Xaml_Block_82dd2cdf}"
                            Style="{StaticResource Hg.AccentButton}"
                            Command="{Binding BlockCommand}" Margin="8,0,0,0"
                            ToolTip="{svc:Loc Key=Xaml_Enter_a_domain_then_add_it_67b6f1e2}" />
                    <TextBox DockPanel.Dock="Right" Width="220" Margin="8,0,0,0"
                             Text="{Binding NewDomain, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource Hg.HintBox}"
                             Tag="{svc:Loc Key=Xaml_Domain_to_block_31b7bab9}"
                             AutomationProperties.Name="{svc:Loc Key=Xaml_Domain_to_block_31b7bab9}"
                             ToolTip="{svc:Loc Key=Xaml_Domain_to_block_31b7bab9}" />
                    <ComboBox DockPanel.Dock="Right" Width="120" Margin="8,0,0,0"
                              ItemsSource="{x:Static vm:HostsViewModel.StatusFilters}"
                              AutomationProperties.Name="{svc:Loc Key=Xaml_Managed_domain_status_filter_c1837b19}"
                              SelectedItem="{Binding StatusFilter}" />
                    <TextBox Text="{Binding Filter, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource Hg.HintBox}"
                             Tag="{svc:Loc Key=Xaml_SearchManagedDomainsHint}"
                             AutomationProperties.Name="{svc:Loc Key=Xaml_Search_managed_domains_f5421c94}"
                             ToolTip="{svc:Loc Key=Xaml_Filters_as_you_type_supports_a2c98d15}" />
                </DockPanel>
                </Border>

                <DataGrid Grid.Row="1" x:Name="DomainsGrid" ItemsSource="{Binding Domains}"
                          AutomationProperties.Name="{svc:Loc Key=Xaml_Managed_domains_a7b9edcb}"
                          IsVisibleChanged="OnGridVisible">
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                            <Setter Property="ToolTip" Value="{Binding Reason}" />
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="{svc:Loc Key=Xaml_Block_selected_d487fbba}"
                                      Command="{Binding PlacementTarget.DataContext.BlockSelectedCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      CommandParameter="{Binding PlacementTarget.SelectedItems, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                            <MenuItem Header="{svc:Loc Key=Xaml_Allow_selected_7bc4fcf5}"
                                      Command="{Binding PlacementTarget.DataContext.AllowSelectedCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      CommandParameter="{Binding PlacementTarget.SelectedItems, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                            <MenuItem Header="{svc:Loc Key=Xaml_Remove_selected_f38b8091}"
                                      Command="{Binding PlacementTarget.DataContext.RemoveSelectedCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      CommandParameter="{Binding PlacementTarget.SelectedItems, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                            <Separator />
                            <MenuItem Header="{svc:Loc Key=Xaml_Block_root_6c8978ac}"
                                      Command="{Binding PlacementTarget.DataContext.BlockRootCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      CommandParameter="{Binding PlacementTarget.SelectedItem.Domain, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                            <Separator />
                            <MenuItem Header="{svc:Loc Key=Xaml_Research_online_0fdb1e04}">
                                <MenuItem Header="{svc:Loc Key=Xaml_Google_2b681c0a}"
                                          Command="{Binding PlacementTarget.DataContext.ResearchGoogleCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                          CommandParameter="{Binding PlacementTarget.SelectedItem.Domain, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                <MenuItem Header="{svc:Loc Key=Xaml_VirusTotal_d38e68d0}"
                                          Command="{Binding PlacementTarget.DataContext.ResearchVirusTotalCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                          CommandParameter="{Binding PlacementTarget.SelectedItem.Domain, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                <MenuItem Header="{svc:Loc Key=Xaml_who_is_42562da6}"
                                          Command="{Binding PlacementTarget.DataContext.ResearchWhoisCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                          CommandParameter="{Binding PlacementTarget.SelectedItem.Domain, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                            </MenuItem>
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="{svc:Loc Key=Xaml_Domain_9b10914d}" Binding="{Binding Domain}" Width="2*" />
                        <DataGridTextColumn Header="{svc:Loc Key=Xaml_Status_bae7d5be}" Binding="{Binding Status}" Width="110" />
                        <DataGridTextColumn Header="{svc:Loc Key=Xaml_Category_a3c686e7}" Binding="{Binding Category}" Width="140" />
                        <DataGridTextColumn Header="{svc:Loc Key=Xaml_Source_6da13add}" Binding="{Binding Source}" Width="110" />
                        <DataGridTextColumn Header="{svc:Loc Key=Xaml_Reason_f219cc06}" Binding="{Binding Reason}" Width="2*" />
                        <DataGridTextColumn Header="{svc:Loc Key=Xaml_Hits_a6179b4c}" Binding="{Binding Hits}" Width="70" />
                        <DataGridTemplateColumn Header="{svc:Loc Key=Xaml_Actions_c3cd636a}" Width="170">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="{svc:Loc Key=Xaml_Allow_3ad0e369}" Padding="8,2" Margin="0,0,6,0"
                                                Command="{Binding DataContext.AllowCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding Domain}" />
                                        <Button Content="{svc:Loc Key=Xaml_Remove_e963907d}" Padding="8,2"
                                                Style="{StaticResource Hg.DangerButton}"
                                                Command="{Binding DataContext.UnblockCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding Domain}" />
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <Border Grid.Row="1"
                        Style="{StaticResource Hg.EmptyState}"
                        Visibility="{Binding Domains.Count, Converter={StaticResource EmptyStateVis}}">
                    <StackPanel>
                        <TextBlock Text="{svc:Loc Key=Xaml_No_managed_domains_90d3bbe6}"
                                   Style="{StaticResource Hg.SectionTitle}"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,4" />
                        <TextBlock Text="{svc:Loc Key=Xaml_Add_a_domain_above_or_import_5ac9415e}"
                                   Style="{StaticResource Hg.EmptyText}" />
                    </StackPanel>
                </Border>

                <TextBlock Grid.Row="2" Margin="2,6,0,0"
                           Text="{Binding StatusText}"
                           Style="{StaticResource Hg.DimText}"
                           AutomationProperties.LiveSetting="Polite" />
            </Grid>
        </TabItem>

        <TabItem Header="{svc:Loc Key=HostsRedirect_Tab, Default=Local redirects}">
            <Grid Margin="4" DataContext="{Binding Hosts}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource Hg.Card}" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="{svc:Loc Key=HostsRedirect_Title, Default=Intentional local redirects}"
                                   Style="{StaticResource Hg.SectionTitle}" />
                        <TextBlock Text="{svc:Loc Key=HostsRedirect_Help, Default=Pin a domain to a unicast IPv4 or IPv6 address. HostsGuard writes and tracks the exact mapping so it is not mistaken for hosts-file hijacking.}"
                                   Style="{StaticResource Hg.HelperText}" Margin="0,3,0,0"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Style="{StaticResource Hg.CommandBar}" Margin="0,0,0,8">
                    <DockPanel>
                        <Button x:Name="PinRedirectButton" DockPanel.Dock="Right"
                                Content="{svc:Loc Key=HostsRedirect_Pin, Default=Pin domain}"
                                Style="{StaticResource Hg.AccentButton}"
                                Command="{Binding PinRedirectCommand}" Margin="8,0,0,0"
                                AutomationProperties.Name="{svc:Loc Key=HostsRedirect_Pin, Default=Pin domain}" />
                        <TextBox x:Name="RedirectIpInput" DockPanel.Dock="Right" Width="190" Margin="8,0,0,0"
                                 Text="{Binding NewRedirectIp, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource Hg.HintBox}"
                                 Tag="{svc:Loc Key=HostsRedirect_IpHint, Default=IP address}"
                                 AutomationProperties.Name="{svc:Loc Key=HostsRedirect_IpHint, Default=IP address}" />
                        <TextBox x:Name="RedirectDomainInput" Text="{Binding NewRedirectDomain, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource Hg.HintBox}"
                                 Tag="{svc:Loc Key=HostsRedirect_DomainHint, Default=Domain to pin}"
                                 AutomationProperties.Name="{svc:Loc Key=HostsRedirect_DomainHint, Default=Domain to pin}" />
                    </DockPanel>
                </Border>

                <DataGrid Grid.Row="2" x:Name="HostsRedirectsGrid" ItemsSource="{Binding Redirects}"
                          AutomationProperties.Name="{svc:Loc Key=HostsRedirect_GridName, Default=Managed local redirects}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="{svc:Loc Key=HostsRedirect_Domain, Default=Domain}"
                                            Binding="{Binding Domain}" Width="2*" />
                        <DataGridTextColumn Header="{svc:Loc Key=HostsRedirect_Ip, Default=IP address}"
                                            Binding="{Binding Ip}" Width="*" />
                        <DataGridTextColumn Header="{svc:Loc Key=HostsRedirect_Modified, Default=Modified}"
                                            Binding="{Binding Modified}" Width="150" />
                        <DataGridTemplateColumn Header="{svc:Loc Key=Xaml_Actions_c3cd636a}" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="{svc:Loc Key=HostsRedirect_Remove, Default=Remove}"
                                            Padding="8,2" Style="{StaticResource Hg.DangerButton}"
                                            Command="{Binding DataContext.RemoveRedirectCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <Border Grid.Row="2" Style="{StaticResource Hg.EmptyState}"
                        Visibility="{Binding Redirects.Count, Converter={StaticResource EmptyStateVis}}">
                    <StackPanel>
                        <TextBlock Text="{svc:Loc Key=HostsRedirect_NoRows, Default=No local redirects}"
                                   Style="{StaticResource Hg.SectionTitle}"
                                   HorizontalAlignment="Center" Margin="0,0,0,4" />
                        <TextBlock Text="{svc:Loc Key=HostsRedirect_EmptyHelp, Default=Add a domain and IP above to create an intentional hosts-file mapping.}"
                                   Style="{StaticResource Hg.EmptyText}" />
                    </StackPanel>
                </Border>

                <TextBlock Grid.Row="3" Margin="2,6,0,0" Text="{Binding StatusText}"
                           Style="{StaticResource Hg.DimText}"
                           AutomationProperties.LiveSetting="Polite" />
            </Grid>
        </TabItem>

        <TabItem Header="{svc:Loc Key=Tab_Blocklists, Default=Blocklists}">
            <Grid Margin="4" DataContext="{Binding Blocklists}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <DataGrid Grid.Row="0" ItemsSource="{Binding Sources}"
                          AutomationProperties.Name="{svc:Loc Key=Xaml_Blocklist_sources_47c4f37d}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="{svc:Loc Key=Xaml_Category_a3c686e7}" Binding="{Binding Category}" Width="120" />
                        <DataGridTextColumn Header="{svc:Loc Key=Xaml_Name_709a2322}" Binding="{Binding Name}" Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="ToolTip" Value="{Binding GalleryTip}" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="{svc:Loc Key=BlockGallery_Tags}" Binding="{Binding Tags}" Width="150">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="ToolTip" Value="{Binding GalleryTip}" />
                                    <Setter Property="Foreground" Value="{DynamicResource Hg.Sub}" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="{svc:Loc Key=BlockGallery_License}" Binding="{Binding License}" Width="86" />
                        <DataGridCheckBoxColumn Header="{svc:Loc Key=Xaml_Subscribed_dd1242a8}" Binding="{Binding Subscribed}" Width="90" IsReadOnly="True" />
                        <DataGridCheckBoxColumn Header="{svc:Loc Key=Xaml_Enabled_df174a3f}" Binding="{Binding Enabled}" Width="72" IsReadOnly="True" />
                        <DataGridTextColumn Header="{svc:Loc Key=Xaml_Domains_a0d641b3}" Binding="{Binding DomainCount}" Width="90" />
                        <DataGridTextColumn Header="{svc:Loc Key=Xaml_Owned_b62ff5cc}" Binding="{Binding OwnedDomainCount}" Width="70" />
                        <DataGridTextColumn Header="{svc:Loc Key=Xaml_Hits_30d_d0f4cbfd}" Binding="{Binding Hits30d}" Width="80" />
                        <DataGridTextColumn Header="{svc:Loc Key=Xaml_Last_refresh_53cadc51}" Binding="{Binding LastRefresh}" Width="160" />
                        <DataGridTextColumn Header="{svc:Loc Key=Xaml_Health_3703cd21}" Binding="{Binding HealthSummary}" Width="180">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource Hg.Peach}" />
                                    <Setter Property="ToolTip" Value="{Binding HealthSummary}" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="{svc:Loc Key=Blocklists_Mirror}" Binding="{Binding MirrorsText}" Width="130"
                                            IsReadOnly="True" />
                        <DataGridTemplateColumn Header="{svc:Loc Key=Xaml_Actions_c3cd636a}" Width="480">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="{svc:Loc Key=Xaml_Preview_f1fbb2b4}" Padding="8,2" Margin="0,0,6,0"
                                                Command="{Binding DataContext.PreviewCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}" />
                                        <Button Content="{svc:Loc Key=Xaml_Import_d6fbc9d2}" Padding="8,2" Margin="0,0,6,0"
                                                Style="{StaticResource Hg.AccentButton}"
                                                Command="{Binding DataContext.ImportCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}" />
                                        <Button Content="{Binding ToggleLabel}" Padding="8,2" Margin="0,0,6,0"
                                                Visibility="{Binding Subscribed, Converter={StaticResource BoolToVis}}"
                                                Command="{Binding DataContext.ToggleEnabledCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}" />
                                        <Button Content="{svc:Loc Key=Xaml_Restore_3cbe6d6b}" Padding="8,2" Margin="0,0,6,0"
                                                Visibility="{Binding CanRollback, Converter={StaticResource BoolToVis}}"
                                                Command="{Binding DataContext.RollbackCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}" />
                                        <Button Content="{svc:Loc Key=Blocklists_Mirror}" Padding="8,2" Margin="0,0,6,0"
                                                Visibility="{Binding Subscribed, Converter={StaticResource BoolToVis}}"
                                                Command="{Binding DataContext.EditMirrorsCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}" />
                                        <Button Content="{svc:Loc Key=Xaml_Remove_e963907d}" Padding="8,2"
                                                Visibility="{Binding Subscribed, Converter={StaticResource BoolToVis}}"
                                                Command="{Binding DataContext.UnsubscribeCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}" />
                                        <Button Content="{svc:Loc Key=BlockGallery_Homepage}" Padding="8,2" Margin="6,0,0,0"
                                                ToolTip="{Binding Homepage}"
                                                Command="{Binding DataContext.OpenHomepageCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Homepage}" Value="">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <Border Grid.Row="0"
                        Style="{StaticResource Hg.EmptyState}"
                        Visibility="{Binding Sources.Count, Converter={StaticResource EmptyStateVis}}">
                    <StackPanel>
                        <TextBlock Text="{svc:Loc Key=Xaml_No_blocklist_sources_2d426058}"
                                   Style="{StaticResource Hg.SectionTitle}"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,4" />
                        <TextBlock Text="{svc:Loc Key=Xaml_The_service_did_not_return_the_e87954a3}"
                                   Style="{StaticResource Hg.EmptyText}" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Style="{StaticResource Hg.Card}" Margin="0,8,0,0"
                        Visibility="{Binding HasConnectivityWarnings, Converter={StaticResource BoolToVis}}"
                        AutomationProperties.Name="{svc:Loc Key=Ncsi_WarningName}">
                    <StackPanel>
                        <DockPanel LastChildFill="False">
                            <Button DockPanel.Dock="Right" Content="{svc:Loc Key=Ncsi_RecoverAction}"
                                    Command="{Binding RecoverWindowsConnectivityCommand}"
                                    Style="{StaticResource Hg.AccentButton}" Margin="10,0,0,0"
                                    AutomationProperties.Name="{svc:Loc Key=Ncsi_RecoverActionName}"
                                    ToolTip="{svc:Loc Key=Ncsi_RecoverTip}" />
                            <StackPanel>
                                <TextBlock Text="{svc:Loc Key=Ncsi_WarningTitle}"
                                           Style="{StaticResource Hg.SectionTitle}" />
                                <TextBlock Text="{svc:Loc Key=Ncsi_WarningHelp}"
                                           Style="{StaticResource Hg.HelperText}" Margin="0,3,0,0"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </DockPanel>
                        <ItemsControl ItemsSource="{Binding ConnectivityWarnings}" Margin="0,8,0,0">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource Hg.StatusStrip}" Margin="0,0,8,6" MinWidth="300">
                                        <StackPanel>
                                            <DockPanel>
                                                <TextBlock DockPanel.Dock="Right" Text="{Binding StateText}"
                                                           Style="{StaticResource Hg.DimText}" Margin="8,0,0,0" />
                                                <TextBlock Text="{Binding Domain}" FontWeight="SemiBold" />
                                            </DockPanel>
                                            <TextBlock Text="{Binding DisplayReason}" Style="{StaticResource Hg.SubText}"
                                                       TextWrapping="Wrap" ToolTip="{Binding Reason}" />
                                            <TextBlock Text="{Binding DisplayMetadata}" Style="{StaticResource Hg.DimText}" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="{Binding ConnectivityWarningStatus}"
                                   Style="{StaticResource Hg.DimText}"
                                   AutomationProperties.LiveSetting="Polite" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="2" Style="{StaticResource Hg.Card}" Margin="0,8,0,0"
                        AutomationProperties.Name="{svc:Loc Key=LocalList_Title}">
                    <StackPanel>
                        <DockPanel LastChildFill="False">
                            <Button x:Name="LocalBlocklistImportButton" DockPanel.Dock="Right"
                                    Content="{svc:Loc Key=LocalList_ImportAction}"
                                    Command="{Binding ImportLocalPreviewCommand}"
                                    Style="{StaticResource Hg.AccentButton}" Margin="8,0,0,0" />
                            <Button x:Name="LocalBlocklistPreviewButton" DockPanel.Dock="Right"
                                    Content="{svc:Loc Key=LocalList_PreviewAction}"
                                    Command="{Binding PreviewLocalFileCommand}" Margin="8,0,0,0" />
                            <StackPanel>
                                <TextBlock Text="{svc:Loc Key=LocalList_Title}" Style="{StaticResource Hg.SectionTitle}" />
                                <TextBlock Text="{svc:Loc Key=LocalList_Help}" Style="{StaticResource Hg.HelperText}"
                                           Margin="0,3,0,0" TextWrapping="Wrap" />
                            </StackPanel>
                        </DockPanel>
                        <TextBlock Text="{Binding LocalFileLabel}" Style="{StaticResource Hg.SubText}"
                                   Margin="0,7,0,0" TextTrimming="CharacterEllipsis" />
                        <TextBlock x:Name="LocalBlocklistPreviewSummary"
                                   Text="{Binding LocalPreviewSummary}" Style="{StaticResource Hg.DimText}"
                                   Margin="0,3,0,0" TextWrapping="Wrap"
                                   AutomationProperties.LiveSetting="Polite" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="3" Style="{StaticResource Hg.Card}" Margin="0,8,0,0">
                    <DockPanel>
                        <Button DockPanel.Dock="Right" Content="{svc:Loc Key=Xaml_Save_apply_allowlists_c3ce8fa2}"
                                Style="{StaticResource Hg.AccentButton}"
                                Command="{Binding SaveAllowlistsCommand}" Margin="8,0,0,0"
                                VerticalAlignment="Top" />
                        <Button DockPanel.Dock="Right" Content="{svc:Loc Key=Xaml_Refresh_all_subscriptions_2a8a52db}"
                                Command="{Binding RefreshAllListsCommand}" Margin="8,0,0,0"
                                VerticalAlignment="Top" />
                        <StackPanel>
                            <TextBlock Text="{svc:Loc Key=Xaml_Allowlist_URLs_one_per_line_67b8a98c}"
                                       Style="{StaticResource Hg.SubText}" Margin="0,0,0,4" />
                            <TextBox Text="{Binding AllowlistUrlsText, UpdateSourceTrigger=PropertyChanged}"
                                     AutomationProperties.Name="{svc:Loc Key=Xaml_Allowlist_subscription_URLs_ef7fa97d}"
                                     AcceptsReturn="True" MinHeight="52" MaxHeight="110"
                                     VerticalScrollBarVisibility="Auto" FontFamily="Consolas" />
                        </StackPanel>
                    </DockPanel>
                </Border>

                <TextBlock Grid.Row="4" Margin="2,6,0,0"
                           Text="{Binding StatusText}"
                           Style="{StaticResource Hg.DimText}"
                           AutomationProperties.LiveSetting="Polite" />
            </Grid>
        </TabItem>

        <TabItem Header="{svc:Loc Key=Tab_RawEditor, Default=Raw Editor}">
            <Grid Margin="4" DataContext="{Binding RawHosts}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource Hg.CommandBar}" Margin="0,0,0,8">
                <DockPanel LastChildFill="False">
                    <Button DockPanel.Dock="Right" Content="{svc:Loc Key=Xaml_Save_efc007a3}"
                            Style="{StaticResource Hg.AccentButton}"
                            Command="{Binding SaveCommand}" IsEnabled="{Binding IsDirty}"
                            ToolTip="{svc:Loc Key=Xaml_Write_the_edited_text_back_to_11af2855}" />
                    <Button DockPanel.Dock="Right" Content="{svc:Loc Key=Xaml_Reload_cce71553}"
                            Command="{Binding LoadCommand}" Margin="0,0,8,0"
                            ToolTip="{svc:Loc Key=Xaml_Discard_edits_and_reload_the_hosts_7d7d2853}" />
                    <Button DockPanel.Dock="Right" Content="{svc:Loc Key=Xaml_AI_Categorize_27b3527f}"
                            Command="{Binding AiCategorizeCommand}" Margin="0,0,8,0"
                            ToolTip="{svc:Loc Key=Xaml_Have_DeepSeek_categorize_every_hosts_file_3b37a22a}" />
                    <TextBlock DockPanel.Dock="Right" Margin="0,0,12,0" VerticalAlignment="Center"
                               Text="{svc:Loc Key=Xaml_Unsaved_changes_617137b6}" Foreground="{DynamicResource Hg.Peach}"
                               Visibility="{Binding IsDirty, Converter={StaticResource BoolToVis}}" />
                </DockPanel>
                </Border>

                <TextBox Grid.Row="1"
                         Text="{Binding Text, UpdateSourceTrigger=PropertyChanged}"
