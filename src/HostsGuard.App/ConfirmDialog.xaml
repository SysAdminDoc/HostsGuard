<Window x:Class="HostsGuard.App.ConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:svc="clr-namespace:HostsGuard.App.Services"
        Style="{StaticResource Hg.Window}"
        Title="{svc:Loc Key=Xaml_Confirm_action_50649c5c}"
        Width="460"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        AutomationProperties.Name="{svc:Loc Key=Xaml_HostsGuard_confirmation_07e67cb7}">
    <Border Style="{StaticResource Hg.DialogFrame}">
        <Grid Margin="22">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0">
                <Border DockPanel.Dock="Left"
                        Style="{StaticResource Hg.DialogIcon}"
                        Background="{DynamicResource Hg.DangerSoft}"
                        BorderBrush="{DynamicResource Hg.DangerBorder}">
                    <Viewbox Stretch="Uniform">
                        <Path Data="M 12 2 L 22 21 H 2 Z M 12 8 V 13 M 12 17 H 12"
                              Stroke="{DynamicResource Hg.Red}"
                              Fill="Transparent"
                              StrokeThickness="2"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              StrokeLineJoin="Round" />
                    </Viewbox>
                </Border>
                <TextBlock x:Name="TitleText"
                           Style="{StaticResource Hg.DialogTitle}" />
            </DockPanel>

            <TextBlock Grid.Row="1"
                       x:Name="MessageText"
                       Margin="0,12,0,0"
                       Style="{StaticResource Hg.SubText}"
                       TextWrapping="Wrap"
                       LineHeight="20" />

            <Border Grid.Row="2"
                    Margin="0,14,0,0"
                    Padding="10,8"
                    CornerRadius="6"
                    Background="{DynamicResource Hg.Mantle}"
                    BorderBrush="{DynamicResource Hg.S0}"
                    BorderThickness="1">
                <TextBlock Text="{svc:Loc Key=Xaml_This_action_is_applied_immediately_Review_690963d1}"
                           Style="{StaticResource Hg.DimText}"
                           TextWrapping="Wrap" />
            </Border>

            <Grid Grid.Row="3" Margin="0,18,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="1"
                        x:Name="CancelButton"
                        Content="{svc:Loc Key=Xaml_Cancel_77dfd213}"
                        MinWidth="92"
                        Margin="0,0,8,0"
                        IsCancel="True"
                        Click="OnCancel" />
                <Button Grid.Column="2"
                        x:Name="ConfirmButton"
                        Content="{svc:Loc Key=Xaml_Continue_2e026239}"
                        MinWidth="104"
                        Style="{StaticResource Hg.DangerButton}"
                        IsDefault="False"
                        Click="OnConfirm" />
            </Grid>
        </Grid>
    </Border>
</Window>
