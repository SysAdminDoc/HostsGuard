<Window x:Class="HostsGuard.App.ConsentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HostsGuard — connection blocked"
        Width="460" SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        Topmost="True" ShowInTaskbar="True" ResizeMode="NoResize"
        AutomationProperties.Name="HostsGuard connection consent prompt"
        Background="{DynamicResource Hg.Base}"
        Foreground="{DynamicResource Hg.Text}">
    <Border BorderBrush="{DynamicResource Hg.S1}" BorderThickness="1">
        <StackPanel Margin="20,16,20,16">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left" Text="Connection blocked" FontSize="15" FontWeight="Bold"
                           Foreground="{DynamicResource Hg.Red}" />
                <TextBlock DockPanel.Dock="Right" x:Name="Countdown" HorizontalAlignment="Right"
                           Foreground="{DynamicResource Hg.Dim}" />
            </DockPanel>

            <Border x:Name="ThreatBanner" Visibility="Collapsed" Margin="0,10,0,0" Padding="8,5"
                    Background="{DynamicResource Hg.Danger2}" CornerRadius="4"
                    AutomationProperties.LiveSetting="Assertive">
                <TextBlock Text="⚠ This remote address is on the threat-intelligence list"
                           AutomationProperties.Name="Warning: this remote address is on the threat-intelligence list"
                           Foreground="{DynamicResource Hg.OnDanger}" FontWeight="SemiBold" />
            </Border>

            <TextBlock x:Name="AppName" FontSize="14" FontWeight="SemiBold" Margin="0,10,0,2" />
            <TextBlock x:Name="AppPath" TextWrapping="Wrap" Foreground="{DynamicResource Hg.Dim}" FontSize="11" />

            <Grid Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition /> <RowDefinition /> <RowDefinition />
                    <RowDefinition /> <RowDefinition /> <RowDefinition />
                    <RowDefinition />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Remote" Foreground="{DynamicResource Hg.Sub}" Margin="0,0,14,3" />
                <TextBlock Grid.Row="0" Grid.Column="1" x:Name="RemoteText" FontFamily="Consolas" />
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Host" Foreground="{DynamicResource Hg.Sub}" Margin="0,0,14,3" />
                <TextBlock Grid.Row="1" Grid.Column="1" x:Name="HostText" Foreground="{DynamicResource Hg.Dim}" Text="resolving…" />
                <TextBlock Grid.Row="2" Grid.Column="0" Text="Location" Foreground="{DynamicResource Hg.Sub}" Margin="0,0,14,3" />
                <TextBlock Grid.Row="2" Grid.Column="1" x:Name="CountryText" />
                <TextBlock Grid.Row="3" Grid.Column="0" Text="Direction" Foreground="{DynamicResource Hg.Sub}" Margin="0,0,14,3" />
                <TextBlock Grid.Row="3" Grid.Column="1" x:Name="DirectionText" />
                <TextBlock Grid.Row="4" Grid.Column="0" Text="Process" Foreground="{DynamicResource Hg.Sub}" Margin="0,0,14,3" />
                <TextBlock Grid.Row="4" Grid.Column="1" x:Name="PidText" />
                <TextBlock Grid.Row="5" Grid.Column="0" Text="Signer" Foreground="{DynamicResource Hg.Sub}" Margin="0,0,14,0" />
                <TextBlock Grid.Row="5" Grid.Column="1" x:Name="SignerText" TextWrapping="Wrap" />
                <TextBlock Grid.Row="6" Grid.Column="0" x:Name="ServiceLabel" Text="Service" Visibility="Collapsed"
                           Foreground="{DynamicResource Hg.Sub}" Margin="0,3,14,0" />
                <TextBlock Grid.Row="6" Grid.Column="1" x:Name="ServiceText" Visibility="Collapsed"
                           Margin="0,3,0,0" TextWrapping="Wrap" />
            </Grid>

            <TextBlock Text="Scope" Margin="0,14,0,4" Foreground="{DynamicResource Hg.Sub}" FontWeight="SemiBold" />
            <WrapPanel>
                <CheckBox x:Name="ScopeRemote" Content="This IP" Margin="0,0,16,0" TabIndex="0"
                          AutomationProperties.Name="Restrict the rule to this remote IP address"
                          Foreground="{DynamicResource Hg.Sub}" />
                <CheckBox x:Name="ScopePort" Content="This port" Margin="0,0,16,0" TabIndex="1"
                          AutomationProperties.Name="Restrict the rule to this remote port"
                          Foreground="{DynamicResource Hg.Sub}" />
                <CheckBox x:Name="ScopeProtocol" Content="This protocol" Margin="0,0,16,0" TabIndex="2"
                          AutomationProperties.Name="Restrict the rule to this protocol"
                          Foreground="{DynamicResource Hg.Sub}" />
                <CheckBox x:Name="ScopeService" Content="This service only" Visibility="Collapsed" TabIndex="3"
                          AutomationProperties.Name="Restrict the rule to the owning Windows service"
                          ToolTip="Blocks only this service, not everything hosted by the same process (svchost)"
                          Foreground="{DynamicResource Hg.Sub}" />
            </WrapPanel>

            <DockPanel Margin="0,12,0,0" LastChildFill="False">
                <TextBlock DockPanel.Dock="Left" Text="Duration" VerticalAlignment="Center"
                           Margin="0,0,10,0" Foreground="{DynamicResource Hg.Sub}" FontWeight="SemiBold" />
                <ComboBox DockPanel.Dock="Left" x:Name="DurationBox" Width="160" SelectedIndex="3" TabIndex="4"
                          AutomationProperties.Name="Rule duration">
                    <ComboBoxItem Tag="once" Content="Once (15 min)" />
                    <ComboBoxItem Tag="1h" Content="1 hour" />
                    <ComboBoxItem Tag="session" Content="This session" />
                    <ComboBoxItem Tag="always" Content="Always" />
                </ComboBox>
            </DockPanel>

            <Grid Margin="0,16,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition /> <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <Button x:Name="AllowButton" Grid.Column="0" Content="Allow" Margin="0,0,6,0" Padding="8,8" TabIndex="5"
                        AutomationProperties.Name="Allow this connection"
                        Style="{StaticResource Hg.AccentButton}" Click="OnAllow" />
                <Button Grid.Column="1" Content="Block" Padding="8,8" TabIndex="6"
                        AutomationProperties.Name="Block this connection"
                        Style="{StaticResource Hg.DangerButton}" Click="OnBlock" />
            </Grid>

            <TextBlock Margin="0,10,0,0" FontSize="11" Foreground="{DynamicResource Hg.Dim}" TextWrapping="Wrap"
                       Text="No decision keeps the connection blocked (default-deny is active). Whole-app by default; check a scope to narrow the rule. Non-permanent rules are removed automatically." />
        </StackPanel>
    </Border>
</Window>
