<Window x:Class="HostsGuard.App.ConsentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:svc="clr-namespace:HostsGuard.App.Services"
        Title="{svc:Loc Key=Consent_WindowTitle}"
        Style="{StaticResource Hg.Window}"
        Width="540" SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        Topmost="True" ShowInTaskbar="True" ResizeMode="NoResize"
        AutomationProperties.Name="{svc:Loc Key=Xaml_HostsGuard_connection_consent_prompt_370e8956}"
        Background="{DynamicResource Hg.Base}"
        Foreground="{DynamicResource Hg.Text}">
    <Window.Resources>
        <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <DataTemplate x:Key="ConsentWrappedContent">
            <TextBlock Text="{Binding}" TextWrapping="Wrap" TextAlignment="Center" />
        </DataTemplate>
        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="ContentTemplate" Value="{StaticResource ConsentWrappedContent}" />
        </Style>
        <Style TargetType="CheckBox" BasedOn="{StaticResource {x:Type CheckBox}}">
            <Setter Property="ContentTemplate" Value="{StaticResource ConsentWrappedContent}" />
        </Style>
    </Window.Resources>
    <Border Style="{StaticResource Hg.DialogFrame}">
        <StackPanel Margin="22,18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0"
                        Style="{StaticResource Hg.DialogIcon}"
                        Background="{DynamicResource Hg.DangerSoft}"
                        BorderBrush="{DynamicResource Hg.DangerBorder}">
                    <Viewbox Stretch="Uniform">
                        <Path Data="M 12 2 L 22 21 H 2 Z M 12 8 V 13 M 12 17 H 12"
                              Stroke="{DynamicResource Hg.Red}"
                              Fill="Transparent"
                              StrokeThickness="2"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              StrokeLineJoin="Round" />
                    </Viewbox>
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="{svc:Loc Key=Xaml_Connection_blocked_c2c1ee6c}"
                               Style="{StaticResource Hg.DialogTitle}"
                               Foreground="{DynamicResource Hg.Red}" />
                    <TextBlock Text="{svc:Loc Key=Xaml_Review_the_process_destination_and_rule_625c4e34}"
                               Style="{StaticResource Hg.HelperText}"
                               Margin="0,3,0,0" />
                </StackPanel>
                <TextBlock Grid.Column="2"
                           x:Name="Countdown"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Top"
                           Foreground="{DynamicResource Hg.Dim}"
                           AutomationProperties.LiveSetting="Polite" />
            </Grid>

            <Border x:Name="ThreatBanner" Visibility="Collapsed" Margin="0,12,0,0" Padding="10,7"
                    Background="{DynamicResource Hg.DangerSoft}"
                    BorderBrush="{DynamicResource Hg.DangerBorder}"
                    BorderThickness="1"
                    CornerRadius="6"
                    AutomationProperties.LiveSetting="Assertive">
                <TextBlock Text="{svc:Loc Key=Consent_ThreatBanner}"
                           AutomationProperties.Name="{svc:Loc Key=Xaml_Warning_this_remote_address_is_on_2674dcd5}"
                           Foreground="{DynamicResource Hg.Red}" FontWeight="SemiBold" />
            </Border>

            <DockPanel Margin="0,10,0,2" LastChildFill="False">
                <TextBlock DockPanel.Dock="Left" x:Name="AppName" FontSize="14" FontWeight="SemiBold" />
                <TextBlock DockPanel.Dock="Right" VerticalAlignment="Center">
                    <Hyperlink x:Name="LookupLink" Click="OnLookup"
                               AutomationProperties.Name="{svc:Loc Key=Xaml_Look_up_this_process_reputation_online_e5312c55}"
                               Foreground="{DynamicResource Hg.Blue}">
                        <Run Text="{svc:Loc Key=Xaml_Look_up_reputation_51bc5c1e}" />
                    </Hyperlink>
                </TextBlock>
            </DockPanel>
            <TextBlock x:Name="AppPath" TextWrapping="Wrap" Foreground="{DynamicResource Hg.Dim}" FontSize="11" />

            <Border Style="{StaticResource Hg.StatusStrip}" Margin="0,12,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition /> <RowDefinition /> <RowDefinition />
                    <RowDefinition /> <RowDefinition /> <RowDefinition />
                    <RowDefinition /> <RowDefinition /> <RowDefinition />
                    <RowDefinition /> <RowDefinition />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="{svc:Loc Key=Xaml_Remote_c93f6536}" Foreground="{DynamicResource Hg.Sub}" Margin="0,0,16,4" />
                <TextBlock Grid.Row="0" Grid.Column="1" x:Name="RemoteText" FontFamily="Consolas" />
                <TextBlock Grid.Row="1" Grid.Column="0" x:Name="LocalLabel" Text="{svc:Loc Key=Consent_LocalEndpoint}" Visibility="Collapsed"
                           Foreground="{DynamicResource Hg.Sub}" Margin="0,0,16,4" />
                <TextBlock Grid.Row="1" Grid.Column="1" x:Name="LocalText" Visibility="Collapsed" FontFamily="Consolas" />
                <TextBlock Grid.Row="2" Grid.Column="0" x:Name="NetworkLabel" Text="{svc:Loc Key=Consent_NetworkEvidence}" Visibility="Collapsed"
                           Foreground="{DynamicResource Hg.Sub}" Margin="0,0,16,4" />
                <TextBlock Grid.Row="2" Grid.Column="1" x:Name="NetworkText" Visibility="Collapsed" TextWrapping="Wrap" />
                <TextBlock Grid.Row="3" Grid.Column="0" x:Name="OriginLabel" Text="{svc:Loc Key=Consent_WfpEvidence}" Visibility="Collapsed"
                           Foreground="{DynamicResource Hg.Sub}" Margin="0,0,16,4" />
                <TextBlock Grid.Row="3" Grid.Column="1" x:Name="OriginText" Visibility="Collapsed" TextWrapping="Wrap" />
                <TextBlock Grid.Row="4" Grid.Column="0" Text="{svc:Loc Key=Xaml_Host_3960ec4c}" Foreground="{DynamicResource Hg.Sub}" Margin="0,0,16,4" />
                <TextBlock Grid.Row="4" Grid.Column="1" x:Name="HostText" Foreground="{DynamicResource Hg.Dim}" Text="{svc:Loc Key=Consent_Resolving}" />
                <TextBlock Grid.Row="5" Grid.Column="0" Text="{svc:Loc Key=Xaml_Location_d219c681}" Foreground="{DynamicResource Hg.Sub}" Margin="0,0,16,4" />
                <TextBlock Grid.Row="5" Grid.Column="1" x:Name="CountryText" />
                <TextBlock Grid.Row="6" Grid.Column="0" Text="{svc:Loc Key=Xaml_Direction_fd8e45ba}" Foreground="{DynamicResource Hg.Sub}" Margin="0,0,16,4" />
                <TextBlock Grid.Row="6" Grid.Column="1" x:Name="DirectionText" />
                <TextBlock Grid.Row="7" Grid.Column="0" Text="{svc:Loc Key=Xaml_Process_12f4c13a}" Foreground="{DynamicResource Hg.Sub}" Margin="0,0,16,4" />
                <TextBlock Grid.Row="7" Grid.Column="1" x:Name="PidText" />
                <TextBlock Grid.Row="8" Grid.Column="0" Text="{svc:Loc Key=Xaml_Signer_362166e4}" Foreground="{DynamicResource Hg.Sub}" Margin="0,0,16,0" />
                <TextBlock Grid.Row="8" Grid.Column="1" x:Name="SignerText" TextWrapping="Wrap" />
                <TextBlock Grid.Row="9" Grid.Column="0" x:Name="ServiceLabel" Text="{svc:Loc Key=Xaml_Service_329cb8b6}" Visibility="Collapsed"
                           Foreground="{DynamicResource Hg.Sub}" Margin="0,4,16,0" />
                <TextBlock Grid.Row="9" Grid.Column="1" x:Name="ServiceText" Visibility="Collapsed"
                           Margin="0,4,0,0" TextWrapping="Wrap" />
                <TextBlock Grid.Row="10" Grid.Column="0" x:Name="CommandLineLabel" Text="{svc:Loc Key=Xaml_Command_line_796f8db3}" Visibility="Collapsed"
                           Foreground="{DynamicResource Hg.Sub}" Margin="0,4,16,0" />
                <TextBlock Grid.Row="10" Grid.Column="1" x:Name="CommandLineText" Visibility="Collapsed"
                           Margin="0,4,0,0" TextWrapping="Wrap" FontFamily="Consolas" />
            </Grid>
            </Border>

            <TextBlock Text="{svc:Loc Key=Xaml_Scope_4651a34e}" Margin="0,14,0,4" Foreground="{DynamicResource Hg.Sub}" FontWeight="SemiBold" />
            <WrapPanel>
                <CheckBox x:Name="ScopeRemote" Content="{svc:Loc Key=Xaml_This_IP_bf8b4db9}" Margin="0,0,16,0" TabIndex="0"
                          AutomationProperties.Name="{svc:Loc Key=Xaml_Restrict_the_rule_to_this_remote_81fecf80}"
                          Foreground="{DynamicResource Hg.Text}" />
                <CheckBox x:Name="ScopePort" Content="{svc:Loc Key=Xaml_This_port_04911fa9}" Margin="0,0,16,0" TabIndex="1"
                          AutomationProperties.Name="{svc:Loc Key=Xaml_Restrict_the_rule_to_this_remote_00c2199f}"
                          Foreground="{DynamicResource Hg.Text}" />
                <CheckBox x:Name="ScopeProtocol" Content="{svc:Loc Key=Xaml_This_protocol_4b170216}" Margin="0,0,16,0" TabIndex="2"
                          AutomationProperties.Name="{svc:Loc Key=Xaml_Restrict_the_rule_to_this_protocol_6e4b38f9}"
                          Foreground="{DynamicResource Hg.Text}" />
                <CheckBox x:Name="ScopeService" Content="{svc:Loc Key=Xaml_This_service_only_faf667a0}" Visibility="Collapsed" TabIndex="3"
                          AutomationProperties.Name="{svc:Loc Key=Xaml_Restrict_the_rule_to_the_owning_21045308}"
                          ToolTip="{svc:Loc Key=Xaml_Blocks_only_this_service_not_everything_1b90c1c7}"
                          Foreground="{DynamicResource Hg.Text}" />
                <CheckBox x:Name="ScopeCommandLine" Content="{svc:Loc Key=Xaml_Only_this_script_module_76f07ae2}" Visibility="Collapsed" TabIndex="4"
                          AutomationProperties.Name="{svc:Loc Key=Xaml_Restrict_the_rule_to_this_script_61fd89a5}"
                          ToolTip="{svc:Loc Key=Xaml_Keeps_other_interpreter_scripts_separate_7febbc2b}"
                          Foreground="{DynamicResource Hg.Text}" />
            </WrapPanel>

            <!-- NET-113: trust the app's Authenticode publisher (shown only when signed). -->
            <CheckBox x:Name="TrustPublisher" Visibility="Collapsed" Margin="0,10,0,0" TabIndex="5"
                      AutomationProperties.Name="{svc:Loc Key=Xaml_Trust_all_software_signed_by_this_f4f554f6}"
                      ToolTip="{svc:Loc Key=Xaml_On_Allow_auto_allow_any_future_9dd11626}"
                      Foreground="{DynamicResource Hg.Text}" />

            <!-- NET-117: trust the app's parent folder (any binary under it). -->
            <CheckBox x:Name="TrustFolder" Visibility="Collapsed" Margin="0,6,0,0" TabIndex="6"
                      AutomationProperties.Name="{svc:Loc Key=Xaml_Trust_all_software_in_this_folder_e1cab6fe}"
                      ToolTip="{svc:Loc Key=Xaml_On_Allow_auto_allow_any_future_155d44e6}"
                      Foreground="{DynamicResource Hg.Text}" />

            <DockPanel Margin="0,12,0,0" LastChildFill="False">
                <TextBlock DockPanel.Dock="Left" Text="{svc:Loc Key=Xaml_Duration_1370004d}" VerticalAlignment="Center"
                           Margin="0,0,10,0" Foreground="{DynamicResource Hg.Sub}" FontWeight="SemiBold" />
                <ComboBox DockPanel.Dock="Left" x:Name="DurationBox" Width="160" SelectedIndex="3" TabIndex="7"
                          AutomationProperties.Name="{svc:Loc Key=Xaml_Rule_duration_5c7aecf7}">
                    <ComboBoxItem Tag="once" Content="{svc:Loc Key=Xaml_Once_15_min_2aef53b4}" />
                    <ComboBoxItem Tag="1h" Content="{svc:Loc Key=Xaml_1_hour_f030c3d6}" />
                    <ComboBoxItem Tag="session" Content="{svc:Loc Key=Xaml_This_session_48c2a13d}" />
                    <ComboBoxItem Tag="always" Content="{svc:Loc Key=Xaml_Always_a91bcce8}" />
                </ComboBox>
            </DockPanel>

            <Grid Margin="0,16,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition /> <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <Button x:Name="AllowButton" Grid.Column="0" Content="{svc:Loc Key=Xaml_Allow_connection_8a284745}" Margin="0,0,6,0" Padding="8,8" TabIndex="8"
                        AutomationProperties.Name="{svc:Loc Key=Xaml_Allow_this_connection_07a37a38}"
                        Style="{StaticResource Hg.AccentButton}" Click="OnAllow" />
                <Button Grid.Column="1" Content="{svc:Loc Key=Xaml_Keep_blocked_74d09533}" Padding="8,8" TabIndex="9"
                        AutomationProperties.Name="{svc:Loc Key=Xaml_Keep_this_connection_blocked_14498f92}"
                        Style="{StaticResource Hg.DangerButton}" Click="OnBlock" />
            </Grid>

            <!-- NET-099: blanket decisions for a prompt burst from the same app. -->
            <Grid Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition /> <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="{svc:Loc Key=Xaml_Allow_all_from_this_app_b32b8fb7}" Margin="0,0,6,0" Padding="8,6" TabIndex="10"
                        AutomationProperties.Name="{svc:Loc Key=Xaml_Allow_all_pending_connections_from_this_f6b8a4c1}"
                        ToolTip="{svc:Loc Key=Xaml_Write_one_whole_app_allow_rule_46ffd33f}"
                        Click="OnAllowAll" />
                <Button Grid.Column="1" Content="{svc:Loc Key=Xaml_Block_all_from_this_app_afff7d44}" Padding="8,6" TabIndex="11"
                        AutomationProperties.Name="{svc:Loc Key=Xaml_Block_all_pending_connections_from_this_e8cbceda}"
                        ToolTip="{svc:Loc Key=Xaml_Write_one_whole_app_block_rule_3cc8f54a}"
                        Click="OnBlockAll" />
            </Grid>

            <Border Style="{StaticResource Hg.StatusStrip}" Margin="0,10,0,0">
                <TextBlock FontSize="11" Foreground="{DynamicResource Hg.Dim}" TextWrapping="Wrap"
                           Text="{svc:Loc Key=Xaml_If_the_timer_expires_the_connection_53901c4b}" />
            </Border>
        </StackPanel>
    </Border>
</Window>
