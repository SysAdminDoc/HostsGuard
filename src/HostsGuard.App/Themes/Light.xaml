<!-- HostsGuard light theme tokens — ported verbatim from the Python v3.14 _LIGHT
     palette (hostsguard/app.py). Keys must stay in parity with Dark.xaml;
     a test enforces it. -->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="Hg.Bg" Color="#EAF0F6" />
    <SolidColorBrush x:Key="Hg.Base" Color="#FFFFFF" />
    <SolidColorBrush x:Key="Hg.Panel" Color="#FBFCFE" />
    <SolidColorBrush x:Key="Hg.PanelAlt" Color="#F2F6FA" />
    <SolidColorBrush x:Key="Hg.Command" Color="#F5F8FB" />
    <SolidColorBrush x:Key="Hg.RowHover" Color="#E4EEF6" />
    <SolidColorBrush x:Key="Hg.SafeSoft" Color="#DFF5F1" />
    <SolidColorBrush x:Key="Hg.SafeBorder" Color="#7ACAC3" />
    <SolidColorBrush x:Key="Hg.Mantle" Color="#F7F9FC" />
    <SolidColorBrush x:Key="Hg.Crust" Color="#DDE5EE" />
    <SolidColorBrush x:Key="Hg.S0" Color="#C7D2DE" />
    <SolidColorBrush x:Key="Hg.S1" Color="#9FAFBE" />
    <SolidColorBrush x:Key="Hg.S2" Color="#708599" />
    <SolidColorBrush x:Key="Hg.Text" Color="#182431" />
    <SolidColorBrush x:Key="Hg.Sub" Color="#3B4B59" />
    <SolidColorBrush x:Key="Hg.Dim" Color="#617283" />
