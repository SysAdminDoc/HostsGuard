    <SolidColorBrush x:Key="Hg.DangerRow" Color="#FFF4F6" />
    <SolidColorBrush x:Key="Hg.Mauve" Color="#6B35C7" />
    <SolidColorBrush x:Key="Hg.Teal" Color="#007B78" />
    <SolidColorBrush x:Key="Hg.Sky" Color="#0E72AC" />
    <SolidColorBrush x:Key="Hg.Focus" Color="#265FDB" />
    <!-- sel = rgba(31,104,229,0.12) -->
    <SolidColorBrush x:Key="Hg.Sel" Color="#24265FDB" />
    <SolidColorBrush x:Key="Hg.OnSel" Color="#ffffff" />
    <SolidColorBrush x:Key="Hg.RowSelected" Color="#24265FDB" />
    <SolidColorBrush x:Key="Hg.OnRowSelected" Color="#17212B" />

    <!-- chart series accents (timeline / sparklines) -->
    <SolidColorBrush x:Key="Hg.Series0" Color="#265FDB" />
    <SolidColorBrush x:Key="Hg.Series1" Color="#047D78" />
    <SolidColorBrush x:Key="Hg.Series2" Color="#BE5A17" />
