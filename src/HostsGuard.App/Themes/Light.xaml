    <SolidColorBrush x:Key="Hg.Blue" Color="#265FDB" />
    <SolidColorBrush x:Key="Hg.AccentHover" Color="#1F4FB9" />
    <SolidColorBrush x:Key="Hg.Green" Color="#1C7A3D" />
    <SolidColorBrush x:Key="Hg.SuccessSoft" Color="#E4F5EA" />
    <SolidColorBrush x:Key="Hg.SuccessBorder" Color="#92D4A8" />
    <SolidColorBrush x:Key="Hg.SuccessHover" Color="#D5EFDE" />
    <SolidColorBrush x:Key="Hg.Red" Color="#B91F3D" />
    <SolidColorBrush x:Key="Hg.DangerSoft" Color="#FAE5EB" />
    <SolidColorBrush x:Key="Hg.DangerBorder" Color="#E0A0AD" />
    <SolidColorBrush x:Key="Hg.DangerSoftHover" Color="#F2D5DD" />
