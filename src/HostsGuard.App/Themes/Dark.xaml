<!-- HostsGuard dark theme tokens — ported verbatim from the Python v3.14 _DARK
     palette (hostsguard/app.py). Keys must stay in parity with Light.xaml;
     a test enforces it. -->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="Hg.Bg" Color="#090C11" />
    <SolidColorBrush x:Key="Hg.Base" Color="#151A23" />
    <SolidColorBrush x:Key="Hg.Mantle" Color="#10151E" />
    <SolidColorBrush x:Key="Hg.Crust" Color="#070A0F" />
    <SolidColorBrush x:Key="Hg.S0" Color="#252D3B" />
    <SolidColorBrush x:Key="Hg.S1" Color="#39465A" />
    <SolidColorBrush x:Key="Hg.S2" Color="#53627A" />
    <SolidColorBrush x:Key="Hg.Text" Color="#F2F5FA" />
    <SolidColorBrush x:Key="Hg.Sub" Color="#C4CCDA" />
    <SolidColorBrush x:Key="Hg.Dim" Color="#8B98AC" />
    <SolidColorBrush x:Key="Hg.Blue" Color="#83B3FF" />
    <SolidColorBrush x:Key="Hg.AccentHover" Color="#9DC4FF" />
    <SolidColorBrush x:Key="Hg.Green" Color="#8BDD8D" />
    <SolidColorBrush x:Key="Hg.SuccessSoft" Color="#213D30" />
    <SolidColorBrush x:Key="Hg.SuccessBorder" Color="#3B8754" />
    <SolidColorBrush x:Key="Hg.SuccessHover" Color="#2B523D" />
    <SolidColorBrush x:Key="Hg.Red" Color="#FF8AA2" />
    <SolidColorBrush x:Key="Hg.DangerSoft" Color="#4A202B" />
    <SolidColorBrush x:Key="Hg.DangerBorder" Color="#873445" />
    <SolidColorBrush x:Key="Hg.DangerSoftHover" Color="#612A37" />
    <SolidColorBrush x:Key="Hg.Danger2" Color="#D94F6C" />
    <SolidColorBrush x:Key="Hg.DangerHover" Color="#C74660" />
    <SolidColorBrush x:Key="Hg.OnDanger" Color="#ffffff" />
    <SolidColorBrush x:Key="Hg.Peach" Color="#FFB86E" />
    <SolidColorBrush x:Key="Hg.Yellow" Color="#EBCB7A" />
    <SolidColorBrush x:Key="Hg.WarnSoft" Color="#3F331F" />
    <SolidColorBrush x:Key="Hg.Mauve" Color="#B990FF" />
    <SolidColorBrush x:Key="Hg.Teal" Color="#62DFD6" />
    <SolidColorBrush x:Key="Hg.Sky" Color="#78D6FF" />
    <SolidColorBrush x:Key="Hg.Focus" Color="#B8D2FF" />
    <!-- sel = rgba(119,167,255,0.16) -->
    <SolidColorBrush x:Key="Hg.Sel" Color="#367FB4FF" />
    <SolidColorBrush x:Key="Hg.OnSel" Color="#071019" />

    <!-- chart series accents (timeline / sparklines) -->
    <SolidColorBrush x:Key="Hg.Series0" Color="#83B3FF" />
    <SolidColorBrush x:Key="Hg.Series1" Color="#62DFD6" />
    <SolidColorBrush x:Key="Hg.Series2" Color="#FFB86E" />
    <SolidColorBrush x:Key="Hg.Series3" Color="#B990FF" />
    <SolidColorBrush x:Key="Hg.Series4" Color="#EBCB7A" />

</ResourceDictionary>
