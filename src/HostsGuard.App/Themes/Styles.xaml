<!-- Theme-independent control styles. Every color comes from a Hg.* token via
     DynamicResource so the Dark/Light dictionaries can be swapped at runtime. -->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <BooleanToVisibilityConverter x:Key="BoolToVis" />

    <Style x:Key="Hg.Window" TargetType="Window">
        <Setter Property="Background" Value="{DynamicResource Hg.Bg}" />
        <Setter Property="Foreground" Value="{DynamicResource Hg.Text}" />
        <Setter Property="FontFamily" Value="Segoe UI Variable Text" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
        <Setter Property="TextOptions.TextRenderingMode" Value="ClearType" />
    </Style>

    <Style TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource Hg.Text}" />
    </Style>

    <Style x:Key="Hg.SubText" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource Hg.Sub}" />
    </Style>

    <Style x:Key="Hg.DimText" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource Hg.Dim}" />
    </Style>

    <Style x:Key="Hg.SectionTitle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource Hg.Text}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="Hg.FieldLabel" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource Hg.Sub}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Margin" Value="0,0,0,4" />
    </Style>

    <Style x:Key="Hg.HelperText" TargetType="TextBlock" BasedOn="{StaticResource Hg.DimText}">
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="LineHeight" Value="18" />
    </Style>

    <Style x:Key="Hg.EmptyText" TargetType="TextBlock" BasedOn="{StaticResource Hg.SubText}">
        <Setter Property="TextAlignment" Value="Center" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="LineHeight" Value="20" />
        <Setter Property="MaxWidth" Value="440" />
    </Style>

    <Style x:Key="Hg.Card" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource Hg.Panel}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Hg.S0}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="14" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

    <Style x:Key="Hg.EmptyState" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource Hg.Mantle}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Hg.S0}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="18,14" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="IsHitTestVisible" Value="False" />
    </Style>

    <Style x:Key="Hg.StatusStrip" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource Hg.Command}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Hg.S0}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="8,6" />
    </Style>

    <Style x:Key="Hg.CommandBar" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource Hg.Command}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Hg.S0}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="10" />
    </Style>

    <Style x:Key="Hg.TopBand" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource Hg.PanelAlt}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Hg.S0}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
        <Setter Property="Padding" Value="12,8" />
    </Style>

    <Style x:Key="Hg.TopBandButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="MinHeight" Value="34" />
        <Setter Property="Padding" Value="12,6" />
        <Setter Property="Background" Value="{DynamicResource Hg.Panel}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Hg.S1}" />
    </Style>

    <Style x:Key="Hg.SafeButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="MinHeight" Value="34" />
        <Setter Property="Padding" Value="12,6" />
        <Setter Property="Background" Value="{DynamicResource Hg.SafeSoft}" />
        <Setter Property="Foreground" Value="{DynamicResource Hg.Green}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Hg.SafeBorder}" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource Hg.SuccessHover}" />
                <Setter Property="BorderBrush" Value="{DynamicResource Hg.Green}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="Hg.Badge" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource Hg.Command}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Hg.S1}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Padding" Value="6,2" />
    </Style>

    <Style x:Key="Hg.ShellSurface" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource Hg.Bg}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="14,12,18,12" />
    </Style>

    <Style x:Key="Hg.SideRail" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource Hg.PanelAlt}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Hg.S0}" />
        <Setter Property="BorderThickness" Value="0,0,1,0" />
        <Setter Property="Padding" Value="14,12,12,10" />
    </Style>

    <Style x:Key="Hg.RailTile" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource Hg.Panel}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Hg.S0}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="10,9" />
        <Setter Property="Margin" Value="0,0,0,8" />
    </Style>

    <Style x:Key="Hg.BrandMark" TargetType="Border">
        <Setter Property="Width" Value="48" />
        <Setter Property="Height" Value="52" />
        <Setter Property="Background" Value="{DynamicResource Hg.SafeSoft}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Hg.SafeBorder}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="9" />
    </Style>

    <Style x:Key="Hg.BrandName" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource Hg.Text}" />
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="Hg.BrandVersion" TargetType="TextBlock" BasedOn="{StaticResource Hg.DimText}">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Margin" Value="0,3,0,0" />
    </Style>

    <Style x:Key="Hg.DialogFrame" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource Hg.Panel}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Hg.S1}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

    <Style x:Key="Hg.DialogIcon" TargetType="Border">
        <Setter Property="Width" Value="42" />
        <Setter Property="Height" Value="42" />
        <Setter Property="Background" Value="{DynamicResource Hg.Command}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Hg.S1}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="10" />
        <Setter Property="Margin" Value="0,0,12,0" />
    </Style>

    <Style x:Key="Hg.DialogTitle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource Hg.Text}" />
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style x:Key="Hg.MetricTile" TargetType="Border" BasedOn="{StaticResource Hg.RailTile}">
        <Setter Property="Background" Value="{DynamicResource Hg.Command}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Hg.S0}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="9,8" />
        <Setter Property="Margin" Value="0,0,8,8" />
    </Style>

    <Style x:Key="Hg.Inspector" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource Hg.PanelAlt}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Hg.S1}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="16" />
    </Style>

    <Style x:Key="Hg.Kicker" TargetType="TextBlock" BasedOn="{StaticResource Hg.DimText}">
        <Setter Property="FontSize" Value="10" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="TextWrapping" Value="NoWrap" />
    </Style>

    <Style x:Key="Hg.MetricValue" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource Hg.Text}" />
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="Hg.InspectorLabel" TargetType="TextBlock" BasedOn="{StaticResource Hg.Kicker}">
        <Setter Property="Margin" Value="0,10,0,3" />
    </Style>

    <Style x:Key="Hg.InspectorValue" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource Hg.Text}" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="LineHeight" Value="18" />
    </Style>

    <Style x:Key="Hg.ActionChip" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="Padding" Value="6,4" />
        <Setter Property="MinHeight" Value="28" />
        <Setter Property="FontSize" Value="12" />
    </Style>

    <Style x:Key="Hg.CloseIconButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="Width" Value="28" />
        <Setter Property="Height" Value="28" />
        <Setter Property="MinHeight" Value="28" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource Hg.Sub}" />
        <Setter Property="FontSize" Value="14" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource Hg.S0}" />
                <Setter Property="BorderBrush" Value="{DynamicResource Hg.S1}" />
                <Setter Property="Foreground" Value="{DynamicResource Hg.Text}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="Hg.RailDivider" TargetType="Border">
        <Setter Property="Height" Value="1" />
        <Setter Property="Background" Value="{DynamicResource Hg.S0}" />
        <Setter Property="Margin" Value="0,6,0,6" />
    </Style>

    <Style x:Key="Hg.RailLinkButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="Padding" Value="3,2" />
        <Setter Property="MinHeight" Value="22" />
        <Setter Property="FontWeight" Value="Normal" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource Hg.S0}" />
                <Setter Property="BorderBrush" Value="{DynamicResource Hg.S1}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="Hg.RailValue" TargetType="TextBlock" BasedOn="{StaticResource Hg.InspectorValue}">
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="Hg.RailActionText" TargetType="TextBlock" BasedOn="{StaticResource Hg.DimText}">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="TextWrapping" Value="NoWrap" />
    </Style>

    <Style x:Key="Hg.IconTileButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="Width" Value="38" />
        <Setter Property="Height" Value="34" />
        <Setter Property="MinHeight" Value="34" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="FontSize" Value="16" />
    </Style>

    <Style x:Key="Hg.MainTabIcon" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource Hg.Sub}" />
        <Setter Property="FontSize" Value="17" />
        <Setter Property="Margin" Value="0,0,8,0" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style x:Key="Hg.MainTabIconPath" TargetType="Path">
        <Setter Property="Width" Value="16" />
        <Setter Property="Height" Value="16" />
        <Setter Property="Stretch" Value="Uniform" />
        <Setter Property="StrokeThickness" Value="1.7" />
        <Setter Property="StrokeStartLineCap" Value="Round" />
        <Setter Property="StrokeEndLineCap" Value="Round" />
        <Setter Property="StrokeLineJoin" Value="Round" />
        <Setter Property="Fill" Value="Transparent" />
        <Setter Property="Margin" Value="0,0,9,0" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style x:Key="Hg.PrimaryTabs" TargetType="TabControl">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabControl">
                    <Grid KeyboardNavigation.TabNavigation="Local">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0"
                                BorderBrush="{DynamicResource Hg.S0}"
                                BorderThickness="0,0,0,1">
                            <TabPanel x:Name="HeaderPanel"
                                      IsItemsHost="True"
                                      KeyboardNavigation.TabIndex="1"
                                      Panel.ZIndex="1" />
                        </Border>
                        <ContentPresenter x:Name="PART_SelectedContentHost"
                                          Grid.Row="1"
                                          Margin="0,10,0,0"
                                          ContentSource="SelectedContent"
                                          SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Hg.PrimaryTabItem" TargetType="TabItem">
        <Setter Property="Foreground" Value="{DynamicResource Hg.Sub}" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabItem">
                    <Grid Margin="0,0,8,0">
                        <Border x:Name="FocusRing"
                                BorderBrush="{DynamicResource Hg.Focus}"
                                BorderThickness="2"
                                CornerRadius="6"
                                Margin="0,3"
                                Opacity="0"
                                IsHitTestVisible="False" />
                        <Border x:Name="Chrome"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="14,10,14,11">
                            <ContentPresenter ContentSource="Header" />
                        </Border>
                        <Rectangle x:Name="ActiveIndicator"
                                   Height="3"
                                   Margin="12,0"
                                   VerticalAlignment="Bottom"
                                   RadiusX="1.5"
                                   RadiusY="1.5"
                                   Fill="{DynamicResource Hg.Teal}"
                                   Visibility="Collapsed" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="ActiveIndicator" Property="Visibility" Value="Visible" />
                            <Setter Property="Foreground" Value="{DynamicResource Hg.Text}" />
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsSelected" Value="False" />
                                <Condition Property="IsMouseOver" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource Hg.Command}" />
                            <Setter Property="Foreground" Value="{DynamicResource Hg.Text}" />
                        </MultiTrigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="FocusRing" Property="Opacity" Value="1" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Hg.SecondaryTabItem" TargetType="TabItem">
        <Setter Property="Foreground" Value="{DynamicResource Hg.Sub}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabItem">
                    <Grid Margin="0,0,6,0">
                        <Border x:Name="FocusRing"
                                BorderBrush="{DynamicResource Hg.Focus}"
                                BorderThickness="2"
                                CornerRadius="6"
                                Margin="0,2"
                                Opacity="0"
                                IsHitTestVisible="False" />
                        <Border x:Name="Chrome"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="12,8,12,9">
                            <ContentPresenter ContentSource="Header" />
                        </Border>
                        <Rectangle x:Name="ActiveIndicator"
                                   Height="2"
                                   Margin="10,0"
                                   VerticalAlignment="Bottom"
                                   Fill="{DynamicResource Hg.Teal}"
                                   Visibility="Collapsed" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource Hg.Command}" />
                            <Setter TargetName="ActiveIndicator" Property="Visibility" Value="Visible" />
                            <Setter Property="Foreground" Value="{DynamicResource Hg.Text}" />
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsSelected" Value="False" />
                                <Condition Property="IsMouseOver" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource Hg.Command}" />
                            <Setter Property="Foreground" Value="{DynamicResource Hg.Text}" />
                        </MultiTrigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="FocusRing" Property="Opacity" Value="1" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Hg.RailGlyphPath" TargetType="Path" BasedOn="{StaticResource Hg.MainTabIconPath}">
        <Setter Property="Width" Value="15" />
        <Setter Property="Height" Value="15" />
        <Setter Property="Margin" Value="0,0,8,0" />
        <Setter Property="StrokeThickness" Value="1.8" />
    </Style>

    <Style x:Key="Hg.ButtonGlyphPath" TargetType="Path" BasedOn="{StaticResource Hg.MainTabIconPath}">
        <Setter Property="Width" Value="15" />
        <Setter Property="Height" Value="15" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="Stroke" Value="{DynamicResource Hg.Text}" />
        <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>

    <Style TargetType="Button">
        <Setter Property="Background" Value="{DynamicResource Hg.S0}" />
        <Setter Property="Foreground" Value="{DynamicResource Hg.Text}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Hg.S1}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="12,6" />
        <Setter Property="MinHeight" Value="32" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid>
                        <Border x:Name="FocusRing"
                                BorderBrush="{DynamicResource Hg.Focus}"
                                BorderThickness="2"
                                CornerRadius="8"
                                Margin="-2"
                                Opacity="0"
                                IsHitTestVisible="False" />
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource Hg.S2}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Chrome" Property="Opacity" Value="0.86" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource Hg.Focus}" />
                            <Setter TargetName="FocusRing" Property="Opacity" Value="1" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45" />
                            <Setter Property="Cursor" Value="Arrow" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource Hg.S1}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="Hg.AccentButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="Background" Value="{DynamicResource Hg.Teal}" />
        <Setter Property="Foreground" Value="{DynamicResource Hg.OnSel}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Hg.Teal}" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource Hg.Sky}" />
                <Setter Property="BorderBrush" Value="{DynamicResource Hg.Sky}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="Hg.SuccessButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="Background" Value="{DynamicResource Hg.SuccessSoft}" />
        <Setter Property="Foreground" Value="{DynamicResource Hg.Green}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Hg.SuccessBorder}" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource Hg.SuccessHover}" />
                <Setter Property="BorderBrush" Value="{DynamicResource Hg.Green}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="Hg.DangerButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="Background" Value="{DynamicResource Hg.DangerSoft}" />
        <Setter Property="Foreground" Value="{DynamicResource Hg.Red}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Hg.DangerBorder}" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource Hg.DangerSoftHover}" />
                <Setter Property="BorderBrush" Value="{DynamicResource Hg.Red}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="TextBox">
        <Setter Property="Background" Value="{DynamicResource Hg.PanelAlt}" />
        <Setter Property="Foreground" Value="{DynamicResource Hg.Text}" />
        <Setter Property="CaretBrush" Value="{DynamicResource Hg.Text}" />
        <Setter Property="SelectionBrush" Value="{DynamicResource Hg.Sel}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Hg.S1}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="6,4" />
        <Setter Property="MinHeight" Value="32" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Grid>
                        <Border x:Name="FocusRing"
                                BorderBrush="{DynamicResource Hg.Focus}"
                                BorderThickness="2"
                                CornerRadius="8"
                                Margin="-2"
                                Opacity="0"
                                IsHitTestVisible="False" />
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" />
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource Hg.S2}" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource Hg.Focus}" />
                            <Setter TargetName="FocusRing" Property="Opacity" Value="1" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- TextBox with a watermark hint taken from Tag, shown while empty. -->
    <Style x:Key="Hg.HintBox" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Grid>
                        <Border x:Name="FocusRing"
                                BorderBrush="{DynamicResource Hg.Focus}"
                                BorderThickness="2"
                                CornerRadius="8"
                                Margin="-2"
                                Opacity="0"
                                IsHitTestVisible="False" />
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <Grid>
                                <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" />
                                <TextBlock x:Name="Hint" Margin="8,0" VerticalAlignment="Center"
                                           IsHitTestVisible="False" Visibility="Collapsed"
                                           Foreground="{DynamicResource Hg.Dim}"
                                           Text="{TemplateBinding Tag}" TextTrimming="CharacterEllipsis" />
                            </Grid>
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Text" Value="">
                            <Setter TargetName="Hint" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource Hg.S2}" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource Hg.Focus}" />
                            <Setter TargetName="FocusRing" Property="Opacity" Value="1" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="PasswordBox">
        <Setter Property="Background" Value="{DynamicResource Hg.PanelAlt}" />
        <Setter Property="Foreground" Value="{DynamicResource Hg.Text}" />
        <Setter Property="CaretBrush" Value="{DynamicResource Hg.Text}" />
        <Setter Property="SelectionBrush" Value="{DynamicResource Hg.Sel}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Hg.S1}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="6,4" />
        <Setter Property="MinHeight" Value="32" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="PasswordBox">
                    <Grid>
                        <Border x:Name="FocusRing"
                                BorderBrush="{DynamicResource Hg.Focus}"
                                BorderThickness="2"
                                CornerRadius="8"
                                Margin="-2"
                                Opacity="0"
                                IsHitTestVisible="False" />
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" />
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource Hg.S2}" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource Hg.Focus}" />
                            <Setter TargetName="FocusRing" Property="Opacity" Value="1" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="CheckBox">
        <Setter Property="Foreground" Value="{DynamicResource Hg.Text}" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="MinHeight" Value="28" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <Border x:Name="FocusRing"
                            BorderBrush="Transparent"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="3,2"
                            Background="Transparent">
                        <StackPanel Orientation="Horizontal" Background="Transparent">
                            <Border x:Name="Box" Width="17" Height="17" CornerRadius="4"
                                    Background="{DynamicResource Hg.Mantle}"
                                    BorderBrush="{DynamicResource Hg.S1}" BorderThickness="1"
                                    VerticalAlignment="Center">
                                <Path x:Name="Check" Stretch="Uniform" Margin="2.5"
                                      Data="M 0 5 L 3.5 8.5 L 9 1"
                                      Stroke="{DynamicResource Hg.OnSel}" StrokeThickness="1.6"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                      Visibility="Collapsed" />
                            </Border>
                            <ContentPresenter Margin="7,0,0,0" VerticalAlignment="Center" RecognizesAccessKey="True" />
                        </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Box" Property="Background" Value="{DynamicResource Hg.Blue}" />
                            <Setter TargetName="Box" Property="BorderBrush" Value="{DynamicResource Hg.Blue}" />
                            <Setter TargetName="Check" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Box" Property="BorderBrush" Value="{DynamicResource Hg.S2}" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="Box" Property="BorderBrush" Value="{DynamicResource Hg.Focus}" />
                            <Setter TargetName="FocusRing" Property="BorderBrush" Value="{DynamicResource Hg.Focus}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45" />
                            <Setter Property="Cursor" Value="Arrow" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="TabControl">
        <Setter Property="Background" Value="{DynamicResource Hg.Bg}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
    </Style>

    <Style TargetType="TabItem">
        <Setter Property="Foreground" Value="{DynamicResource Hg.Sub}" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabItem">
                    <Grid Margin="0,0,6,0">
                        <Border x:Name="FocusRing"
                                BorderBrush="{DynamicResource Hg.Focus}"
                                BorderThickness="2"
                                CornerRadius="8,8,0,0"
                                Margin="-2,-2,-2,0"
                                Opacity="0"
                                IsHitTestVisible="False" />
                        <Border x:Name="Chrome" Background="Transparent" CornerRadius="8,8,0,0"
                                BorderBrush="Transparent" BorderThickness="1,1,1,0"
                                Padding="14,9">
                            <ContentPresenter ContentSource="Header" />
                        </Border>
                        <!-- Accent bar marks the active tab beyond the surface change alone. -->
                        <Rectangle x:Name="ActiveIndicator" Height="3" Margin="10,0"
                                   VerticalAlignment="Bottom" RadiusX="1.5" RadiusY="1.5"
                                   Fill="{DynamicResource Hg.Teal}" Visibility="Collapsed" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource Hg.Panel}" />
                            <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource Hg.S0}" />
                            <Setter TargetName="ActiveIndicator" Property="Visibility" Value="Visible" />
                            <Setter Property="Foreground" Value="{DynamicResource Hg.Text}" />
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsSelected" Value="False" />
                                <Condition Property="IsMouseOver" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource Hg.Command}" />
                            <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource Hg.S0}" />
                            <Setter Property="Foreground" Value="{DynamicResource Hg.Text}" />
                        </MultiTrigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource Hg.Focus}" />
                            <Setter TargetName="FocusRing" Property="Opacity" Value="1" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="DataGrid">
        <Setter Property="Background" Value="{DynamicResource Hg.Panel}" />
        <Setter Property="Foreground" Value="{DynamicResource Hg.Text}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Hg.S0}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="RowBackground" Value="{DynamicResource Hg.Panel}" />
        <Setter Property="AlternatingRowBackground" Value="{DynamicResource Hg.PanelAlt}" />
        <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource Hg.S0}" />
        <Setter Property="VerticalGridLinesBrush" Value="{DynamicResource Hg.S0}" />
        <Setter Property="AutoGenerateColumns" Value="False" />
        <Setter Property="IsReadOnly" Value="True" />
        <Setter Property="HeadersVisibility" Value="Column" />
        <Setter Property="SelectionUnit" Value="FullRow" />
        <Setter Property="CanUserAddRows" Value="False" />
        <Setter Property="RowHeaderWidth" Value="0" />
        <Setter Property="SelectionMode" Value="Extended" />
        <Setter Property="ScrollViewer.CanContentScroll" Value="True" />
        <Setter Property="GridLinesVisibility" Value="Horizontal" />
    </Style>

    <!-- Invisible 6px-wide grab handles the DataGrid needs for column resizing. -->
    <Style x:Key="Hg.HeaderGripper" TargetType="Thumb">
        <Setter Property="Width" Value="6" />
        <Setter Property="Cursor" Value="SizeWE" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Rectangle Fill="Transparent" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="DataGridColumnHeader">
        <Setter Property="Background" Value="{DynamicResource Hg.Command}" />
        <Setter Property="Foreground" Value="{DynamicResource Hg.Sub}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Hg.S0}" />
        <Setter Property="BorderThickness" Value="0,0,1,1" />
        <Setter Property="Padding" Value="10,8" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="DataGridColumnHeader">
                    <Grid>
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <StackPanel Orientation="Horizontal">
                                <ContentPresenter VerticalAlignment="Center" RecognizesAccessKey="True" />
                                <Path x:Name="SortArrow" Margin="6,0,0,0" VerticalAlignment="Center"
                                      Data="M 0 4 L 3.5 0 L 7 4" Visibility="Collapsed"
                                      Stroke="{DynamicResource Hg.Blue}" StrokeThickness="1.4"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" />
                            </StackPanel>
                        </Border>
                        <Thumb x:Name="PART_LeftHeaderGripper" HorizontalAlignment="Left"
                               Style="{StaticResource Hg.HeaderGripper}" />
                        <Thumb x:Name="PART_RightHeaderGripper" HorizontalAlignment="Right"
                               Style="{StaticResource Hg.HeaderGripper}" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="SortDirection" Value="Ascending">
                            <Setter TargetName="SortArrow" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="SortDirection" Value="Descending">
                            <Setter TargetName="SortArrow" Property="Visibility" Value="Visible" />
                            <Setter TargetName="SortArrow" Property="Data" Value="M 0 0 L 3.5 4 L 7 0" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource Hg.RowHover}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="DataGridRow">
        <Setter Property="Foreground" Value="{DynamicResource Hg.Text}" />
        <Setter Property="MinHeight" Value="34" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource Hg.RowHover}" />
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{DynamicResource Hg.Sel}" />
            </Trigger>
            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                <Setter Property="Background" Value="{DynamicResource Hg.Sel}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="DataGridCell">
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="Padding" Value="10,5" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="DataGridCell">
                    <Grid>
                        <Border x:Name="FocusRing"
                                BorderBrush="{DynamicResource Hg.Focus}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Opacity="0"
                                IsHitTestVisible="False" />
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter TargetName="FocusRing" Property="Opacity" Value="1" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{DynamicResource Hg.Sel}" />
                <Setter Property="Foreground" Value="{DynamicResource Hg.Text}" />
            </Trigger>
            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                <Setter Property="BorderBrush" Value="{DynamicResource Hg.Focus}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ─── Scrollbars: slim themed track + rounded thumb (replaces the system-
             gray Aero chrome, which ignores the dark palette entirely). ─── -->
    <Style x:Key="Hg.ScrollPageButton" TargetType="RepeatButton">
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RepeatButton">
                    <Rectangle Fill="Transparent" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Hg.ScrollThumb" TargetType="Thumb">
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Border x:Name="ThumbChrome" Background="{DynamicResource Hg.S1}"
                            CornerRadius="4" Margin="2" />
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ThumbChrome" Property="Background" Value="{DynamicResource Hg.S2}" />
                        </Trigger>
                        <Trigger Property="IsDragging" Value="True">
                            <Setter TargetName="ThumbChrome" Property="Background" Value="{DynamicResource Hg.S2}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ScrollBar">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Width" Value="12" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Grid Background="{TemplateBinding Background}">
                        <Track x:Name="PART_Track" IsDirectionReversed="True">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Command="ScrollBar.PageUpCommand" Style="{StaticResource Hg.ScrollPageButton}" />
                            </Track.DecreaseRepeatButton>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Command="ScrollBar.PageDownCommand" Style="{StaticResource Hg.ScrollPageButton}" />
                            </Track.IncreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb Style="{StaticResource Hg.ScrollThumb}" />
                            </Track.Thumb>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="Orientation" Value="Horizontal">
                <Setter Property="Width" Value="Auto" />
                <Setter Property="Height" Value="12" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ScrollBar">
                            <Grid Background="{TemplateBinding Background}">
                                <Track x:Name="PART_Track">
                                    <Track.DecreaseRepeatButton>
                                        <RepeatButton Command="ScrollBar.PageLeftCommand" Style="{StaticResource Hg.ScrollPageButton}" />
                                    </Track.DecreaseRepeatButton>
                                    <Track.IncreaseRepeatButton>
                                        <RepeatButton Command="ScrollBar.PageRightCommand" Style="{StaticResource Hg.ScrollPageButton}" />
                                    </Track.IncreaseRepeatButton>
                                    <Track.Thumb>
                                        <Thumb Style="{StaticResource Hg.ScrollThumb}" />
                                    </Track.Thumb>
                                </Track>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="StatusBar">
        <Setter Property="Background" Value="{DynamicResource Hg.Crust}" />
        <Setter Property="Foreground" Value="{DynamicResource Hg.Sub}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Hg.S0}" />
        <Setter Property="BorderThickness" Value="0,1,0,0" />
        <Setter Property="MinHeight" Value="30" />
        <Setter Property="Padding" Value="4,1" />
    </Style>

    <!-- StatusBar separators resolve through their own style key, not the
         implicit Separator style — without this they render in system colors. -->
    <Style x:Key="{x:Static StatusBar.SeparatorStyleKey}" TargetType="Separator">
        <Setter Property="Background" Value="{DynamicResource Hg.S0}" />
        <Setter Property="Width" Value="1" />
        <Setter Property="Margin" Value="8,3" />
    </Style>

    <Style TargetType="GroupBox">
        <Setter Property="Foreground" Value="{DynamicResource Hg.Sub}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Hg.S0}" />
    </Style>

    <!-- Retemplated so the corners can round without the square popup surface
         showing through: HasDropShadow=True makes the popup transparency-capable,
         the control Background is Transparent, and the rounded Border paints the
         fill — no white corner artifacts. -->
    <Style TargetType="ToolTip">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource Hg.Text}" />
        <Setter Property="Padding" Value="8,6" />
        <Setter Property="MaxWidth" Value="420" />
        <Setter Property="HasDropShadow" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToolTip">
                    <Border Background="{DynamicResource Hg.Mantle}"
                            BorderBrush="{DynamicResource Hg.S1}" BorderThickness="1"
                            CornerRadius="6" Padding="{TemplateBinding Padding}">
                        <ContentPresenter />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Fully retemplated: the default template ships system drop-shadow
         chrome and scroll buttons that stay light in dark mode. -->
    <Style TargetType="ContextMenu">
        <Setter Property="Background" Value="{DynamicResource Hg.Mantle}" />
        <Setter Property="Foreground" Value="{DynamicResource Hg.Text}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Hg.S1}" />
        <Setter Property="Padding" Value="4" />
        <!-- HasDropShadow stays default-true: it makes the popup surface
             transparency-capable, which the rounded corners need. -->
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ContextMenu">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="1" CornerRadius="6"
                            Padding="{TemplateBinding Padding}">
                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Cycle" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Separators inside menus resolve MenuItem.SeparatorStyleKey, not the
         implicit Separator style — without this they render in system colors. -->
    <Style x:Key="{x:Static MenuItem.SeparatorStyleKey}" TargetType="Separator">
        <Setter Property="Background" Value="{DynamicResource Hg.S0}" />
        <Setter Property="Height" Value="1" />
        <Setter Property="Margin" Value="6,4" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Separator">
                    <Rectangle Height="1" Fill="{TemplateBinding Background}" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="Menu">
        <Setter Property="Background" Value="{DynamicResource Hg.Crust}" />
        <Setter Property="Foreground" Value="{DynamicResource Hg.Text}" />
        <Setter Property="Padding" Value="4,2" />
    </Style>

    <!-- Top-level menu-bar item: plain label, dropdown opens BELOW. -->
    <ControlTemplate x:Key="Hg.TopLevelMenuItem" TargetType="MenuItem">
        <Border x:Name="Chrome" Background="Transparent" CornerRadius="4" Padding="{TemplateBinding Padding}">
            <Grid>
                <ContentPresenter ContentSource="Header" VerticalAlignment="Center" RecognizesAccessKey="True" />
                <Popup x:Name="PART_Popup" Placement="Bottom" VerticalOffset="2"
                       IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                       AllowsTransparency="True" Focusable="False">
                    <Border Background="{DynamicResource Hg.Mantle}"
                            BorderBrush="{DynamicResource Hg.S1}" BorderThickness="1"
                            CornerRadius="6" Padding="4" MinWidth="220">
                        <ItemsPresenter />
                    </Border>
                </Popup>
            </Grid>
        </Border>
        <ControlTemplate.Triggers>
            <Trigger Property="IsHighlighted" Value="True">
                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource Hg.Sel}" />
            </Trigger>
            <Trigger Property="IsSubmenuOpen" Value="True">
                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource Hg.Sel}" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.45" />
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <!-- Context/submenu roles by default; top-level roles swap templates via
         triggers below. The default template highlights in system blue and
         paints a light icon gutter; this one stays on Hg.* tokens and shows
         IsChecked marks. -->
    <Style TargetType="MenuItem">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource Hg.Text}" />
        <Setter Property="Padding" Value="6,6" />
        <Setter Property="MinHeight" Value="28" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="MenuItem">
                    <Border x:Name="Chrome" Background="{TemplateBinding Background}" CornerRadius="4"
                            Padding="{TemplateBinding Padding}" MinHeight="{TemplateBinding MinHeight}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="18" />
                            </Grid.ColumnDefinitions>
                            <Path x:Name="CheckGlyph" Grid.Column="0" Visibility="Hidden"
                                  Data="M 0 4 L 3 7 L 8 0" VerticalAlignment="Center"
                                  Stroke="{DynamicResource Hg.Blue}" StrokeThickness="1.6"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" />
                            <ContentPresenter Grid.Column="1" ContentSource="Header"
                                              VerticalAlignment="Center" RecognizesAccessKey="True" />
                            <Path x:Name="SubmenuChevron" Grid.Column="2" Visibility="Collapsed"
                                  Data="M 0 0 L 4 4 L 0 8" HorizontalAlignment="Right" VerticalAlignment="Center"
                                  Stroke="{DynamicResource Hg.Sub}" StrokeThickness="1.5"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" />
                            <Popup x:Name="PART_Popup" Placement="Right" HorizontalOffset="2" VerticalOffset="-8"
                                   IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                   AllowsTransparency="True" Focusable="False">
                                <Border Background="{DynamicResource Hg.Mantle}"
                                        BorderBrush="{DynamicResource Hg.S1}" BorderThickness="1"
                                        CornerRadius="6" Padding="4">
                                    <ItemsPresenter />
                                </Border>
                            </Popup>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Role" Value="SubmenuHeader">
                            <Setter TargetName="SubmenuChevron" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="CheckGlyph" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource Hg.Sel}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="Role" Value="TopLevelHeader">
                <Setter Property="Template" Value="{StaticResource Hg.TopLevelMenuItem}" />
                <Setter Property="Padding" Value="10,4" />
                <Setter Property="MinHeight" Value="0" />
            </Trigger>
            <Trigger Property="Role" Value="TopLevelItem">
                <Setter Property="Template" Value="{StaticResource Hg.TopLevelMenuItem}" />
                <Setter Property="Padding" Value="10,4" />
                <Setter Property="MinHeight" Value="0" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="Separator">
        <Setter Property="Background" Value="{DynamicResource Hg.S0}" />
        <Setter Property="Margin" Value="2,4" />
    </Style>

    <!-- Down-expanding only (the sole direction the app uses). The default
         template's arrow circle draws in hardcoded system grays. -->
    <Style TargetType="Expander">
        <Setter Property="Foreground" Value="{DynamicResource Hg.Text}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Expander">
                    <StackPanel>
                        <ToggleButton x:Name="HeaderSite" Cursor="Hand"
                                      Foreground="{TemplateBinding Foreground}"
                                      Content="{TemplateBinding Header}"
                                      ContentTemplate="{TemplateBinding HeaderTemplate}"
                                      IsChecked="{Binding IsExpanded, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border x:Name="Chrome" Background="Transparent" CornerRadius="4"
                                            BorderBrush="Transparent" BorderThickness="1"
                                            Padding="4,3" HorizontalAlignment="Left">
                                        <StackPanel Orientation="Horizontal">
                                            <Path x:Name="Chevron" Data="M 0 0 L 4 4 L 0 8" Margin="2,0,8,0"
                                                  VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5"
                                                  Stroke="{DynamicResource Hg.Sub}" StrokeThickness="1.5"
                                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round">
                                                <Path.RenderTransform>
                                                    <RotateTransform Angle="0" />
                                                </Path.RenderTransform>
                                            </Path>
                                            <ContentPresenter VerticalAlignment="Center" RecognizesAccessKey="True" />
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="Chevron" Property="RenderTransform">
                                                <Setter.Value>
                                                    <RotateTransform Angle="90" />
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource Hg.S0}" />
                                        </Trigger>
                                        <Trigger Property="IsKeyboardFocused" Value="True">
                                            <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource Hg.Focus}" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>
                        <ContentPresenter x:Name="ExpandSite" Visibility="Collapsed" Margin="0,4,0,0" />
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsExpanded" Value="True">
                            <Setter TargetName="ExpandSite" Property="Visibility" Value="Visible" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ComboBoxItem">
        <Setter Property="Foreground" Value="{DynamicResource Hg.Text}" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Border x:Name="Chrome" Background="Transparent" Padding="{TemplateBinding Padding}" CornerRadius="4">
                        <ContentPresenter />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource Hg.Sel}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ComboBox">
        <Setter Property="Foreground" Value="{DynamicResource Hg.Text}" />
        <Setter Property="Background" Value="{DynamicResource Hg.S0}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Hg.S1}" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="MinHeight" Value="32" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <ToggleButton x:Name="Toggle" Focusable="False" ClickMode="Press"
                                      IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border x:Name="Chrome"
                                            Background="{Binding Background, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                            BorderBrush="{Binding BorderBrush, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                            BorderThickness="1" CornerRadius="6">
                                        <Path HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,8,0"
                                              Data="M 0 0 L 4 4 L 8 0"
                                              Stroke="{DynamicResource Hg.Sub}" StrokeThickness="1.5" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource Hg.S1}" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>
                        <!-- Right margin reserves room for the chevron so long values never sit under it. -->
                        <ContentPresenter Margin="8,4,22,4"
                                          HorizontalAlignment="Left" VerticalAlignment="Center"
                                          IsHitTestVisible="False"
                                          Content="{TemplateBinding SelectionBoxItem}"
                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" />
                        <Popup IsOpen="{TemplateBinding IsDropDownOpen}" Placement="Bottom"
                               AllowsTransparency="True" StaysOpen="False">
                            <Border Background="{DynamicResource Hg.Mantle}"
                                    BorderBrush="{DynamicResource Hg.S1}" BorderThickness="1"
                                    CornerRadius="6" Padding="4" Margin="0,2,0,0"
                                    MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                                <ScrollViewer MaxHeight="240">
                                    <ItemsPresenter />
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="BorderBrush" Value="{DynamicResource Hg.S2}" />
                        </Trigger>
                        <!-- Keyboard focus visibility (WCAG 2.4.7): the ToggleButton
                             Chrome binds its BorderBrush to the ComboBox's, so
                             recoloring the ComboBox border shows a focus ring.
                             Listed after hover so focus wins when both apply. -->
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter Property="BorderBrush" Value="{DynamicResource Hg.Focus}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45" />
                            <Setter Property="Cursor" Value="Arrow" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
